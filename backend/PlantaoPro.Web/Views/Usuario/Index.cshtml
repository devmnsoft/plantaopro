@using PlantaoPro.Web.Models.ViewModels
@model UserSettingsViewModel
@{ ViewData["Title"] = "Configurações do Usuário"; }

<div class="data-card p-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <h4 class="mb-0">Meu Perfil</h4>
        <span class="badge bg-light text-dark border">Conta ativa</span>
    </div>

    <dl class="row mb-4">
        <dt class="col-sm-3">Nome</dt><dd class="col-sm-9">@Model.Nome</dd>
        <dt class="col-sm-3">E-mail</dt><dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Telefone</dt><dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Telefone) ? "Não informado" : Model.Telefone)</dd>
        <dt class="col-sm-3">Notificações</dt><dd class="col-sm-9">@Model.PreferenciasNotificacao</dd>
    </dl>

    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-action="Edit"><i class="bi bi-pencil"></i> Editar dados</a>
        <a class="btn btn-outline-primary" asp-action="AlterarSenha"><i class="bi bi-key"></i> Alterar senha</a>
        <button class="btn btn-outline-secondary" disabled title="Ação indisponível">2FA</button>
    </div>
</div>
