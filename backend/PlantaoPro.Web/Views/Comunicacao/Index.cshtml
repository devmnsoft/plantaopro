@model IEnumerable<PlantaoPro.Web.Models.ConversaListViewModel>
@{ ViewData["Title"] = "Comunicação"; }
<div class="page-header mb-3"><h2>Central de Comunicação</h2><p class="text-muted">Converse com coordenação, financeiro e médicos.</p></div>
<div class="row">
    <div class="col-12 col-lg-4">
        <div class="card"><div class="card-body">
            <a class="btn btn-primary w-100 mb-3" asp-action="NovaConversa">Nova conversa</a>
            @if (!Model.Any()) { <div class="alert alert-info mb-0">Nenhuma conversa encontrada.</div> }
            else { <div class="list-group">@foreach (var c in Model){<a class="list-group-item list-group-item-action d-flex justify-content-between" asp-action="Details" asp-route-id="@c.Id"><span>@c.Titulo</span><span class="badge bg-primary rounded-pill">@c.NaoLidas</span></a>}</div> }
        </div></div>
    </div>
    <div class="col-12 col-lg-8"><div class="card"><div class="card-body text-muted">Selecione uma conversa ao lado para visualizar as mensagens.</div></div></div>
</div>
