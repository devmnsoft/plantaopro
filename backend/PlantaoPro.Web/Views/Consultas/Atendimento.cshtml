@{
    ViewData["Title"] = "Atendimento médico";
}
<section class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <p class="text-uppercase text-primary fw-semibold small mb-1">PlantãoPro Saúde 360</p>
            <h1 class="h3 mb-1">Atendimento médico</h1>
            <p class="text-muted mb-0">Triagem finalizada, consulta, CID, conduta e prescrição vinculada.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#confirmarFinalizacao">Finalizar consulta</button>
            <a asp-controller="Consultas" asp-action="Imprimir" class="btn btn-primary">Imprimir resumo</a>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-lg-4"><div class="card border-0 shadow-sm h-100"><div class="card-body"><h2 class="h6">Dados do paciente</h2><p class="text-muted">Identificação, alergias e dados administrativos visíveis por permissão.</p></div></div></div>
        <div class="col-lg-4"><div class="card border-0 shadow-sm h-100"><div class="card-body"><h2 class="h6">Dados da triagem</h2><p class="text-muted">Classificação de risco, queixa principal e sinais vitais.</p></div></div></div>
        <div class="col-lg-4"><div class="card border-0 shadow-sm h-100"><div class="card-body"><h2 class="h6">Prescrição vinculada</h2><p class="text-muted">Rascunho, modelos rápidos, finalização e impressão auditada.</p></div></div></div>
        <div class="col-lg-6"><label class="form-label">Anamnese</label><textarea class="form-control" rows="5" maxlength="4000"></textarea></div>
        <div class="col-lg-6"><label class="form-label">Exame físico</label><textarea class="form-control" rows="5" maxlength="4000"></textarea></div>
        <div class="col-lg-6"><label class="form-label">Diagnóstico / CID</label><input class="form-control" placeholder="Buscar por código ou descrição" maxlength="120" /></div>
        <div class="col-lg-6"><label class="form-label">Conduta</label><input class="form-control" maxlength="500" /></div>
    </div>
    <div class="toast-container position-fixed bottom-0 end-0 p-3"><div class="toast show" role="status"><div class="toast-body">Rascunho pronto para salvar com auditoria clínica.</div></div></div>
</section>
<div class="modal fade" id="confirmarFinalizacao" tabindex="-1" aria-labelledby="confirmarFinalizacaoLabel" aria-hidden="true">
    <div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h2 class="modal-title h5" id="confirmarFinalizacaoLabel">Finalizar consulta?</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button></div><div class="modal-body">A finalização bloqueia edição comum e registra auditoria clínica.</div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Voltar</button><button type="button" class="btn btn-primary" data-bs-dismiss="modal">Confirmar</button></div></div></div>
</div>
