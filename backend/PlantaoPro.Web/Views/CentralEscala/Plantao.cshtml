@model PlantaoPro.Web.Models.PlantaoDetailsDto?
@{
    ViewData["Title"] = "Plantão - Central de Escala";
}

<div class="mb-3">
    <a asp-controller="CentralEscala" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @ViewBag.ErrorMessage</div>
}

@if (Model != null)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>@Model.HospitalNome</strong>
            <span class="badge text-bg-primary">@Model.Status</span>
        </div>
        <div class="card-body">
            <h4>@Model.EspecialidadeNome</h4>
            <p class="text-muted mb-2">@Model.HospitalCidade/@Model.HospitalEstado</p>
            <div class="row g-3">
                <div class="col-md-3"><small>Início</small><div>@Model.DataInicio.ToString("dd/MM/yyyy HH:mm")</div></div>
                <div class="col-md-3"><small>Fim</small><div>@Model.DataFim.ToString("dd/MM/yyyy HH:mm")</div></div>
                <div class="col-md-3"><small>Vagas</small><div>@Model.VagasDisponiveis / @Model.Vagas</div></div>
                <div class="col-md-3"><small>Valor</small><div>@Model.Valor.ToString("C")</div></div>
            </div>
            <hr />
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Plantoes" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">Detalhes completos</a>
                <a asp-controller="Escalas" asp-action="Index" asp-route-plantaoId="@Model.Id" class="btn btn-outline-success">Escalas</a>
                <a asp-controller="Agenda" asp-action="Index" class="btn btn-outline-secondary">Agenda</a>
            </div>
        </div>
    </div>
}
