@{
    var messages = new[] { ("Success", "success"), ("Error", "error"), ("Warning", "warning"), ("Info", "info") }
        .Where(x => TempData[x.Item1] is string text && !string.IsNullOrWhiteSpace(text))
        .Select(x => new { Type = x.Item2, Message = (TempData[x.Item1] as string)! })
        .ToList();
}
@if (messages.Any())
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            @foreach (var toast in messages)
            {
                @:window.PlantaoProToast?.@toast.Type("@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(toast.Message))");
            }
        });
    </script>
}
