@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.EscalaResumoDto>
@{ var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.EscalaResumoDto>(); var total=items.Count(); var solicitado=items.Count(x=>x.Status=="solicitado"); var confirmado=items.Count(x=>x.Status=="confirmado"); var realizado=items.Count(x=>x.Status=="realizado"); var cancelado=items.Count(x=>x.Status=="cancelado"); }
<div class="page-header d-flex justify-content-between align-items-start gap-3 mb-4"><div><h2 class="mb-1">Escalas Médicas</h2><p class="text-muted mb-0">Tela principal de operação das confirmações e execução de plantões.</p></div><div><button class="btn btn-primary" disabled title="Em breve">Nova Escala</button></div></div>
<div class="row g-3 mb-3">
    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Total</div>
            <div class="metric-value">@total</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Solicitadas</div>
            <div class="metric-value">@solicitado</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Confirmadas</div>
            <div class="metric-value">@confirmado</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Realizadas</div>
            <div class="metric-value">@realizado</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Canceladas</div>
            <div class="metric-value">@cancelado</div>
        </div>
    </div>
</div>

<div class="filter-card mb-3">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select class="form-select" name="status" disabled>
                <option value="">Todos</option>
                <option value="solicitado">Solicitado</option>
                <option value="confirmado">Confirmado</option>
                <option value="realizado">Realizado</option>
                <option value="cancelado">Cancelado</option>
                <option value="recusado">Recusado</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Hospital</label>
            <input class="form-control"
                   name="hospital"
                   placeholder="Hospital ou clínica"
                   disabled />
        </div>

        <div class="col-md-3">
            <label class="form-label">Especialidade</label>
            <input class="form-control"
                   name="especialidade"
                   placeholder="Especialidade"
                   disabled />
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="button"
                    class="btn btn-soft-primary w-100"
                    disabled
                    title="Em breve">
                <i class="bi bi-funnel me-1"></i>
                Filtrar
            </button>

            <button type="button"
                    class="btn btn-outline-secondary w-100"
                    disabled
                    title="Em breve">
                Limpar
            </button>
        </div>
    </form>
</div>
<div class="data-card card"><div class="card-body p-0"><div class="table-responsive"><table class="table table-modern align-middle"><thead><tr><th>Médico</th><th>Hospital</th><th>Especialidade</th><th>Data/hora</th><th>Valor</th><th>Status</th><th>Justificativa</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var e in items){<tr><td><div class="fw-semibold">@e.MedicoNome</div><small class="text-muted">CRM @e.MedicoCrm/@e.MedicoUfCrm</small></td><td>@e.HospitalNome</td><td>@e.EspecialidadeNome</td><td>@e.DataInicio.ToString("dd/MM/yyyy HH:mm") - @e.DataFim.ToString("HH:mm")</td><td>@e.Valor.ToString("C")</td><td><partial name="_StatusBadge" model="e.Status"/></td><td>@(string.IsNullOrWhiteSpace(e.Justificativa)?"-":e.Justificativa)</td><td class="action-buttons"><a class="btn btn-sm btn-soft-primary" asp-action="Details" asp-route-id="@e.Id">Detalhes</a><button class="btn btn-sm btn-soft-success" disabled title="Em breve">Confirmar</button><button class="btn btn-sm btn-soft-danger" disabled title="Em breve">Recusar</button><button class="btn btn-sm btn-soft-warning" disabled title="Em breve">Cancelar</button><button class="btn btn-sm btn-outline-success" disabled title="Em breve">Realizado</button><button class="btn btn-sm btn-outline-primary" disabled title="Em breve">Pagamento</button></td></tr>}
@if(!items.Any()){<tr><td colspan="8"><div class="empty-state text-center"><div class="empty-state-icon"><i class="bi bi-calendar2-x"></i></div><h5 class="mb-2">Sem escalas</h5><p class="text-muted mb-3">Nenhuma escala encontrada para os filtros atuais.</p></div></td></tr>}
</tbody></table></div></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model"/></div></div>
