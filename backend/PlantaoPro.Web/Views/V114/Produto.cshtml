@model PlantaoPro.Web.Controllers.V114ProdutoWebPage
@{
    ViewData["Title"] = Model.Title;
}
<section class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <span class="badge text-bg-primary">v1.14 PlantãoPro</span>
            <h1 class="h3 mt-2 mb-1">@Model.Title</h1>
            <p class="text-muted mb-0">@Model.Subtitle</p>
        </div>
        <a class="btn btn-outline-primary" href="/Operacao">Central O que fazer agora</a>
    </div>
    <div class="alert alert-info" role="status">Dados carregados por APIs <code>@Model.Endpoint</code> com autenticação, tenant, perfil e auditoria. Módulos bloqueados exibem mensagem amigável.</div>
    <div class="row g-3">
        <div class="col-lg-4"><div class="card h-100"><div class="card-body"><h2 class="h6">Filtros salvos</h2><p class="small text-muted">Busca, tipo, status, perfil responsável e período.</p><span class="badge text-bg-light">Usuário atual</span></div></div></div>
        <div class="col-lg-4"><div class="card h-100"><div class="card-body"><h2 class="h6">Timeline auditada</h2><p class="small text-muted">Paciente, atendimento, plantão ou financeiro conforme a tela.</p><span class="badge text-bg-warning">LGPD</span></div></div></div>
        <div class="col-lg-4"><div class="card h-100"><div class="card-body"><h2 class="h6">Ações rápidas</h2><p class="small text-muted">Favoritos, últimos acessados, checklist e próximas ações.</p><span class="badge text-bg-success">Integrado</span></div></div></div>
    </div>
    <div class="card mt-3"><div class="card-body"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Entidade</th><th>Status</th><th>Perfil</th><th>CTA</th></tr></thead><tbody><tr><td>@Model.Title</td><td><span class="badge text-bg-secondary">Pendente QA funcional</span></td><td>Conforme RBAC</td><td><a class="btn btn-sm btn-primary" href="/@ViewContext.RouteData.Values["controller"]">Abrir</a></td></tr></tbody></table></div></div></div>
</section>
