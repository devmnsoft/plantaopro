@{
    ViewData["Title"] = "Marketplace";
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Marketplace de módulos", "Entenda módulos inclusos, bloqueados e disponíveis para upgrade sem exibir erro técnico ao cliente.", "bi-bag-plus")' />
<div class="row g-3 mb-4">
    <div class="col-md-4"><partial name="_KpiCard" model='new PlantaoPro.Web.Models.KpiCardViewModel("Plano atual", "Profissional", "White label básico incluso", "bi-gem", null, "primary")' /></div>
    <div class="col-md-4"><partial name="_KpiCard" model='new PlantaoPro.Web.Models.KpiCardViewModel("Módulos inclusos", "7", "Operação, financeiro e relatórios", "bi-check2-circle", null, "success")' /></div>
    <div class="col-md-4"><partial name="_KpiCard" model='new PlantaoPro.Web.Models.KpiCardViewModel("Oportunidades", "3", "BI avançado, API e revenda", "bi-rocket", null, "warning")' /></div>
</div>
<div class="row g-4">
    @foreach (var modulo in new[] { new { Nome = "BI Avançado", Status = "Disponível para upgrade", Icone = "bi-bar-chart" }, new { Nome = "API Enterprise", Status = "Bloqueado pelo plano", Icone = "bi-code-slash" }, new { Nome = "Revenda white label", Status = "Enterprise/Revendedor", Icone = "bi-handshake" } })
    {
        <div class="col-lg-4"><div class="module-card"><div class="module-icon mb-3"><i class="bi @modulo.Icone"></i></div><h2 class="h5">@modulo.Nome</h2><p class="text-muted">@modulo.Status</p><partial name="_ModuleLockedNotice" model='@("Para contratar este módulo, solicite upgrade com o time comercial.")' /></div></div>
    }
</div>
