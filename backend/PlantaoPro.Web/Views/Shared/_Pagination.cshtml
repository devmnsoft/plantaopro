@model dynamic
@{
    var total = (long?)(Model?.Total) ?? 0;
    var page = (int?)(Model?.Page) ?? 1;
    var pageSize = (int?)(Model?.PageSize) ?? 20;
    var totalPages = (int?)(Model?.TotalPages) ?? 0;
}
@if (totalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small>Total: @total | Página @page / @totalPages</small>
        <div>
            <a class="btn btn-sm btn-outline-secondary @(page <= 1 ? "disabled" : "")" href="?page=@(page-1)&pageSize=@pageSize">Anterior</a>
            <a class="btn btn-sm btn-outline-secondary @(page >= totalPages ? "disabled" : "")" href="?page=@(page+1)&pageSize=@pageSize">Próximo</a>
        </div>
    </div>
}
