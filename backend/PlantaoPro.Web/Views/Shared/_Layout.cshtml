<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PlantãoPro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" />
</head>
<body class="app-body">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="d-flex">
            <aside class="sidebar p-3"><h4>PlantãoPro</h4><ul class="nav flex-column gap-2 mt-3"><li><a asp-controller="Home" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li><li><a href="#"><i class="bi bi-people"></i> Médicos</a></li><li><a href="#"><i class="bi bi-hospital"></i> Hospitais/Clínicas</a></li><li><a href="#"><i class="bi bi-heart-pulse"></i> Especialidades</a></li><li><a href="#"><i class="bi bi-calendar2-week"></i> Plantões</a></li><li><a href="#"><i class="bi bi-diagram-3"></i> Escalas</a></li><li><a href="#"><i class="bi bi-cash-coin"></i> Financeiro</a></li><li><a href="#"><i class="bi bi-bell"></i> Notificações</a></li><li><a href="#"><i class="bi bi-file-earmark-bar-graph"></i> Relatórios</a></li><li><a href="#"><i class="bi bi-gear"></i> Configurações</a></li><li><a asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Sair</a></li></ul></aside>
            <main class="flex-grow-1 p-4">
                <div class="topbar mb-3"><span>Olá, @User.Identity?.Name</span></div>
                <partial name="_ToastMessages" />
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <partial name="_ToastMessages" />
        @RenderBody()
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>
