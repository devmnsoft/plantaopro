<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PlantãoPro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" />
</head>
<body class="app-body">
    @{ var currentController = ViewContext.RouteData.Values["controller"]?.ToString(); }
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="d-flex">
            <aside class="sidebar p-3"><h4>PlantãoPro</h4><ul class="nav flex-column gap-2 mt-3">
                <li><a class="@(currentController=="Home"?"active":"")" asp-controller="Home" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                <li><a class="@(currentController=="Medicos"?"active":"")" asp-controller="Medicos" asp-action="Index"><i class="bi bi-people"></i> Médicos</a></li>
                <li><a class="@(currentController=="Hospitais"?"active":"")" asp-controller="Hospitais" asp-action="Index"><i class="bi bi-hospital"></i> Hospitais/Clínicas</a></li>
                <li><a class="@(currentController=="Especialidades"?"active":"")" asp-controller="Especialidades" asp-action="Index"><i class="bi bi-heart-pulse"></i> Especialidades</a></li>
                <li><a class="@(currentController=="Plantoes"?"active":"")" asp-controller="Plantoes" asp-action="Index"><i class="bi bi-calendar2-week"></i> Plantões</a></li>
                <li><a class="@(currentController=="Escalas"?"active":"")" asp-controller="Escalas" asp-action="Index"><i class="bi bi-diagram-3"></i> Escalas</a></li>
                <li><a class="@(currentController=="Financeiro"?"active":"")" asp-controller="Financeiro" asp-action="Index"><i class="bi bi-cash-coin"></i> Financeiro</a></li>
                <li><a class="@(currentController=="Notificacoes"?"active":"")" asp-controller="Notificacoes" asp-action="Index"><i class="bi bi-bell"></i> Notificações</a></li>
                <li><a class="@(currentController=="MinhaAgenda"?"active":"")" asp-controller="MinhaAgenda" asp-action="Index"><i class="bi bi-calendar-check"></i> Minha Agenda</a></li>
                <li><a class="@(currentController=="Auditoria"?"active":"")" asp-controller="Auditoria" asp-action="Index"><i class="bi bi-shield-check"></i> Auditoria</a></li>
                <li><a class="@(currentController=="Relatorios"?"active":"")" asp-controller="Relatorios" asp-action="Index"><i class="bi bi-file-earmark-bar-graph"></i> Relatórios</a></li>
                <li><a class="@(currentController=="Configuracoes"?"active":"")" asp-controller="Configuracoes" asp-action="Index"><i class="bi bi-gear"></i> Configurações</a></li>
                <li><a asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Sair</a></li>
            </ul></aside>
            <main class="flex-grow-1 p-4">
                <div class="topbar mb-3 d-flex justify-content-between"><span>Olá, @User.Identity?.Name</span><a asp-controller="Notificacoes" asp-action="Index" class="btn btn-sm btn-light"><i class="bi bi-bell"></i> <span class="badge text-bg-danger">0</span></a></div>
                <partial name="_ToastMessages" />
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <partial name="_ToastMessages" />
        @RenderBody()
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>
