@model PlantaoPro.Web.Models.PlanoSaasViewModel
@{ ViewData["Title"] = "Detalhes do plano"; }
<div class="container py-3"><h1 class="h3">@Model.Nome</h1><div class="card"><div class="card-body"><p>@Model.Descricao</p><dl class="row"><dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge bg-secondary">@Model.Status</span></dd><dt class="col-sm-3">Valor mensal</dt><dd class="col-sm-9">@Model.ValorMensal.ToString("C")</dd><dt class="col-sm-3">Limites</dt><dd class="col-sm-9">@Model.LimiteMedicos médicos, @Model.LimiteHospitais hospitais, @Model.LimitePlantoesMes plantões/mês.</dd></dl><a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a> <a class="btn btn-outline-success" asp-action="Recursos" asp-route-id="@Model.Id">Recursos</a> <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a></div></div></div>
