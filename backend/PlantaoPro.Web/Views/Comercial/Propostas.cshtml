@model IEnumerable<PlantaoPro.Web.Models.ComercialPropostaViewModel>
@{ ViewData["Title"] = "Propostas SaaS"; }
<div class="card shadow-sm mb-3"><div class="card-body"><h2 class="h5">Gerar proposta</h2><form asp-action="CriarProposta" method="post" class="row g-2" data-ajax-form="true" data-confirm="true" data-confirm-title="Gerar proposta" data-confirm-message="Confirma gerar esta proposta comercial?" data-confirm-type="success">@Html.AntiForgeryToken()<div class="col-md-3"><input name="OportunidadeId" class="form-control" placeholder="ID oportunidade" required /></div><div class="col-md-3"><input name="PlanoNome" class="form-control" placeholder="Plano" required /></div><div class="col-md-2"><input name="ValorMensal" class="form-control" type="number" step="0.01" placeholder="Mensalidade" /></div><div class="col-md-2"><input name="DescontoPercentual" class="form-control" type="number" step="0.01" placeholder="Desconto %" /></div><div class="col-md-2"><input name="Validade" class="form-control" type="date" /></div><div class="col-12"><button class="btn btn-primary">Gerar proposta</button></div></form></div></div>
<div class="row g-3">@foreach (var item in Model) { <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><span class="badge text-bg-info">@item.Status</span><h3 class="h6 mt-2">@item.Numero</h3><p>@item.PlanoNome • @item.ValorMensal.ToString("C")</p><small>Desconto @item.DescontoPercentual% • válida até @item.Validade.ToShortDateString()</small></div></div></div> }</div>
