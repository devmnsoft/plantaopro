@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.EscalaResumoDto>
@{ var items = Model.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.EscalaResumoDto>(); }
<h2>Escalas</h2>
<table class="table">
<thead><tr><th>Médico</th><th>Hospital</th><th>Especialidade</th><th>Data/Hora</th><th>Valor</th><th>Status</th><th>Justificativa</th><th>Ações</th></tr></thead>
<tbody>
@foreach (var e in items){
<tr>
<td>@e.MedicoNome<br/><small>CRM @e.MedicoCrm/@e.MedicoUfCrm</small></td>
<td>@e.HospitalNome</td><td>@e.EspecialidadeNome</td>
<td>@e.DataInicio.ToString("dd/MM HH:mm") - @e.DataFim.ToString("dd/MM HH:mm")</td><td>@e.Valor.ToString("C")</td>
<td><partial name="_StatusBadge" model="e.Status"/></td><td>@(e.Justificativa??"-")</td>
<td><a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">Detalhes</a></td>
</tr>}
</tbody>
</table>
<partial name="_Pagination" model="Model" />
