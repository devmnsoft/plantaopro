@{
    ViewData["Title"] = "Relatórios gerenciais";
    var relatorios = new[] { "Plantões por período", "Escalas por médico", "Pagamentos médicos", "Produtividade médica", "Agendamentos", "Atendimentos clínicos", "Financeiro da Clínica", "Convênios e glosas", "Uso do Plano SaaS", "Auditoria" };
}
<h1>Relatórios gerenciais vendáveis</h1>
<p class="lead">Visões executivas com filtros, cards de resumo, tabela responsiva e bloqueio comercial para exportações ainda não auditadas.</p>
<div class="alert alert-warning">LGPD: relatórios clínicos exibem apenas o mínimo necessário por perfil e tenant.</div>
<div class="row g-3">
@foreach (var relatorio in relatorios)
{
    <div class="col-md-6"><article class="card h-100 shadow-sm"><div class="card-body">
        <h2 class="h5">Relatório de @relatorio</h2>
        <p>Filtros por período, unidade, médico, status e perfil responsável quando aplicável.</p>
        <button class="btn btn-secondary" type="button" disabled>Exportação futura bloqueada até auditoria</button>
    </div></article></div>
}
</div>
