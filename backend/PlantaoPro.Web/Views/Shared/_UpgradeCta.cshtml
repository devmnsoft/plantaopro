@model PlantaoPro.Web.Models.LockedResourceViewModel
<div class="upgrade-cta card card-body border-warning-subtle bg-warning-subtle">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div><strong>Desbloqueie @Model.Recurso</strong><div class="text-muted">@Model.Motivo</div></div>
        <div class="d-flex gap-2"><a class="btn btn-warning" asp-controller="MinhaAssinatura" asp-action="Upgrade">Solicitar upgrade</a><a class="btn btn-outline-dark" asp-controller="MinhaAssinatura" asp-action="Index">Minha assinatura</a></div>
    </div>
</div>
