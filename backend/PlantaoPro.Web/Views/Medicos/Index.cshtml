@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.MedicoDto>
<h1 class="h3">Médicos</h1><p class="text-muted">Gestão de médicos cadastrados</p>
<div class="card p-3 mb-3"><div class="row g-2"><div class="col"><input class="form-control" placeholder="Buscar por nome, CRM ou cidade"/></div><div class="col-auto"><button class="btn btn-primary" disabled>Filtrar</button> <button class="btn btn-outline-secondary" disabled>Novo Médico</button></div></div></div>
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage) || !string.IsNullOrWhiteSpace(ViewBag.ErrorMessage)) { <div class="alert alert-warning">@(Model?.ErrorMessage ?? ViewBag.ErrorMessage)</div> }
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Nome</th><th>CRM/UF</th><th>CPF</th><th>Email</th><th>Telefone</th><th>Cidade/UF</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var item in Model.Items){<tr><td>@item.Nome</td><td>@item.Crm/@item.UfCrm</td><td>@item.Cpf</td><td>@item.Email</td><td>@item.Telefone</td><td>@item.Cidade/@item.Estado</td><td><span class="badge @(item.RegStatus=="A"?"bg-success":"bg-secondary")">@(item.RegStatus=="A"?"Ativo":"Inativo")</span></td><td class="text-end"><button class="btn btn-sm btn-outline-primary" disabled>Ver</button></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="8" class="text-center text-muted py-4">Nenhum médico encontrado.</td></tr>}
</tbody></table></div>