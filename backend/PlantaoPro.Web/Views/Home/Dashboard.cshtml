@model DashboardOverviewDto
@using PlantaoPro.Web.Security
@{
    ViewData["Title"] = "Dashboard Executivo";
    var i = Model?.Indicadores;
    var proximos = Model?.ProximosPlantoes ?? Enumerable.Empty<PlantaoPro.Web.Models.PlantaoResumoDto>();
    var porEspecialidade = Model?.PlantoesPorEspecialidade ?? Enumerable.Empty<DashboardChartItem>();
    var porHospital = Model?.PlantoesPorHospital ?? Enumerable.Empty<DashboardChartItem>();
    var notificacoes = Model?.UltimasNotificacoes ?? Enumerable.Empty<NotificacaoDto>();

    var isAdmin = User.IsAdmin();
    var isCoord = User.IsCoordenacao();
    var isMed = User.IsMedico();
    var isFin = User.IsFinanceiro();
    var isHosp = User.IsHospital();

    var perfilLabel = isAdmin ? "Admin" : isCoord ? "Coordenação" : isMed ? "Médico" : isFin ? "Financeiro" : isHosp ? "Hospital" : "Operacional";
    var tituloVisao = isMed ? "Minha Agenda" : isFin ? "KPIs Financeiros" : isHosp ? "Visão da Unidade" : "Visão Operacional";
}

<div class="page-header mb-4 d-flex flex-wrap justify-content-between gap-3 align-items-start">
    <div>
        <img src="~/branding/logo-horizontal-dark.svg" class="dashboard-brand mb-2" alt="PlantãoPro" />
        <h2 class="page-title">Dashboard • @perfilLabel</h2>
        <p class="page-subtitle mb-0">@tituloVisao com indicadores atualizados, alertas visuais e ações rápidas.</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <span class="badge text-bg-light border">Perfil: @perfilLabel</span>
        <button class="btn btn-outline-secondary btn-sm" disabled title="Em breve">Exportar BI</button>
    </div>
</div>
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form class="row g-2">
            <div class="col-12 col-md-3"><input type="month" class="form-control form-control-sm" aria-label="Período" /></div>
            <div class="col-12 col-md-3"><input type="text" class="form-control form-control-sm" placeholder="Hospital" /></div>
            <div class="col-12 col-md-3"><input type="text" class="form-control form-control-sm" placeholder="Especialidade" /></div>
            <div class="col-12 col-md-3 d-grid"><button type="button" class="btn btn-outline-primary btn-sm" disabled title="Em breve">Aplicar filtros avançados</button></div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4 kpi-grid">
@foreach (var m in new[] {
("Plantões",(i?.TotalPlantoes ?? 0).ToString(),"bi-calendar2-week"),
("Confirmados",(i?.PlantoesConfirmados ?? 0).ToString(),"bi-check2-circle"),
("Pendentes",(i?.PagamentosPendentes ?? 0).ToString(),"bi-cash"),
("Notificações",(i?.NotificacoesNaoLidas ?? 0).ToString(),"bi-bell")
})
{
    <div class="col-6 col-lg-3"><div class="metric-card h-100"><div class="kpi-icon"><i class="bi @m.Item3"></i></div><div class="kpi-title">@m.Item1</div><div class="metric-value">@m.Item2</div></div></div>
}
</div>

<div class="row g-3">
    <div class="col-12 col-xxl-8">
        <div class="data-card card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@(isMed ? "Minha Agenda" : "Próximos plantões e escalas")</strong>
                <span class="badge text-bg-light border">Atualizado agora</span>
            </div>
            <div class="table-responsive">
                <table class="table table-modern"><thead><tr><th>Hospital</th><th>Especialidade</th><th>Início</th><th>Status</th></tr></thead><tbody>
                @if(proximos.Any())
                {
                    foreach(var p in proximos.Take(8))
                    {
                        <tr><td>@(p.HospitalNome ?? "—")</td><td>@(p.EspecialidadeNome ?? "—")</td><td>@p.DataInicio.ToString("dd/MM/yyyy HH:mm")</td><td><partial name="_StatusBadge" model="p.Status" /></td></tr>
                    }
                }
                else
                { <tr><td colspan="4"><div class="empty-state">Nenhum plantão encontrado no período selecionado.</div></td></tr> }
                </tbody></table>
            </div>
        </div>
    </div>
    <div class="col-12 col-xxl-4">
        <div class="data-card card h-100">
            <div class="card-header"><strong>@(isFin ? "KPIs Financeiros" : isHosp ? "Visão da Unidade" : "Distribuição")</strong></div>
            <div class="card-body">
                @if(isFin)
                {
                    <ul class="list-group list-group-flush"><li class="list-group-item d-flex justify-content-between"><span>Valor pendente</span><strong>@(i?.ValorPendente ?? 0).ToString("C")</strong></li><li class="list-group-item d-flex justify-content-between"><span>Pago no mês</span><strong>@(i?.ValorPagoMes ?? 0).ToString("C")</strong></li></ul>
                }
                else if(isHosp && porHospital.Any())
                {
                    foreach(var it in porHospital.Take(6)){<div class="d-flex justify-content-between border-bottom py-1"><span>@it.Label</span><strong>@it.Valor</strong></div>}
                }
                else if(porEspecialidade.Any())
                {
                    foreach(var it in porEspecialidade.Take(6)){<div class="mb-2"><div class="d-flex justify-content-between"><span>@it.Label</span><span>@it.Valor</span></div><div class="progress"><div class="progress-bar" style="width:@(Math.Min(it.Valor*10,100))%"></div></div></div>}
                }
                else
                { <div class="empty-state">Sem dados no período.</div> }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-12 col-xl-7"><div class="data-card card"><div class="card-header"><strong>Resumo visual da semana</strong></div><div class="card-body"><canvas id="kpiChart" height="100"></canvas></div></div></div>
    <div class="col-12 col-xl-5"><div class="data-card card"><div class="card-header d-flex justify-content-between"><strong>Notificações in-app</strong><a asp-controller="Notificacoes" asp-action="Index" class="small">Ver todas</a></div><div class="card-body">
        @if(notificacoes.Any()){
            foreach(var n in notificacoes.Take(5)){<div class="border-bottom py-2"><div class="d-flex justify-content-between"><strong>@n.Titulo</strong><span class="badge @(n.Lida ? "text-bg-light" : "text-bg-warning")">@(n.Lida ? "Lida" : "Nova")</span></div><div class="text-muted small">@n.Mensagem</div></div>}
        } else { <div class="empty-state">Sem notificações recentes.</div> }
    </div></div></div>
</div>

@section Scripts{
<script>
document.addEventListener("DOMContentLoaded",()=>{
  if(!window.Chart) return;
  const ctx=document.getElementById("kpiChart");
  if(!ctx) return;
  const labels=[@Html.Raw(string.Join(",", (Model?.PlantoesPorMes ?? Enumerable.Empty<DashboardChartItem>()).Select(x=>$"\"{x.Label}\"")))];
  const values=[@Html.Raw(string.Join(",", (Model?.PlantoesPorMes ?? Enumerable.Empty<DashboardChartItem>()).Select(x=>x.Valor.ToString(System.Globalization.CultureInfo.InvariantCulture))))];
  new Chart(ctx,{type:"bar",data:{labels:labels.length?labels:["Sem dados"],datasets:[{label:"Plantões por mês",data:values.length?values:[0],borderRadius:8,backgroundColor:"#155eef"}]},options:{plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}});
});
</script>
}
