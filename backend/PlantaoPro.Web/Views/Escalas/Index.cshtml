@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.EscalaResumoDto>

@{
    ViewData["Title"] = "Escalas";
    var items = Model?.Items ?? Array.Empty<PlantaoPro.Web.Models.EscalaResumoDto>();
}

<div class="page-header">
    <h2>Escalas Médicas</h2>
    <p class="text-muted">Acompanhe solicitações, confirmações e execução dos plantões.</p>
    <button class="btn btn-primary" disabled title="Em breve">Nova Escala</button>
</div>

@if (!items.Any())
{
    <div class="empty-state">
        <i class="bi bi-calendar2-x"></i>
        <h5>Sem escalas</h5>
        <p>Nenhuma escala encontrada para os filtros atuais.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-modern align-middle mb-0">
            <thead>
                <tr>
                    <th>Médico</th>
                    <th>Hospital</th>
                    <th>Especialidade</th>
                    <th>Data/Hora</th>
                    <th>Valor</th>
                    <th>Status</th>
                    <th>Justificativa</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in items)
                {
                    <tr>
                        <td>@e.MedicoNome</td>
                        <td>@e.HospitalNome</td>
                        <td>@e.EspecialidadeNome</td>
                        <td>@e.DataInicio.ToString("dd/MM/yyyy HH:mm") - @e.DataFim.ToString("HH:mm")</td>
                        <td>@e.Valor.ToString("C")</td>
                        <td><span class="badge status-@e.Status.ToLowerInvariant()">@e.Status</span></td>
                        <td>@(string.IsNullOrWhiteSpace(e.Justificativa) ? "-" : e.Justificativa)</td>
                        <td class="text-end">
                            <div class="action-buttons">
                                <a class="btn btn-sm btn-soft-primary" asp-action="Details" asp-route-id="@e.Id">Detalhes</a>
                                <button class="btn btn-sm btn-soft-success" disabled title="Em breve">Confirmar</button>
                                <button class="btn btn-sm btn-soft-danger" disabled title="Em breve">Recusar</button>
                                <button class="btn btn-sm btn-soft-warning" disabled title="Em breve">Cancelar</button>
                                <button class="btn btn-sm btn-outline-success" disabled title="Em breve">Realizado</button>
                                <button class="btn btn-sm btn-outline-primary" disabled title="Em breve">Pagamentos</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="card-footer bg-white">
    <partial name="_Pagination" model="Model" />
</div>