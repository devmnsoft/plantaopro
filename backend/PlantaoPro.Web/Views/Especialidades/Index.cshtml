@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.EspecialidadeDto>
@{ ViewData["Title"] = "Especialidades"; var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.EspecialidadeDto>(); }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Especialidades","Gestão de especialidades médicas para classificação dos plantões.","bi-journal-medical","Nova Especialidade",null,null,true)' />
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Nome</th><th>Descrição</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@if (items.Any()) { foreach (var row in items) { <tr><td class="fw-semibold">@row.Nome</td><td>@row.Descricao</td><td><partial name="_StatusBadge" model='@(string.Equals(row.RegStatus,"A",StringComparison.OrdinalIgnoreCase) ? "ativo" : "inativo")' /></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@row.Id"><i class="bi bi-eye"></i></a> <button class="btn btn-sm btn-outline-secondary" disabled title="Em breve"><i class="bi bi-pencil"></i></button></td></tr> } } else { <tr><td colspan="4" class="py-5"><partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-inbox","Nenhuma especialidade encontrada","Cadastre especialidades para organizar melhor a operação.")' /></td></tr> }
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model" /></div></div>
