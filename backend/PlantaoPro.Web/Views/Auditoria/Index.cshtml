@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.AuditoriaDto>
@{ ViewData["Title"] = "Auditoria"; var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.AuditoriaDto>(); }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Auditoria","Rastreabilidade de ações e eventos operacionais.","bi-shield-check","Exportar",null,null,true)' />
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Data/hora</th><th>Usuário</th><th>Ação</th><th>Entidade</th><th>IP</th><th>Descrição</th></tr></thead><tbody>
@if(items.Any()){foreach(var log in items){<tr><td>@log.DataHora.ToString("dd/MM/yyyy HH:mm")</td><td>@log.Usuario</td><td><partial name="_StatusBadge" model="log.Acao" /></td><td>@log.Entidade</td><td>@log.Ip</td><td>@log.Descricao</td></tr>}}else{<tr><td colspan="6" class="py-5"><partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-journal-x","Sem registros de auditoria","Não houve eventos no período selecionado.")' /></td></tr>}
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model" /></div></div>
