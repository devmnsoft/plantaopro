@model PlantaoPro.Web.Models.PlanoSaasViewModel
<div class="card"><div class="card-body"><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="row g-3"><div class="col-md-6"><label class="form-label" asp-for="Nome"></label><input class="form-control" asp-for="Nome" /></div><div class="col-md-3"><label class="form-label" asp-for="ValorMensal"></label><input class="form-control" asp-for="ValorMensal" type="number" step="0.01" min="0" /></div><div class="col-12"><label class="form-label" asp-for="Descricao"></label><textarea class="form-control" asp-for="Descricao"></textarea></div><div class="col-md-4"><label class="form-label" asp-for="LimiteMedicos"></label><input class="form-control" asp-for="LimiteMedicos" min="0" /></div><div class="col-md-4"><label class="form-label" asp-for="LimiteHospitais"></label><input class="form-control" asp-for="LimiteHospitais" min="0" /></div><div class="col-md-4"><label class="form-label" asp-for="LimitePlantoesMes"></label><input class="form-control" asp-for="LimitePlantoesMes" min="0" /></div><div class="col-md-3 form-check ms-2"><input class="form-check-input" asp-for="PermiteMobile" /><label class="form-check-label" asp-for="PermiteMobile"></label></div><div class="col-md-3 form-check"><input class="form-check-input" asp-for="PermiteBi" /><label class="form-check-label" asp-for="PermiteBi"></label></div><div class="col-md-3 form-check"><input class="form-check-input" asp-for="PermiteRelatoriosAvancados" /><label class="form-check-label" asp-for="PermiteRelatoriosAvancados"></label></div><div class="col-md-3 form-check"><input class="form-check-input" asp-for="PermiteIntegracoes" /><label class="form-check-label" asp-for="PermiteIntegracoes"></label></div></div></div><div class="card-footer bg-white"><button class="btn btn-primary" type="submit">Salvar</button> <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a></div></div>
