@model PlantaoPro.Web.Models.ActionToolbarViewModel?
@{
    var newText = Model?.NewText ?? string.Empty;
    var newController = Model?.NewController ?? string.Empty;
    var newAction = Model?.NewAction ?? string.Empty;
    var newDisabled = Model?.NewDisabled ?? true;
    var downloadFormId = Model?.DownloadFormId ?? string.Empty;
    var canCreate = !string.IsNullOrWhiteSpace(newController) && !string.IsNullOrWhiteSpace(newAction) && !newDisabled;
    var canDownload = !string.IsNullOrWhiteSpace(downloadFormId);
}
<div class="action-toolbar mb-3" role="toolbar" aria-label="Ações da página">
    <div class="d-flex gap-2 flex-wrap">
        @if (!string.IsNullOrWhiteSpace(newText))
        {
            if (canCreate)
            {
                <a class="btn btn-primary" asp-controller="@newController" asp-action="@newAction"><i class="bi bi-plus-circle me-1"></i>@newText</a>
            }
            else
            {
                <button type="button" class="btn btn-primary" disabled title="Ação indisponível"><i class="bi bi-plus-circle me-1"></i>@newText</button>
            }
        }
        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#globalFilterPanel" aria-controls="globalFilterPanel" aria-expanded="false"><i class="bi bi-funnel me-1"></i>Filtros</button>
        @if (canDownload)
        {
            <button type="submit" form="@downloadFormId" class="btn btn-outline-success" title="Baixar"><i class="bi bi-download me-1"></i>Baixar</button>
        }
        else
        {
            <button type="button" class="btn btn-outline-success" disabled title="Ação indisponível"><i class="bi bi-download me-1"></i>Baixar</button>
        }
        <a class="btn btn-outline-primary" href="@Context.Request.Path@Context.Request.QueryString"><i class="bi bi-arrow-clockwise me-1"></i>Atualizar</a>
    </div>
</div>
