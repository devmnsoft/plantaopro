@model IEnumerable<PlantaoPro.Web.Models.PlanoSaasViewModel>
@{ ViewData["Title"] = "Comparativo de planos"; var planos = Model ?? Array.Empty<PlantaoPro.Web.Models.PlanoSaasViewModel>(); }
<div class="container-fluid py-3"><h1 class="h3">Comparativo de planos</h1><div class="table-responsive card"><table class="table mb-0"><thead><tr><th>Plano</th><th>Valor</th><th>Médicos</th><th>Hospitais</th><th>Plantões</th><th>Mobile</th><th>BI</th><th>Integrações</th></tr></thead><tbody>@foreach (var p in planos){<tr><td>@p.Nome</td><td>@p.ValorMensal.ToString("C")</td><td>@p.LimiteMedicos</td><td>@p.LimiteHospitais</td><td>@p.LimitePlantoesMes</td><td>@(p.PermiteMobile ? "Sim" : "Não")</td><td>@(p.PermiteBi ? "Sim" : "Não")</td><td>@(p.PermiteIntegracoes ? "Sim" : "Não")</td></tr>}</tbody></table></div></div>
