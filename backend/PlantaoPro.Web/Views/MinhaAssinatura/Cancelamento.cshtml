@{
    ViewData["Title"] = "Solicitar cancelamento";
}
<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <span class="badge bg-warning text-dark">Ação sensível</span>
            <h1 class="h3 mt-2">Solicitar cancelamento da assinatura</h1>
            <p class="text-muted">A solicitação gera auditoria e atendimento comercial. O acesso não é encerrado automaticamente sem validação.</p>
            <form method="post" data-confirm="true" data-confirm-message="Deseja registrar a solicitação de cancelamento?">
                @Html.AntiForgeryToken()
                <label class="form-label" for="motivo">Motivo</label>
                <textarea class="form-control" id="motivo" name="motivo" rows="5" minlength="10" required></textarea>
                <div class="form-text">Informe contexto suficiente para a equipe de Customer Success.</div>
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-danger" type="submit">Solicitar cancelamento</button>
                    <a class="btn btn-outline-secondary" asp-controller="MinhaAssinatura" asp-action="Index">Voltar</a>
                </div>
            </form>
        </div>
    </div>
</div>
