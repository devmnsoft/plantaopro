@model IEnumerable<PlantaoPro.Web.Models.ComercialLeadViewModel>
@{ ViewData["Title"] = "Leads SaaS"; }
<div class="row g-3"><div class="col-lg-4"><div class="card shadow-sm"><div class="card-body"><h2 class="h5">Novo lead</h2><form asp-action="CriarLead" method="post" data-ajax-form="true">@Html.AntiForgeryToken()<input name="Nome" class="form-control mb-2" placeholder="Nome" required /><input name="Empresa" class="form-control mb-2" placeholder="Empresa" required /><input name="Email" class="form-control mb-2" placeholder="E-mail" required /><input name="Telefone" class="form-control mb-2" placeholder="Telefone" /><input name="MedicosDesejados" class="form-control mb-2" type="number" placeholder="Médicos desejados" /><input name="Hospitais" class="form-control mb-2" type="number" placeholder="Hospitais" /><input name="PlantoesMes" class="form-control mb-2" type="number" placeholder="Plantões/mês" /><button class="btn btn-primary w-100">Criar lead</button></form></div></div></div><div class="col-lg-8"><div class="card shadow-sm"><div class="card-body"><h2 class="h5">Leads</h2><table class="table"><thead><tr><th>Empresa</th><th>Contato</th><th>Uso desejado</th><th>Status</th></tr></thead><tbody>@foreach (var item in Model) { <tr><td>@item.Empresa</td><td>@item.Nome<br /><small>@item.Email</small></td><td>@item.MedicosDesejados médicos • @item.Hospitais hospitais • @item.PlantoesMes plantões</td><td><span class="badge text-bg-info">@item.Status</span></td></tr> }</tbody></table></div></div></div></div>
