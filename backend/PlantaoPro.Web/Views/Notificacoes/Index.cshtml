@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.NotificacaoDto>
@{ ViewData["Title"] = "Notificações"; var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.NotificacaoDto>(); }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Notificações","Acompanhe alertas e avisos do sistema.","bi-bell","Marcar todas como lidas",null,null,true)' />
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Título</th><th>Mensagem</th><th>Tipo</th><th>Status</th><th>Data</th><th class="text-end">Ações</th></tr></thead><tbody>
@if(items.Any()){foreach(var n in items){<tr><td class="fw-semibold">@n.Titulo</td><td>@n.Mensagem</td><td><span class="badge bg-light text-dark border">@n.Tipo</span></td><td><partial name="_StatusBadge" model="@(n.Lida ? "pago" : "pendente")" /></td><td>@n.RegDate.ToString("dd/MM/yyyy HH:mm")</td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@n.Id">Detalhes</a> <button class="btn btn-sm btn-outline-secondary" disabled title="Ação indisponível">Marcar lida</button></td></tr>}}else{<tr><td colspan="6" class="py-5"><partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-bell-slash","Nenhuma notificação encontrada","Você está em dia com os alertas do sistema.")' /></td></tr>}
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model" /></div></div>
