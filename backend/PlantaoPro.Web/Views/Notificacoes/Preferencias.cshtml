@{
    ViewData["Title"] = "Preferências de notificações";
}
<section class="container-fluid py-4">
    <h1 class="h3">Preferências de notificações</h1>
    <p class="text-muted">Defina quais eventos operacionais, financeiros e SaaS devem gerar alertas in-app, e-mail, push ou WhatsApp quando o plano permitir.</p>
    <div class="card shadow-sm">
        <div class="card-body table-responsive">
            <table class="table align-middle">
                <thead><tr><th>Evento</th><th>In-app</th><th>E-mail</th><th>Push</th><th>WhatsApp</th></tr></thead>
                <tbody>
                    @foreach (var evento in new[] { "CONVITE_ENVIADO", "PLANTAO_COM_RISCO", "SUBSTITUICAO_SOLICITADA", "PAGAMENTO_CONFIRMADO", "FATURA_VENCIDA" })
                    {
                        <tr><td><span class="badge bg-light text-dark">@evento</span></td><td>Ativo</td><td>Opcional</td><td>Opcional</td><td>Plano Enterprise</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
