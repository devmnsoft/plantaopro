@model PlantaoPro.Web.Models.AssinaturaSaasViewModel
<div class="card"><div class="card-body"><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="row g-3"><div class="col-md-6"><label class="form-label" asp-for="ClienteId"></label><input class="form-control" asp-for="ClienteId" /></div><div class="col-md-6"><label class="form-label" asp-for="PlanoId"></label><input class="form-control" asp-for="PlanoId" /></div><div class="col-md-4"><label class="form-label" asp-for="DataInicio"></label><input class="form-control" asp-for="DataInicio" type="date" /></div><div class="col-md-4"><label class="form-label" asp-for="DataFim"></label><input class="form-control" asp-for="DataFim" type="date" /></div><div class="col-md-4"><label class="form-label" asp-for="DiaVencimento"></label><input class="form-control" asp-for="DiaVencimento" min="1" max="31" /></div><div class="col-md-4"><label class="form-label" asp-for="ValorContratado"></label><input class="form-control" asp-for="ValorContratado" min="0" step="0.01" /></div><div class="col-12"><label class="form-label" asp-for="Observacoes"></label><textarea class="form-control" asp-for="Observacoes"></textarea></div></div></div><div class="card-footer bg-white"><button class="btn btn-primary" type="submit">Salvar</button> <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a></div></div>
