@model IEnumerable<PlantaoPro.Web.Models.AjudaChecklistViewModel>
@{ ViewData["Title"] = "Checklist de primeiros passos"; var perfil = ViewBag.Perfil as string ?? string.Empty; }
<div class="card shadow-sm"><div class="card-body"><h2 class="h5">Checklist para @perfil</h2><div class="list-group">@foreach (var item in Model) { <div class="list-group-item d-flex justify-content-between align-items-start"><div><h3 class="h6">@item.Titulo</h3><p class="mb-0 text-muted">@item.Descricao</p></div>@if (!string.IsNullOrWhiteSpace(item.LinkAcao)) { <a class="btn btn-sm btn-outline-primary" href="@item.LinkAcao">Abrir</a> }</div> }</div>@if (!Model.Any()) { <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-check2-square", "Checklist vazio", "Nenhum checklist encontrado para este perfil.")' /> }</div></div>
