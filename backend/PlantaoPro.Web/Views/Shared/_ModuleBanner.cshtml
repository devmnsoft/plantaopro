@model PlantaoPro.Web.Models.ModuleBannerViewModel?
<section class="module-banner mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <div class="module-banner-title"><i class="bi @(Model?.Icon ?? "bi-grid") me-2"></i>@(Model?.Title ?? "Módulo")</div>
            <p class="module-banner-description mb-0">@(Model?.Description ?? "Gerencie este módulo com produtividade e visibilidade.")</p>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model?.ActionText))
        {
            if (!string.IsNullOrWhiteSpace(Model?.ActionController) && !string.IsNullOrWhiteSpace(Model?.ActionName) && !(Model?.ActionDisabled ?? false))
            {
                <a class="btn btn-primary" asp-controller="@Model!.ActionController" asp-action="@Model.ActionName">@Model.ActionText</a>
            }
            else
            {
                <button class="btn btn-primary" disabled title="Em breve">@Model.ActionText</button>
            }
        }
    </div>
</section>
