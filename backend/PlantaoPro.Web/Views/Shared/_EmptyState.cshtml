@model PlantaoPro.Web.Models.EmptyStateViewModel?
@{
    var icon = Model?.Icon ?? "bi-inbox";
    var title = Model?.Title ?? "Nada por aqui";
    var description = Model?.Description ?? "Sem dados disponíveis no momento.";
    var buttonText = Model?.ButtonText ?? string.Empty;
    var buttonAction = Model?.ButtonAction ?? string.Empty;
    var buttonController = Model?.ButtonController ?? string.Empty;
    var buttonDisabled = Model?.ButtonDisabled ?? true;
}
<div class="empty-state text-center">
    <div class="empty-state-icon"><i class="bi @icon"></i></div>
    <h5 class="mb-2">@title</h5>
    <p class="text-muted mb-3">@description</p>
    @if (!string.IsNullOrWhiteSpace(buttonText))
    {
        if (!buttonDisabled && !string.IsNullOrWhiteSpace(buttonAction) && !string.IsNullOrWhiteSpace(buttonController))
        {
            <a class="btn btn-soft-primary" asp-action="@buttonAction" asp-controller="@buttonController">@buttonText</a>
        }
        else
        {
            <button class="btn btn-soft-primary" disabled title="Em breve">@buttonText</button>
        }
    }
</div>
