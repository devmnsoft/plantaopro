@model PlantaoPro.Web.Models.AjudaInterativaChecklistViewModel
@{
    ViewData["Title"] = "Primeiros Passos";
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Primeiros passos", "Roteiro rápido para começar a usar o PlantãoPro com segurança.", "bi-rocket-takeoff")' />
<div class="row g-3">
@foreach (var artigo in Model.Artigos)
{
    <div class="col-md-4"><div class="card h-100"><div class="card-body"><span class="badge bg-light text-dark border mb-2">@artigo.Perfil</span><h2 class="h5">@artigo.Titulo</h2><p>@artigo.Resumo</p><a class="btn btn-sm btn-outline-primary" asp-action="Artigo" asp-route-id="@artigo.Id">Começar</a></div></div></div>
}
</div>
