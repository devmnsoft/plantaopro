@model IEnumerable<PlantaoPro.Web.Models.ComercialOportunidadeViewModel>
@{ ViewData["Title"] = "Oportunidades SaaS"; }
<div class="card shadow-sm mb-3"><div class="card-body"><h2 class="h5">Nova oportunidade</h2><form asp-action="CriarOportunidade" method="post" class="row g-2" data-ajax-form="true">@Html.AntiForgeryToken()<div class="col-md-4"><input name="Titulo" class="form-control" placeholder="Título" required /></div><div class="col-md-2"><input name="ValorEstimado" class="form-control" type="number" step="0.01" placeholder="Valor" /></div><div class="col-md-3"><input name="PlanoRecomendado" class="form-control" placeholder="Plano recomendado" /></div><div class="col-md-2"><input name="Probabilidade" class="form-control" type="number" value="10" /></div><div class="col-md-1"><button class="btn btn-primary w-100">Criar</button></div></form></div></div>
<div class="row g-3">@foreach (var item in Model) { <div class="col-md-4"><div class="card shadow-sm h-100"><div class="card-body"><span class="badge text-bg-primary">@item.Etapa</span><h3 class="h6 mt-2">@item.Titulo</h3><p class="mb-1">@item.ValorEstimado.ToString("C") • @item.Probabilidade%</p><small>@item.PlanoRecomendado</small></div></div></div> }</div>
