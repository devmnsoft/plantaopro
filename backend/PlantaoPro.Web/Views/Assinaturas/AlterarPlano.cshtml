@model PlantaoPro.Web.Models.AssinaturaSaasViewModel
@{ ViewData["Title"] = "Alterar plano"; }
<div class="container py-3"><h1 class="h3">Alterar plano da assinatura</h1><div class="card"><div class="card-body"><p>Cliente: <strong>@Model.ClienteNome</strong></p><p>Plano atual: <strong>@Model.PlanoNome</strong></p><form method="post" data-confirm="true" data-confirm-message="Confirmar alteração de plano?">@Html.AntiForgeryToken()<div class="mb-3"><label class="form-label" for="planoId">Novo PlanoId</label><input class="form-control" id="planoId" name="planoId" /></div><div class="mb-3"><label class="form-label" for="justificativa">Justificativa</label><textarea class="form-control" id="justificativa" name="justificativa" required></textarea></div><button class="btn btn-primary" type="submit">Alterar plano</button> <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Voltar</a></form></div></div></div>
