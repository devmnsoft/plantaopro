@model PlantaoPro.Web.Models.AjudaArtigoViewModel
@{ ViewData["Title"] = Model.Titulo; }
<div class="card shadow-sm"><div class="card-body"><span class="badge text-bg-info">@Model.Perfil</span><h2 class="h4 mt-2">@Model.Titulo</h2><p class="lead">@Model.Resumo</p><p>@Model.Conteudo</p>@if (!string.IsNullOrWhiteSpace(Model.LinkAcao)) { <a class="btn btn-primary" href="@Model.LinkAcao">Ir para tela relacionada</a> }<hr /><h3 class="h6">Este artigo foi útil?</h3><form asp-action="Feedback" method="post" class="d-flex gap-2" data-ajax-form="true">@Html.AntiForgeryToken()<input type="hidden" name="artigoId" value="@Model.Id" /><button class="btn btn-outline-success" name="util" value="true">Foi útil</button><button class="btn btn-outline-secondary" name="util" value="false">Não ajudou</button></form></div></div>
