@{ ViewData["Title"] = "Consentimentos LGPD"; }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Consentimentos", "Registre e consulte consentimentos por finalidade e versão de política.", "bi-check2-square")' />
<div class="card"><div class="card-body"><form asp-action="RegistrarConsentimento" method="post" class="row g-3"><div class="col-md-4"><label class="form-label">Finalidade</label><select name="finalidade" class="form-select"><option>Comunicação operacional</option><option>Customer Success</option><option>Suporte</option></select></div><div class="col-md-4"><label class="form-label">Base legal</label><select name="baseLegal" class="form-select"><option>Consentimento</option><option>Execução de contrato</option><option>Legítimo interesse</option></select></div><div class="col-md-2"><label class="form-label">Versão</label><input name="versaoPolitica" class="form-control" value="2026.06" /></div><div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100" type="submit">Registrar</button></div><input type="hidden" name="consentido" value="true" /></form></div></div>
<div class="alert alert-info mt-3">Histórico completo disponível na API <code>/api/lgpd/consentimentos</code>.</div>
