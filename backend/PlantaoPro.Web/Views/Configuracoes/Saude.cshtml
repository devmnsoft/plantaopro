@model PlantaoPro.Web.Models.HealthViewModel
@{
    ViewData["Title"] = "Saúde do Sistema";
}
<h2 class="mb-3">Saúde do Sistema</h2>

@if (TempData["Error"] is string erro && !string.IsNullOrWhiteSpace(erro))
{
    <div class="alert alert-warning" role="alert">
        <strong>Atenção:</strong> @erro
    </div>
}

@if (Model is null)
{
    <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("Sem dados de saúde", "Não foi possível obter dados de monitoramento.", "Voltar para Configurações", Url.Action("Index", "Configuracoes"))' />
}
else
{
    <div class="row g-3">
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><small>Status</small><h5>@(Model.Status ?? "N/D")</h5></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><small>Banco</small><h5>@(Model.BancoConectado ? "Conectado" : "Indisponível")</h5></div></div></div>
        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><small>Ambiente</small><h5>@(Model.Ambiente ?? "N/D")</h5></div></div></div>
    </div>
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-md-3">Schema</dt><dd class="col-md-9">@(Model.Schema ?? "N/D")</dd>
                <dt class="col-md-3">Data/Hora (UTC)</dt><dd class="col-md-9">@Model.DataHora.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                <dt class="col-md-3">Versão</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.Versao) ? "N/D" : Model.Versao)</dd>
                <dt class="col-md-3">Base URL API</dt><dd class="col-md-9">@(Model.BaseUrlApi ?? "N/D")</dd>
                <dt class="col-md-3">Token presente</dt><dd class="col-md-9">@(Model.TokenPresente ? "Sim" : "Não")</dd>
                <dt class="col-md-3">Usuário autenticado</dt><dd class="col-md-9">@(Model.UsuarioAutenticado ?? "N/D")</dd>
                <dt class="col-md-3">Swagger</dt><dd class="col-md-9"><a href="@Model.SwaggerUrl" target="_blank" rel="noopener">@Model.SwaggerUrl</a></dd>
            </dl>
        </div>
    </div>
}
