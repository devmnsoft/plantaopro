@{
    ViewData["Title"] = "Centro de Ajuda";
    var busca = (string?)ViewBag.Busca;
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Centro de Ajuda", "Guias rápidos para acelerar sua operação SaaS.", "bi-life-preserver")' />
<div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Selecione um módulo para ver passo a passo e próximos passos esperados.</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-8"><input name="busca" value="@busca" class="form-control" placeholder="Buscar tema" /></div>
    <div class="col-md-4"><button class="btn btn-primary w-100"><i class="bi bi-search"></i> Buscar</button></div>
</form>
<div class="row g-3">
@foreach (var item in new[]{("plantoes","Como criar plantão","bi-calendar-plus"),("escalas","Como confirmar escala","bi-check2-square"),("pagamentos","Como gerar pagamento","bi-cash-stack"),("medicos","Como configurar médico","bi-person-badge"),("medico-area","Como usar área do médico","bi-heart-pulse"),("operacao","Como usar central operacional","bi-speedometer2"),("alertas","Como entender alertas","bi-exclamation-triangle"),("assinatura","Como acompanhar assinatura","bi-receipt")})
{
    if(!string.IsNullOrWhiteSpace(busca) && !item.Item2.Contains(busca, StringComparison.OrdinalIgnoreCase)){ continue; }
    <div class="col-lg-3 col-md-6"><a asp-action="Modulo" asp-route-id="@item.Item1" class="card text-decoration-none h-100"><div class="card-body"><i class="bi @item.Item3 fs-2 text-primary"></i><h6 class="mt-2">@item.Item2</h6></div></a></div>
}
</div>

<div class="mt-3 d-flex gap-2 flex-wrap"><a class="btn btn-primary" asp-controller="Ajuda" asp-action="PrimeirosPassos">Primeiros passos</a><a class="btn btn-outline-primary" asp-controller="Ajuda" asp-action="Busca">Buscar ajuda</a><a class="btn btn-outline-secondary" asp-controller="Ajuda" asp-action="Checklist">Checklist</a></div>
