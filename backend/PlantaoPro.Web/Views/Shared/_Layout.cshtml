@using PlantaoPro.Web.Security
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#155eef" />
    <title>@(ViewData["Title"] ?? "PlantãoPro")</title>
    <link rel="icon" type="image/svg+xml" href="~/branding/logo-icon.svg" />
    <link rel="apple-touch-icon" href="~/branding/logo-plantaopro.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/plantaopro.css" asp-append-version="true" />
</head>
<body class="app-body">
<a class="skip-link" href="#mainContent">Pular para o conteúdo</a>
@if (isAuthenticated)
{
    <div class="app-shell">
        <partial name="_AppSidebar" />
        <section class="app-main" data-app-shell="true">
            <partial name="_AppTopbar" />
            <main class="app-content" id="mainContent" tabindex="-1">
                <partial name="_ToastMessages" />
                <partial name="_ImpersonationBanner" />
                @RenderBody()
            </main>
            <partial name="_AppFooter" />
        </section>
    </div>
    <partial name="_MobileNavigation" />
    <partial name="_NotificationDrawer" />
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
}
else
{
    <main class="auth-main"><partial name="_ToastMessages" />@RenderBody()</main>
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/plantaopro-toast.js" asp-append-version="true"></script>
<script src="~/js/plantaopro-ui.js" asp-append-version="true"></script>
<script src="~/js/plantao-saas.js" asp-append-version="true"></script>
<script src="~/js/saude360-ui.js" asp-append-version="true"></script>
<script src="~/js/saude360-tooltips.js" asp-append-version="true"></script>
<script src="~/js/saude360-modals.js" asp-append-version="true"></script>
<script src="~/js/saude360-tour.js" asp-append-version="true"></script>
<script src="~/js/lookup.js" asp-append-version="true"></script>
<script>
if ("serviceWorker" in navigator) {
  window.addEventListener("load", function(){ navigator.serviceWorker.register("/service-worker.js").catch(function(){}); });
}
</script>
@await RenderSectionAsync("Scripts", false)
<partial name="_ConfirmModal" model="new PlantaoPro.Web.Models.ConfirmModalViewModel()" />
</body>
</html>
