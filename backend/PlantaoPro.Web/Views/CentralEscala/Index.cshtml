@model PlantaoPro.Web.Models.OperacaoResumoDto
@{
    ViewData["Title"] = "Central de Escala";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1"><i class="bi bi-radar text-primary"></i> Central de Escala</h2>
        <p class="text-muted mb-0">Sala de controle para cobertura, solicitações, conflitos e pendências financeiras.</p>
    </div>
    <a asp-controller="Agenda" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-calendar3"></i> Abrir agenda</a>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @ViewBag.ErrorMessage</div>
}

<div class="row g-3 mb-3">
    <div class="col-6 col-lg-2"><div class="card border-0 shadow-sm p-3"><small>Hoje</small><h3>@Model.TotalPlantoesHoje</h3></div></div>
    <div class="col-6 col-lg-2"><div class="card border-0 shadow-sm p-3"><small>Abertos</small><h3>@Model.TotalPlantoesAbertos</h3></div></div>
    <div class="col-6 col-lg-2"><div class="card border-0 shadow-sm p-3"><small>Solicitações</small><h3>@Model.TotalEscalasSolicitadas</h3></div></div>
    <div class="col-6 col-lg-2"><div class="card border-0 shadow-sm p-3"><small>Confirmadas hoje</small><h3>@Model.TotalEscalasConfirmadasHoje</h3></div></div>
    <div class="col-6 col-lg-2"><div class="card border-0 shadow-sm p-3"><small>Conflitos</small><h3>@Model.TotalConflitos</h3></div></div>
    <div class="col-6 col-lg-2"><div class="card border-0 shadow-sm p-3"><small>Financeiro</small><h3>@Model.TotalPagamentosPendentes</h3></div></div>
</div>

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap gap-2">
        <a asp-controller="Plantoes" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Novo plantão</a>
        <a asp-controller="Plantoes" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-send"></i> Publicar/convites</a>
        <a asp-controller="Escalas" asp-action="Index" class="btn btn-outline-success"><i class="bi bi-check2-circle"></i> Confirmar escalas</a>
        <a asp-controller="Financeiro" asp-action="Index" class="btn btn-outline-warning"><i class="bi bi-cash-stack"></i> Pagamentos</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card h-100"><div class="card-header fw-semibold">Plantões sem cobertura</div><div class="list-group list-group-flush">
            @foreach (var item in Model.PlantoesCriticos)
            {
                <a asp-controller="CentralEscala" asp-action="Plantao" asp-route-id="@item.Id" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between"><strong>@item.HospitalNome</strong><span class="badge text-bg-danger">@item.Status</span></div>
                    <small>@item.EspecialidadeNome • @item.DataInicio.ToString("dd/MM HH:mm")</small>
                </a>
            }
        </div></div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100"><div class="card-header fw-semibold">Escalas solicitadas</div><div class="list-group list-group-flush">
            @foreach (var item in Model.EscalasPendentes)
            {
                <a asp-controller="Escalas" asp-action="Details" asp-route-id="@item.Id" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between"><strong>@item.MedicoNome</strong><span class="badge text-bg-info">@item.Status</span></div>
                    <small>@item.HospitalNome • @item.DataInicio.ToString("dd/MM HH:mm")</small>
                </a>
            }
        </div></div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100"><div class="card-header fw-semibold">Pagamentos pendentes</div><div class="list-group list-group-flush">
            @foreach (var item in Model.PagamentosPendentes)
            {
                <a asp-controller="Financeiro" asp-action="Details" asp-route-id="@item.Id" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between"><strong>@item.MedicoNome</strong><span class="badge text-bg-warning">@item.Status</span></div>
                    <small>@item.HospitalNome • @item.ValorPrevisto.ToString("C")</small>
                </a>
            }
        </div></div>
    </div>
</div>
