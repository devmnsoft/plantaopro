@model PlantaoPro.Web.Models.AjudaInterativaArtigoViewModel
@{
    ViewData["Title"] = Model.Titulo;
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel(Model.Titulo, "Passo a passo do módulo selecionado no manual interativo.", "bi-book")' />
<div class="card">
    <div class="card-body">
        <p class="lead">@Model.Resumo</p>
        <ol>
        @foreach (var passo in Model.Passos)
        {
            <li>@passo</li>
        }
        </ol>
        <a class="btn btn-primary" asp-controller="@Model.Controller" asp-action="@Model.Action">Abrir tela relacionada</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
    </div>
</div>
