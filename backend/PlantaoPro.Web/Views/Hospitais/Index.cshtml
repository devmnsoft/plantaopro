@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.HospitalDto>
<h2 class="mb-3">Hospitais</h2>
<div class="card p-3 mb-3"><div class="d-flex justify-content-between"><div>Gestão de hospitais.</div><button class="btn btn-sm btn-outline-primary" disabled>Em breve</button></div></div>
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage)) { <div class="alert alert-warning">@Model.ErrorMessage</div> }
<div class="table-responsive"><table class="table table-striped"><thead><tr><th>ID</th><th>Resumo</th></tr></thead><tbody>
@if (Model?.Items?.Any() == true) { foreach (var item in Model.Items) { <tr><td>@item.Id</td><td>@item</td></tr> } } else { <tr><td colspan="2" class="text-center text-muted">Nenhum registro encontrado.</td></tr> }
</tbody></table></div>