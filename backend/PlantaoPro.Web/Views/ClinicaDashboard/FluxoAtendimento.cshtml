@{
    ViewData["Title"] = "Fluxo de Atendimento";
    var etapas = new List<dynamic>
    {
        new { N = 1, Icon = "bi-person-plus", Title = "Cadastre o paciente", Text = "Comece cadastrando ou localizando o paciente.", Primary = "Novo paciente", PrimaryController = "Pacientes", PrimaryAction = "Create", Secondary = "Buscar paciente", SecondaryController = "Pacientes", SecondaryAction = "Buscar", Status = "Comece aqui" },
        new { N = 2, Icon = "bi-calendar-plus", Title = "Agende o atendimento", Text = "Escolha médico, data, horário, unidade e tipo de atendimento.", Primary = "Novo agendamento", PrimaryController = "Agendamentos", PrimaryAction = "Create", Secondary = "Agenda do dia", SecondaryController = "Agendamentos", SecondaryAction = "AgendaDia", Status = "Depois do paciente" },
        new { N = 3, Icon = "bi-person-check", Title = "Realize o check-in", Text = "Confirme a chegada do paciente e envie para a fila.", Primary = "Check-in", PrimaryController = "Agendamentos", PrimaryAction = "CheckIn", Secondary = "Ver fila", SecondaryController = "PainelChamada", SecondaryAction = "Fila", Status = "Chegada" },
        new { N = 4, Icon = "bi-megaphone", Title = "Chame o paciente", Text = "Use o painel de chamada para orientar o paciente até a sala ou triagem.", Primary = "Painel de chamada", PrimaryController = "PainelChamada", PrimaryAction = "Index", Secondary = "Modo TV", SecondaryController = "PainelChamada", SecondaryAction = "Tv", Status = "Sala de espera" },
        new { N = 5, Icon = "bi-clipboard2-pulse", Title = "Faça a triagem", Text = "Registre sinais vitais, queixa principal e classificação de risco.", Primary = "Fila de triagem", PrimaryController = "Triagem", PrimaryAction = "Fila", Secondary = "Nova triagem", SecondaryController = "Triagem", SecondaryAction = "Create", Status = "Assistencial" },
        new { N = 6, Icon = "bi-stethoscope", Title = "Inicie a consulta", Text = "O médico registra anamnese, diagnóstico, CID e conduta.", Primary = "Consultas", PrimaryController = "Consultas", PrimaryAction = "Index", Secondary = "Atendimento médico", SecondaryController = "Consultas", SecondaryAction = "Atendimento", Status = "Médico" },
        new { N = 7, Icon = "bi-prescription2", Title = "Emita prescrição", Text = "Crie prescrições e orientações vinculadas à consulta.", Primary = "Prescrições", PrimaryController = "Prescricoes", PrimaryAction = "Index", Secondary = "Modelos", SecondaryController = "Prescricoes", SecondaryAction = "Modelos", Status = "Conduta" },
        new { N = 8, Icon = "bi-cash-coin", Title = "Feche o financeiro", Text = "Gere cobrança, receba pagamento ou envie para convênio.", Primary = "Financeiro clínica", PrimaryController = "ClinicaFinanceiro", PrimaryAction = "Index", Secondary = "Contas a receber", SecondaryController = "ClinicaFinanceiro", SecondaryAction = "ContasReceber", Status = "Fechamento" }
    };
}

<nav aria-label="breadcrumb" class="mb-3"><ol class="breadcrumb"><li class="breadcrumb-item"><a asp-controller="Home" asp-action="Dashboard">Início</a></li><li class="breadcrumb-item active" aria-current="page">Fluxo de Atendimento</li></ol></nav>
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div><p class="text-uppercase text-primary fw-semibold small mb-1">PlantãoPro Saúde 360</p><h1 class="h3 mb-1">Fluxo de Atendimento</h1><p class="text-muted mb-0">Jornada guiada para conduzir Paciente → Agendamento → Check-in → Painel → Triagem → Consulta → Prescrição → Financeiro.</p></div>
    <a asp-controller="PendenciasClinicas" asp-action="Index" class="btn btn-primary"><i class="bi bi-lightning-charge me-1"></i>Próxima ação recomendada</a>
</div>
<div class="alert alert-info"><strong>Onde começar?</strong> Se não houver dados, cadastre o primeiro paciente e siga os cards em ordem.</div>
<div class="row g-3">
@foreach (var e in etapas)
{
    <div class="col-lg-6 col-xl-3"><div class="card h-100 border-0 shadow-sm"><div class="card-body d-flex flex-column gap-3"><div class="d-flex justify-content-between"><span class="badge rounded-pill bg-primary">Passo @e.N</span><span class="badge bg-light text-dark">@e.Status</span></div><i class="bi @e.Icon text-primary fs-2"></i><div><h2 class="h5">@e.Title</h2><p class="text-muted mb-0">@e.Text</p></div><div class="mt-auto d-grid gap-2"><a class="btn btn-primary" asp-controller="@e.PrimaryController" asp-action="@e.PrimaryAction">@e.Primary</a><a class="btn btn-outline-secondary" asp-controller="@e.SecondaryController" asp-action="@e.SecondaryAction">@e.Secondary</a></div></div></div></div>
}
</div>
