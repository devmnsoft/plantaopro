@model PlantaoPro.Web.Models.CustomerSuccessIndexViewModel
@{ ViewData["Title"] = "Customer Success"; var alertas = Model.Alertas ?? Array.Empty<PlantaoPro.Web.Models.ClienteAlertaSaasViewModel>(); }
<div class="container-fluid py-3"><h1 class="h3">Customer Success SaaS</h1><p class="text-muted">Carteira, riscos, planos de ação e oportunidades comerciais.</p><div class="row g-3 mb-4"><div class="col-md-3"><div class="card"><div class="card-body"><span>Clientes em risco</span><h2>@Model.Resumo.ClientesRisco</h2></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><span>Clientes críticos</span><h2>@Model.Resumo.ClientesCriticos</h2></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><span>Upgrade</span><h2>@Model.Resumo.OportunidadesUpgrade</h2></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><span>Alertas</span><h2>@Model.Resumo.AlertasAbertos</h2></div></div></div></div><div class="card"><div class="card-header">Alertas de CS</div><div class="list-group list-group-flush">@if(!alertas.Any()){<div class="p-3 text-muted">Nenhum alerta de Customer Success aberto.</div>}else{foreach(var alerta in alertas){<a class="list-group-item list-group-item-action" asp-action="Details" asp-route-clienteId="@alerta.ClienteId"><strong>@alerta.ClienteNome</strong> — @alerta.Titulo <span class="badge bg-secondary">@alerta.Tipo</span></a>}}</div></div></div>
