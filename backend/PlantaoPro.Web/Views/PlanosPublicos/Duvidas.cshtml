@model IEnumerable<PlantaoPro.Web.Models.PlanoFaqWebViewModel>
@{
    ViewData["Title"] = "Dúvidas sobre planos";
    var perguntas = Model ?? Array.Empty<PlantaoPro.Web.Models.PlanoFaqWebViewModel>();
}
<div class="container py-5">
    <div class="mb-4">
        <span class="badge bg-primary-subtle text-primary">FAQ</span>
        <h1 class="display-6 mt-2">Dúvidas sobre planos e cadastro self-service</h1>
        <p class="text-muted">Veja respostas rápidas antes de escolher um plano e iniciar o cadastro da sua operação.</p>
    </div>
    <div class="accordion" id="faqPlanos">
        @foreach (var item in perguntas.Select((valor, indice) => new { valor, indice }))
        {
            var collapseId = "faq-" + item.indice.ToString();
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                        @item.valor.Pergunta
                    </button>
                </h2>
                <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#faqPlanos">
                    <div class="accordion-body">@item.valor.Resposta</div>
                </div>
            </div>
        }
    </div>
    <div class="mt-4 d-flex gap-2">
        <a class="btn btn-primary" asp-controller="Cadastro" asp-action="Empresa">Começar agora</a>
        <a class="btn btn-outline-secondary" asp-controller="PlanosPublicos" asp-action="Comparar">Comparar planos</a>
    </div>
</div>
