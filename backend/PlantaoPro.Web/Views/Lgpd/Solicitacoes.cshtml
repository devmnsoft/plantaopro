@model PlantaoPro.Web.Models.LgpdSolicitacaoFormViewModel
@{ ViewData["Title"] = "Solicitações LGPD"; }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Solicitações do titular", "Solicite exportação, correção ou exclusão/anonimização com limites legais claros.", "bi-person-lines-fill")' />
<div class="card"><div class="card-body"><form asp-action="CriarSolicitacao" method="post" class="row g-3"><div class="col-md-3"><label class="form-label">Tipo</label><select asp-for="Tipo" class="form-select"><option value="EXPORTACAO">Exportação</option><option value="CORRECAO">Correção</option><option value="ANONIMIZACAO">Exclusão/anonimização</option></select></div><div class="col-md-7"><label class="form-label">Descrição</label><input asp-for="Descricao" class="form-control" placeholder="Descreva sua solicitação" /></div><div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100" type="submit">Enviar</button></div></form><div class="alert alert-warning mt-3 mb-0">Anonimizações respeitam retenções obrigatórias de auditoria, financeiro e obrigações legais.</div></div></div>
