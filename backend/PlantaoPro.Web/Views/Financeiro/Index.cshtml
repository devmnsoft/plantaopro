@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PagamentoResumoDto>
@{ ViewData["Title"]="Financeiro"; var items=Model?.Items??Enumerable.Empty<PlantaoPro.Web.Models.PagamentoResumoDto>(); var pend=items.Where(x=>x.Status=="pendente"); var pago=items.Where(x=>x.Status=="pago"); var cancelados=items.Count(x=>x.Status=="cancelado"); var previstoMes=items.Where(x=>x.DataPrevista.HasValue && x.DataPrevista.Value.Month==DateTime.Today.Month && x.DataPrevista.Value.Year==DateTime.Today.Year).Sum(x=>x.ValorPrevisto);} 
<div class="page-header mb-4"><h2 class="page-title">Financeiro</h2><p class="page-subtitle">Controle de pagamentos previstos, pendentes, pagos e cancelados.</p></div>
<div class="row g-3 mb-3"><div class="col-md"><div class="metric-card"><div class="metric-label">Valor pendente</div><div class="metric-value">@pend.Sum(x=>x.ValorPrevisto).ToString("C")</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Valor pago</div><div class="metric-value">@pago.Sum(x=>x.ValorPago ?? 0).ToString("C")</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Qtd pendente</div><div class="metric-value">@pend.Count()</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Qtd paga</div><div class="metric-value">@pago.Count()</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Cancelados</div><div class="metric-value">@cancelados</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Previsto no mês</div><div class="metric-value">@previstoMes.ToString("C")</div></div></div></div>
<table class="table table-modern"><thead><tr><th>Médico</th><th>CRM</th><th>Hospital</th><th>Especialidade</th><th>Data</th><th>Previsto</th><th>Pago</th><th>Status</th><th>Data prevista</th><th>Data pagamento</th><th>Forma</th><th>Ações</th></tr></thead><tbody>
@foreach(var pg in items){<tr><td>@pg.MedicoNome</td><td>@pg.MedicoCrm</td><td>@pg.HospitalNome</td><td>@pg.EspecialidadeNome</td><td>@pg.DataPlantao.ToString("dd/MM/yyyy HH:mm")</td><td>@pg.ValorPrevisto.ToString("C")</td><td>@((pg.ValorPago ?? 0).ToString("C"))</td><td><partial name="_StatusBadge" model="pg.Status"/></td><td>@(pg.DataPrevista?.ToString("dd/MM/yyyy")??"-")</td><td>@(pg.DataPagamento?.ToString("dd/MM/yyyy")??"-")</td><td>@(pg.FormaPagamento??"-")</td><td><a class="btn btn-sm btn-soft-primary" asp-action="Details" asp-route-id="@pg.Id">Detalhes</a>@if(pg.Status=="pendente"){<form asp-action="ConfirmarPagamento" asp-route-id="@pg.Id" method="post" class="d-inline"><input type="hidden" name="valorPago" value="@pg.ValorPrevisto"/><input type="hidden" name="dataPagamento" value="@DateOnly.FromDateTime(DateTime.Today)"/><input type="hidden" name="formaPagamento" value="PIX"/><button class="btn btn-sm btn-soft-success">Confirmar</button></form><a class="btn btn-sm btn-soft-danger" asp-action="Details" asp-route-id="@pg.Id">Cancelar</a>}</td></tr>}
</tbody></table><partial name="_Pagination" model="Model" />
