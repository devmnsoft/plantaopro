@model PlantaoPro.Web.Models.ComercialLeadFormViewModel
@{ ViewData["Title"] = "Leads"; }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Leads comerciais", "Cadastre leads e receba sugestão determinística de plano.", "bi-person-plus")' />
<div class="card"><div class="card-body"><form asp-action="CriarLead" method="post" class="row g-3"><div class="col-md-3"><label class="form-label">Nome</label><input asp-for="Nome" class="form-control" required /></div><div class="col-md-3"><label class="form-label">E-mail</label><input asp-for="Email" class="form-control" required /></div><div class="col-md-3"><label class="form-label">Empresa</label><input asp-for="Empresa" class="form-control" /></div><div class="col-md-3"><label class="form-label">Telefone</label><input asp-for="Telefone" class="form-control" /></div><div class="col-md-2"><label class="form-label">Médicos</label><input asp-for="MedicosDesejados" class="form-control" type="number" min="0" /></div><div class="col-md-2"><label class="form-label">Hospitais</label><input asp-for="HospitaisDesejados" class="form-control" type="number" min="0" /></div><div class="col-md-2"><label class="form-label">Plantões/mês</label><input asp-for="PlantoesMes" class="form-control" type="number" min="0" /></div><div class="col-md-4 d-flex gap-3 align-items-end"><label><input asp-for="PrecisaMobile" /> Mobile</label><label><input asp-for="PrecisaBi" /> BI</label><label><input asp-for="SuportePrioritario" /> Suporte</label><label><input asp-for="OperacaoAssistida" /> Operação</label></div><div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100" type="submit">Criar lead</button></div></form></div></div>
