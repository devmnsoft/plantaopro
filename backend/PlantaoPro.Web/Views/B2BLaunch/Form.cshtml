@model PlantaoPro.Web.Models.B2BLaunchPageViewModel
@{
    ViewData["Title"] = Model.Titulo;
    var escopos = new List<(string Codigo, string Texto)>
    {
        ("plantoes:read", "Ler plantões"),
        ("plantoes:write", "Criar e atualizar plantões"),
        ("medicos:read", "Ler médicos"),
        ("escalas:read", "Ler escalas"),
        ("webhooks:write", "Configurar webhooks"),
        ("pacientes:read", "Ler pacientes"),
        ("agendamentos:read", "Ler agendamentos"),
        ("consultas:read", "Ler consultas"),
        ("financeiro:read", "Ler financeiro")
    };
}
<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Dashboard">Início</a></li>
            <li class="breadcrumb-item active" aria-current="page">API Keys</li>
        </ol>
    </nav>
    <div class="row g-4">
        <div class="col-lg-5">
            <p class="text-uppercase text-primary fw-semibold mb-1">Developer Portal</p>
            <h1 class="h3">@Model.Titulo</h1>
            <p class="text-muted">@Model.Subtitulo</p>
            <div class="alert alert-warning"><strong>Atenção:</strong> a API Key completa aparece apenas uma vez após a criação. Guarde em cofre seguro; depois disso o sistema mantém somente o hash.</div>
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Boas práticas</h2>
                    <ul class="mb-0">
                        <li>Use uma chave por integração.</li>
                        <li>Escolha apenas os escopos necessários.</li>
                        <li>Revogue imediatamente chaves suspeitas.</li>
                        <li>Rotacione periodicamente sem expor segredos em logs.</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <form method="post" asp-controller="Developer" asp-action="CreateApiKey" class="card shadow-sm">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label" for="nome">Nome da integração</label>
                        <input id="nome" name="Nome" class="form-control" required maxlength="120" placeholder="Ex.: ERP financeiro produção" />
                    </div>
                    <fieldset class="mb-3">
                        <legend class="h6">Escopos disponíveis</legend>
                        <div class="row g-2">
                            @foreach (var escopo in escopos)
                            {
                                <div class="col-md-6">
                                    <div class="form-check border rounded p-3 h-100">
                                        <input id="scope_@escopo.Codigo.Replace(":", "_")" name="Escopos" class="form-check-input" type="checkbox" value="@escopo.Codigo" />
                                        <label class="form-check-label" for="scope_@escopo.Codigo.Replace(":", "_")"><strong>@escopo.Codigo</strong><br /><span class="text-muted small">@escopo.Texto</span></label>
                                    </div>
                                </div>
                            }
                        </div>
                    </fieldset>
                    <div class="alert alert-info mb-0">Após criar, copie a chave exibida no retorno. O hash não será mostrado no portal.</div>
                </div>
                <div class="card-footer d-flex justify-content-between bg-white">
                    <a class="btn btn-outline-secondary" asp-controller="Developer" asp-action="Index">Voltar</a>
                    <button type="submit" class="btn btn-primary">Criar API Key</button>
                </div>
            </form>
        </div>
    </div>
</div>
