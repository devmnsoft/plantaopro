@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.HospitalDto>
<h1 class="h3">Hospitais</h1><p class="text-muted">Gestão de hospitais e clínicas</p>
<div class="card p-3 mb-3"><div class="row g-2"><div class="col"><input class="form-control" placeholder="Buscar por nome, CNPJ ou cidade"/></div><div class="col-auto"><button class="btn btn-primary" disabled>Filtrar</button> <button class="btn btn-outline-secondary" disabled>Novo Hospital</button></div></div></div>
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage) || !string.IsNullOrWhiteSpace(ViewBag.ErrorMessage)) { <div class="alert alert-warning">@(Model?.ErrorMessage ?? ViewBag.ErrorMessage)</div> }
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Nome Fantasia</th><th>Razão Social</th><th>CNPJ</th><th>Cidade/UF</th><th>Telefone</th><th>Responsável</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var item in Model.Items){<tr><td>@item.NomeFantasia</td><td>@item.RazaoSocial</td><td>@item.Cnpj</td><td>@item.Cidade/@item.Estado</td><td>@item.Telefone</td><td>@item.Responsavel</td><td><span class="badge @(item.RegStatus=="A"?"bg-success":"bg-secondary")">@(item.RegStatus=="A"?"Ativo":"Inativo")</span></td><td class="text-end"><button class="btn btn-sm btn-outline-primary" disabled>Ver</button></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="8" class="text-center text-muted py-4">Nenhum hospital encontrado.</td></tr>}
</tbody></table></div>