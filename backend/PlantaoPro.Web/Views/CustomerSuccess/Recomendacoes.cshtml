@model IEnumerable<PlantaoPro.Web.Models.SaasRecomendacaoViewModel>
@{ ViewData["Title"] = "Recomendações SaaS"; var itens = Model ?? Array.Empty<PlantaoPro.Web.Models.SaasRecomendacaoViewModel>(); }
<div class="container py-3"><h1 class="h3">Recomendações SaaS</h1><div class="row g-3">@foreach(var item in itens){<div class="col-md-4"><div class="card h-100"><div class="card-body"><span class="badge bg-secondary">@item.Prioridade</span><h2 class="h5 mt-2">@item.Titulo</h2><p>@item.Descricao</p></div></div></div>}</div></div>
