@model LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login • PlantãoPro</title>
    <link rel="icon" type="image/svg+xml" href="~/branding/logo-icon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
</head>
<body class="auth-main">
<div class="login-shell container py-4">
    @await Html.PartialAsync("_ToastMessages")
    <div class="login-wrapper">
        <section class="login-side">
            <div>
                <img src="~/branding/logo-horizontal-light.svg" alt="PlantãoPro" class="img-fluid" style="max-width:290px" />
                <h1 class="h3 mt-4">Gestão de plantões com governança e performance.</h1>
                <p class="mb-0 opacity-75">Uma experiência premium para equipes médicas, coordenação operacional e financeiro trabalharem com previsibilidade.</p>
            </div>
            <div>
                <div class="login-feature"><i class="bi bi-shield-lock"></i><span>Segurança com monitoramento de tentativas e bloqueio temporário inteligente.</span></div>
                <div class="login-feature"><i class="bi bi-calendar2-check"></i><span>Escalas, plantões e disponibilidade em uma visão unificada.</span></div>
                <div class="login-feature"><i class="bi bi-cash-stack"></i><span>Conciliação e pagamentos com rastreabilidade de ponta a ponta.</span></div>
            </div>
        </section>

        <section class="login-card-modern">
            <div class="d-flex align-items-center gap-2 mb-3">
                <img src="~/branding/logo-icon.svg" alt="PlantãoPro" class="login-logo" />
                <div><strong>PlantãoPro</strong><div class="text-muted small">Acesse sua conta profissional</div></div>
            </div>
            <form asp-action="Login" method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert-validation mb-3"></div>
                <div class="mb-3"><label asp-for="Email" class="form-label">E-mail</label><input asp-for="Email" class="form-control form-control-lg" placeholder="voce@empresa.com" autocomplete="email" /><span asp-validation-for="Email" class="text-danger small"></span></div>
                <div class="mb-3"><label asp-for="Senha" class="form-label">Senha</label><div class="input-group"><input asp-for="Senha" class="form-control form-control-lg" type="password" id="senha" placeholder="Sua senha" autocomplete="current-password" /><button class="btn btn-outline-secondary" type="button" onclick="togglePassword('senha',this)" aria-label="Mostrar senha"><i class="bi bi-eye"></i></button></div><span asp-validation-for="Senha" class="text-danger small"></span></div>
                <div class="d-flex justify-content-between align-items-center mb-4"><a asp-action="ForgotPassword" class="small text-decoration-none">Esqueci a senha</a><span class="login-state-tag"><i class="bi bi-shield-check"></i>Ambiente protegido</span></div>
                <button id="btnLogin" class="btn btn-primary btn-lg w-100" type="submit"><span class="label">Entrar</span><span class="spinner-border spinner-border-sm d-none"></span></button>
                <p class="login-footnote mt-3 mb-0">Ao entrar, você concorda com as políticas de uso e segurança da plataforma.</p>
            </form>
        </section>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
