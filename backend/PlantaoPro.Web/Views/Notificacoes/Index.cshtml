@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.NotificacaoDto>
@{ViewData["Title"]="Notificações"; var items=Model?.Items??Enumerable.Empty<PlantaoPro.Web.Models.NotificacaoDto>(); var lidas=items.Count(x=>x.Lida); var nl=items.Count(x=>!x.Lida);} 
<div class="page-header d-flex justify-content-between flex-wrap gap-2 mb-4"><div><h2 class="page-title">Notificações</h2><p class="page-subtitle">Acompanhe alertas, push e avisos do sistema.</p></div><div class="d-flex gap-2"><button class="btn btn-soft-secondary" disabled title="Push nativo disponível em roadmap premium"><i class="bi bi-phone me-1"></i>Conectar Push</button><button class="btn btn-soft-secondary" disabled title="Em breve">Marcar todas como lidas</button></div></div>
<div class="row g-3 mb-3"><div class="col-md-4"><div class="metric-card"><div class="metric-label">Total</div><div class="metric-value">@items.Count()</div></div></div><div class="col-md-4"><div class="metric-card"><div class="metric-label">Lidas</div><div class="metric-value">@lidas</div></div></div><div class="col-md-4"><div class="metric-card"><div class="metric-label">Não lidas</div><div class="metric-value">@nl</div></div></div></div>
<div class="filter-card mb-3"><form class="row g-2"><div class="col-md-4"><input class="form-control" placeholder="Tipo" disabled></div><div class="col-md-4"><input class="form-control" placeholder="Lida/Não lida" disabled></div><div class="col-md-4"><input class="form-control" placeholder="Período" disabled></div></form></div>
<div class="data-card card"><div class="table-responsive"><table class="table table-modern"><thead><tr><th>Título</th><th>Mensagem</th><th>Tipo</th><th>Status</th><th>Data</th><th class="text-end">Ações</th></tr></thead><tbody>@if(items.Any()){foreach(var n in items){<tr><td>@n.Titulo</td><td>@n.Mensagem</td><td>@n.Tipo</td><td>@if(n.Lida){<span class="status-badge status-pago">Lida</span>}else{<span class="status-badge status-pendente">Não lida</span>}</td><td>@n.RegDate.ToString("dd/MM/yyyy HH:mm")</td><td class="action-buttons"><a class="btn btn-sm btn-soft-primary" asp-action="Details" asp-route-id="@n.Id">Detalhes</a><button class="btn btn-sm btn-soft-success" disabled title="Em breve">Marcar como lida</button></td></tr>}}else{<tr><td colspan="6"><div class="empty-state text-center">Nenhuma notificação encontrada.</div></td></tr>}</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model"/></div></div>
