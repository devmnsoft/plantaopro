@{ var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home"; }
<header class="app-topbar">
  <div class="topbar-left"><button class="btn btn-light d-lg-none" id="sidebarToggle" type="button" aria-label="Abrir menu"><i class="bi bi-list"></i></button><div><h1 class="page-title">@(ViewData["Title"] ?? currentController)</h1><nav aria-label="breadcrumb"><ol class="breadcrumb app-breadcrumb mb-0"><li class="breadcrumb-item"><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li class="breadcrumb-item active" aria-current="page">@currentController</li></ol></nav></div></div>
  <div class="topbar-actions"><form class="topbar-search d-none d-xl-flex" asp-controller="Ajuda" asp-action="Busca" method="get"><label class="visually-hidden" for="qTopbar">Buscar</label><i class="bi bi-search"></i><input id="qTopbar" name="q" class="form-control" placeholder="Buscar telas, ajuda e atalhos" /></form><partial name="_ContextBar" /><a class="btn btn-light btn-icon" asp-controller="Ajuda" asp-action="Index" title="Ajuda"><i class="bi bi-question-circle"></i></a><button class="btn btn-light btn-icon position-relative" type="button" data-bs-toggle="offcanvas" data-bs-target="#notificationDrawer" aria-controls="notificationDrawer"><i class="bi bi-bell"></i><span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-danger">@((ViewBag.NotificationCount as int?) ?? 0)</span></button><partial name="_UserMenu" /></div>
</header>
