@model PlantaoPro.Web.Models.CadastroSelfServiceWebViewModel
@{
    ViewData["Title"] = "Cadastro self-service";
}
<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="mb-4">
                <span class="badge bg-success">Self-service</span>
                <h1>Crie sua conta PlantãoPro</h1>
                <p class="text-muted">Preencha empresa, plano e administrador. A API cria tenant, cliente, assinatura, usuário admin, LGPD e onboarding.</p>
                <div class="progress"><div class="progress-bar" style="width: 75%">Cadastro em etapas</div></div>
            </div>
            <form asp-controller="Cadastro" asp-action="Confirmar" method="post" class="card shadow-sm">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <h2 class="h5">1. Empresa</h2>
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">Nome fantasia</label><input class="form-control" asp-for="NomeFantasia" /></div>
                        <div class="col-md-6"><label class="form-label">Razão social</label><input class="form-control" asp-for="RazaoSocial" /></div>
                        <div class="col-md-4"><label class="form-label">CNPJ</label><input class="form-control" asp-for="Cnpj" /></div>
                        <div class="col-md-4"><label class="form-label">Segmento</label><input class="form-control" asp-for="Segmento" /></div>
                        <div class="col-md-4"><label class="form-label">E-mail corporativo</label><input class="form-control" asp-for="EmailCorporativo" /></div>
                        <div class="col-md-4"><label class="form-label">Médicos estimados</label><input class="form-control" asp-for="QuantidadeMedicos" /></div>
                        <div class="col-md-4"><label class="form-label">Unidades</label><input class="form-control" asp-for="QuantidadeHospitais" /></div>
                        <div class="col-md-4"><label class="form-label">Plantões/mês</label><input class="form-control" asp-for="VolumePlantoesMes" /></div>
                    </div>
                    <hr />
                    <h2 class="h5">2. Plano</h2>
                    <select class="form-select" asp-for="PlanoId">
                        @foreach (var plano in Model.Planos)
                        {
                            <option value="@plano.Id">@plano.Nome - @(plano.ValorMensal <= 0 ? "Sob proposta" : plano.ValorMensal.ToString("C"))</option>
                        }
                    </select>
                    <div class="mt-2"><label class="form-label">Periodicidade</label><select class="form-select" asp-for="Periodicidade"><option>MENSAL</option><option>ANUAL</option></select></div>
                    <hr />
                    <h2 class="h5">3. Administrador</h2>
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">Nome</label><input class="form-control" asp-for="ResponsavelNome" /></div>
                        <div class="col-md-6"><label class="form-label">E-mail</label><input class="form-control" asp-for="ResponsavelEmail" /></div>
                        <div class="col-md-6"><label class="form-label">Telefone</label><input class="form-control" asp-for="ResponsavelTelefone" /></div>
                        <div class="col-md-6"><label class="form-label">Cargo</label><input class="form-control" asp-for="ResponsavelCargo" /></div>
                        <div class="col-md-6"><label class="form-label">Senha</label><input type="password" class="form-control" asp-for="Senha" /></div>
                    </div>
                    <hr />
                    <div class="form-check"><input class="form-check-input" asp-for="AceiteTermos" /><label class="form-check-label" asp-for="AceiteTermos">Aceito os termos de uso</label></div>
                    <div class="form-check"><input class="form-check-input" asp-for="AceitePrivacidade" /><label class="form-check-label" asp-for="AceitePrivacidade">Aceito a política de privacidade</label></div>
                    <div class="form-check"><input class="form-check-input" asp-for="ConsentimentoLgpd" /><label class="form-check-label" asp-for="ConsentimentoLgpd">Autorizo o tratamento conforme LGPD</label></div>
                </div>
                <div class="card-footer d-flex justify-content-between"><a class="btn btn-outline-secondary" asp-controller="PlanosPublicos" asp-action="Index">Voltar aos planos</a><button class="btn btn-primary" type="submit">Finalizar cadastro</button></div>
            </form>
        </div>
    </div>
</section>
