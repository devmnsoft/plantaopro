@model PlantaoPro.Web.Models.B2BLaunchPageViewModel
@{
    ViewData["Title"] = Model.Titulo;
}
<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-5">
            <p class="text-uppercase text-primary fw-semibold mb-1">Fluxo auditável</p>
            <h1 class="h3">@Model.Titulo</h1>
            <p class="text-muted">@Model.Subtitulo</p>
            <div class="alert alert-info">Ao salvar, a operação deve chamar a API correspondente, validar tenant/plano/perfil e registrar auditoria.</div>
        </div>
        <div class="col-lg-7">
            <form method="get" asp-controller="Home" asp-action="Dashboard" class="card shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label" for="nome">Nome ou título</label>
                        <input id="nome" name="nome" class="form-control" required maxlength="180" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="prioridade">Prioridade/visibilidade</label>
                        <select id="prioridade" name="prioridade" class="form-select">
                            <option value="NORMAL">Normal</option>
                            <option value="ALTA">Alta</option>
                            <option value="CRITICA">Crítica</option>
                            <option value="PARCEIRO">Parceiro</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="descricao">Descrição</label>
                        <textarea id="descricao" name="descricao" class="form-control" rows="5" maxlength="1200"></textarea>
                    </div>
                    <div class="form-check">
                        <input id="confirmacao" name="confirmacao" class="form-check-input" type="checkbox" required />
                        <label class="form-check-label" for="confirmacao">Confirmo que a operação deve respeitar tenant, permissões, LGPD e limites do plano.</label>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between bg-white">
                    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Dashboard">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Validar fluxo</button>
                </div>
            </form>
        </div>
    </div>
</div>
