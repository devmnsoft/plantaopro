@model PlantaoPro.Web.Models.OperacaoResumoDto
@{
    ViewData["Title"] = "Central Operacional";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1"><i class="bi bi-broadcast-pin text-primary"></i> Central Operacional</h2>
        <p class="text-muted mb-0">Monitore plantões, escalas, pendências financeiras e alertas críticos em tempo real.</p>
    </div>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @ViewBag.ErrorMessage</div>
}

<div class="row g-3 mb-3">
    <div class="col-md-4 col-lg-2"><div class="card p-3"><small>Plantões hoje</small><h4>@Model.TotalPlantoesHoje</h4></div></div>
    <div class="col-md-4 col-lg-2"><div class="card p-3"><small>Plantões abertos</small><h4>@Model.TotalPlantoesAbertos</h4></div></div>
    <div class="col-md-4 col-lg-2"><div class="card p-3"><small>Escalas pendentes</small><h4>@Model.TotalEscalasSolicitadas</h4></div></div>
    <div class="col-md-4 col-lg-2"><div class="card p-3"><small>Conflitos detectados</small><h4>@Model.TotalConflitos</h4></div></div>
    <div class="col-md-4 col-lg-2"><div class="card p-3"><small>Pagamentos pendentes</small><h4>@Model.TotalPagamentosPendentes</h4></div></div>
    <div class="col-md-4 col-lg-2"><div class="card p-3"><small>Valor pendente</small><h4>@Model.ValorPendente.ToString("C")</h4></div></div>
</div>

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap gap-2">
        <a asp-controller="Plantoes" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Novo Plantão</a>
        <a asp-controller="Escalas" asp-action="Index" class="btn btn-outline-primary">Ver Escalas Pendentes</a>
        <a asp-controller="Financeiro" asp-action="Index" class="btn btn-outline-success">Ver Financeiro</a>
        <a asp-controller="Medicos" asp-action="Index" class="btn btn-outline-secondary">Ver Médicos</a>
        <a asp-controller="Notificacoes" asp-action="Index" class="btn btn-outline-dark">Ver Notificações (@Model.NotificacoesNaoLidas)</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4"><div class="card"><div class="card-header">Plantões críticos</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Hospital</th><th>Especialidade</th><th>Início</th></tr></thead><tbody>@foreach(var item in Model.PlantoesCriticos){<tr><td>@item.HospitalNome</td><td>@item.EspecialidadeNome</td><td>@item.DataInicio.ToString("dd/MM HH:mm")</td></tr>} </tbody></table></div></div></div>
    <div class="col-lg-4"><div class="card"><div class="card-header">Escalas pendentes</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Médico</th><th>Hospital</th><th>Período</th></tr></thead><tbody>@foreach(var item in Model.EscalasPendentes){<tr><td>@item.MedicoNome</td><td>@item.HospitalNome</td><td>@item.DataInicio.ToString("dd/MM HH:mm")</td></tr>} </tbody></table></div></div></div>
    <div class="col-lg-4"><div class="card"><div class="card-header">Pagamentos pendentes</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Médico</th><th>Hospital</th><th>Valor</th></tr></thead><tbody>@foreach(var item in Model.PagamentosPendentes){<tr><td>@item.MedicoNome</td><td>@item.HospitalNome</td><td>@item.ValorPrevisto.ToString("C")</td></tr>} </tbody></table></div></div></div>
</div>
