@model PlantaoPro.Web.Models.NovaConversaViewModel
@using PlantaoPro.Web.Models
@{
    ViewData["Title"] = "Nova conversa";
    var usuarios = Model?.UsuariosDisponiveis ?? Array.Empty<UsuarioConversaOpcaoDto>();
}

<h2 class="mb-3">Nova conversa</h2>
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<form asp-action="NovaConversa" method="post" class="card">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3"><label asp-for="Titulo" class="form-label"></label><input asp-for="Titulo" class="form-control" /><span asp-validation-for="Titulo" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="Tipo" class="form-label"></label><input asp-for="Tipo" class="form-control" /><span asp-validation-for="Tipo" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="Entidade" class="form-label"></label><input asp-for="Entidade" class="form-control" /><span asp-validation-for="Entidade" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="MensagemInicial" class="form-label"></label><textarea asp-for="MensagemInicial" rows="4" class="form-control"></textarea><span asp-validation-for="MensagemInicial" class="text-danger"></span></div>

        <div class="mb-3">
            <label class="form-label">Participantes</label>
            @if (usuarios.Any())
            {
                @foreach (var user in usuarios)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="ParticipantesSelecionados" value="@user.UsuarioId" id="usr_@user.UsuarioId" />
                        <label class="form-check-label" for="usr_@user.UsuarioId">@user.Nome <span class="text-muted">(@user.Email)</span></label>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info mb-0">Nenhum usuário disponível no momento. Você ainda pode criar a conversa.</div>
            }
        </div>
    </div>
    <div class="card-footer d-flex justify-content-end gap-2">
        <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
        <button class="btn btn-primary" type="submit">Criar conversa</button>
    </div>
</form>
