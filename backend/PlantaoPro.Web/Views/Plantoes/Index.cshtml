@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PlantaoResumoDto>
@{ var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.PlantaoResumoDto>(); var total=items.Count(); var abertos=items.Count(x=>x.Status=="aberto"); var realizados=items.Count(x=>x.Status=="realizado"); var cancelados=items.Count(x=>x.Status=="cancelado"); var vagas=items.Sum(x=>x.VagasDisponiveis); }
<div class="page-header d-flex justify-content-between align-items-start gap-3 mb-4"><div><h2 class="mb-1">Plantões</h2><p class="text-muted mb-0">Agenda operacional de oportunidades por hospital e especialidade.</p></div><div class="d-flex gap-2"><a class="btn btn-outline-primary" asp-action="Calendario">Calendário</a><a class="btn btn-primary" asp-action="Create">Novo Plantão</a></div></div>
<div class="row g-3 mb-3"><div class="col-md"><div class="metric-card"><div class="metric-label">Total</div><div class="metric-value">@total</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Abertos</div><div class="metric-value">@abertos</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Realizados</div><div class="metric-value">@realizados</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Cancelados</div><div class="metric-value">@cancelados</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Vagas disponíveis</div><div class="metric-value">@vagas</div></div></div></div>
<div class="filter-card mb-3"><div class="row g-2"><div class="col-md-3"><label class="form-label">Hospital</label><input class="form-control" disabled/></div><div class="col-md-2"><label class="form-label">Especialidade</label><input class="form-control" disabled/></div><div class="col-md-2"><label class="form-label">Status</label><select class="form-select" disabled><option>Todos</option></select></div><div class="col-md-3"><label class="form-label">Período</label><input class="form-control" disabled/></div><div class="col-md-2 d-flex align-items-end"><button class="btn btn-soft-primary w-100" disabled title="Em breve">Filtrar</button></div></div></div>
<div class="data-card card"><div class="card-body p-0"><div class="table-responsive"><table class="table table-modern"><thead><tr><th>Hospital</th><th>Cidade/UF</th><th>Especialidade</th><th>Início</th><th>Fim</th><th>Valor</th><th>Vagas</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var p in items){<tr><td>@p.HospitalNome</td><td>@p.HospitalCidade/@p.HospitalEstado</td><td>@p.EspecialidadeNome</td><td>@p.DataInicio.ToString("dd/MM/yyyy HH:mm")</td><td>@p.DataFim.ToString("dd/MM/yyyy HH:mm")</td><td>@p.Valor.ToString("C")</td><td>@p.VagasDisponiveis/@p.Vagas</td><td><partial name="_StatusBadge" model="p.Status"/></td><td class="action-buttons"><a class="btn btn-sm btn-soft-primary" asp-action="Details" asp-route-id="@p.Id">Detalhes</a><button class="btn btn-sm btn-outline-secondary" disabled title="Em breve">Solicitar</button></td></tr>}
@if(!items.Any()){<tr><td colspan="9"><partial name="_EmptyState" model='("bi-calendar-x","Sem plantões","Nenhum plantão disponível no momento.","Novo Plantão","/Plantoes/Create",false)'/></td></tr>}
</tbody></table></div></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model"/></div></div>
