@model LoginViewModel
@{ Layout = null; }
<!DOCTYPE html><html><head><meta name="viewport" content="width=device-width"/><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/><link rel="stylesheet" href="~/css/custom.css"/></head>
<body class="login-page"><div class="login-card shadow-lg"><h2>PlantãoPro</h2><p class="text-muted">Gestão inteligente de plantões médicos.</p><form asp-action="Login" method="post" id="loginForm">@Html.AntiForgeryToken()<div class="mb-3 input-group"><span class="input-group-text"><i class="bi bi-envelope"></i></span><input asp-for="Email" class="form-control" placeholder="E-mail"/></div><span asp-validation-for="Email" class="text-danger"></span><div class="mb-3 input-group"><span class="input-group-text"><i class="bi bi-lock"></i></span><input asp-for="Senha" class="form-control" type="password" id="senha" placeholder="Senha"/><button class="btn btn-outline-secondary" type="button" onclick="togglePassword('senha',this)"><i class="bi bi-eye"></i></button></div><span asp-validation-for="Senha" class="text-danger"></span><button id="btnLogin" class="btn btn-primary w-100" type="submit"><span class="label">Entrar</span><span class="spinner-border spinner-border-sm d-none"></span></button><a asp-action="ForgotPassword" class="d-block text-center mt-3">Esqueci minha senha</a></form><footer class="mt-3 small text-muted">v1.0.0</footer></div><partial name="~/Views/Shared/_ToastMessages.cshtml"/><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script><script src="~/js/site.js"></script></body></html>
