@model PlantaoPro.Web.Models.JornadaClienteFormViewModel
@{ ViewData["Title"] = "Detalhe da Jornada"; var clienteId = (Guid?)ViewBag.ClienteId ?? Guid.Empty; }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Detalhe da jornada", "Timeline, tarefas pendentes e mudança de etapa auditada.", "bi-clock-history")' />
<div class="row g-3"><div class="col-lg-8"><div class="card"><div class="card-body"><h2 class="h5">Timeline</h2><p class="text-muted">Eventos são registrados em <code>jornada_cliente_eventos</code>. Avanços e retrocessos exigem motivo.</p><form asp-action="Avancar" method="post" class="row g-3"><input type="hidden" name="ClienteId" value="@clienteId" /><div class="col-md-9"><label class="form-label">Motivo/resumo</label><input name="Motivo" class="form-control" required /></div><div class="col-md-3 d-flex align-items-end"><button type="submit" class="btn btn-primary w-100">Avançar etapa</button></div></form></div></div></div><div class="col-lg-4"><div class="card"><div class="card-body"><h2 class="h5">Regras</h2><ul class="small mb-0"><li>Conversão exige plano e assinatura.</li><li>Risco cria ação de Customer Success.</li><li>Cancelamento exige motivo.</li></ul></div></div></div></div>
