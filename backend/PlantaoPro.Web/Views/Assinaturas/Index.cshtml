@model PlantaoPro.Web.Models.AssinaturasSaasIndexViewModel
@{ ViewData["Title"] = "Assinaturas SaaS"; var itens = Model.Assinaturas.Items ?? Array.Empty<PlantaoPro.Web.Models.AssinaturaSaasViewModel>(); }
<div class="container-fluid py-3"><div class="d-flex justify-content-between mb-3"><div><h1 class="h3">Assinaturas SaaS</h1><p class="text-muted">Ciclo de vida contratual, trial, suspensão e cancelamento.</p></div><a class="btn btn-primary" asp-action="Create">Nova assinatura</a></div><form method="get" class="card card-body mb-3"><div class="row g-2"><div class="col-md-4"><select class="form-select" name="status"><option value="">Todos</option><option value="TRIAL" selected="@(Model.Status == "TRIAL")">TRIAL</option><option value="ATIVA" selected="@(Model.Status == "ATIVA")">ATIVA</option><option value="SUSPENSA" selected="@(Model.Status == "SUSPENSA")">SUSPENSA</option><option value="CANCELADA" selected="@(Model.Status == "CANCELADA")">CANCELADA</option><option value="VENCIDA" selected="@(Model.Status == "VENCIDA")">VENCIDA</option></select></div><div class="col-md-4"><button class="btn btn-outline-primary" type="submit">Filtrar</button></div></div></form>@if(!itens.Any()){<partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-file-earmark-check", "Nenhuma assinatura", "Crie assinaturas para clientes SaaS.", "Nova assinatura", "Create", "Assinaturas")' />}else{<div class="table-responsive card"><table class="table align-middle mb-0"><thead><tr><th>Cliente</th><th>Plano</th><th>Status</th><th>Vigência</th><th class="text-end">Valor</th><th></th></tr></thead><tbody>@foreach(var item in itens){<tr><td>@item.ClienteNome</td><td>@item.PlanoNome</td><td><span class="badge bg-secondary">@item.Status</span></td><td>@item.DataInicio.ToString("dd/MM/yyyy") - @item.DataFim.ToString("dd/MM/yyyy")</td><td class="text-end">@item.ValorContratado.ToString("C")</td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Detalhes</a> <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Editar</a> <a class="btn btn-sm btn-outline-success" asp-action="Uso" asp-route-id="@item.Id">Uso</a></td></tr>}</tbody></table></div>}</div>
