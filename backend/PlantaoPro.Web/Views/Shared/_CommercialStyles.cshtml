<style>
.pp-hero,.pp-page-head{display:grid;grid-template-columns:minmax(0,1.4fr) minmax(280px,.6fr);gap:2rem;align-items:center;padding:3rem 0}.pp-page-head{display:block}.pp-hero h1,.pp-page-head h1{font-size:clamp(2rem,4vw,4rem);font-weight:800;color:#102a43}.pp-hero p,.pp-page-head p{font-size:1.2rem;color:#486581}.pp-badge{display:inline-flex;background:#e0f2fe;color:#0369a1;border-radius:999px;padding:.45rem .8rem;font-weight:700;margin-bottom:1rem}.pp-actions{display:flex;gap:.75rem;flex-wrap:wrap}.pp-panel,.pp-card,.pp-form{background:#fff;border:1px solid #d9e2ec;border-radius:24px;box-shadow:0 16px 40px rgba(16,42,67,.08);padding:1.5rem}.pp-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;margin:2rem 0}.pp-grid-2{grid-template-columns:repeat(2,minmax(0,1fr))}.pp-card h2{color:#102a43;font-weight:800}.pp-card p,.pp-card li{color:#52606d}.pp-form{max-width:760px;display:grid;gap:1rem}.pp-form label{display:grid;gap:.4rem;font-weight:700;color:#243b53}.pp-form input{border:1px solid #bcccdc;border-radius:12px;padding:.8rem}.pp-progress{height:10px;background:#d9e2ec;border-radius:999px;overflow:hidden}.pp-progress span{display:block;height:100%;background:#0d6efd}.pp-mobile-cta{display:none}.pp-hp{position:absolute;left:-10000px}@media (max-width:900px){.pp-hero,.pp-grid,.pp-grid-2{grid-template-columns:1fr}.pp-mobile-cta{display:block;position:fixed;left:1rem;right:1rem;bottom:1rem;z-index:50}.pp-mobile-cta a{display:block;text-align:center;background:#0d6efd;color:#fff;border-radius:16px;padding:1rem;font-weight:800;text-decoration:none}}
