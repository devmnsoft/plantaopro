@{
    ViewData["Title"] = "BI Executivo";
}
<div class="page-header mb-4"><h1>BI Executivo</h1><p class="text-muted">Indicadores estratégicos do SaaS.</p></div>
<div class="row g-3">
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Clientes Ativos</h6><h3 id="kpi-clientes">-</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Receita Estimada</h6><h3 id="kpi-receita">-</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Receita Vencida</h6><h3 id="kpi-vencida">-</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Cobertura</h6><h3 id="kpi-cobertura">-</h3></div></div></div>
</div>
@section Scripts {
<script>
fetch('/api/bi/resumo-executivo').then(r=>r.json()).then(x=>{const d=x.data||{};document.getElementById('kpi-clientes').innerText=d.totalClientesAtivos??0;document.getElementById('kpi-receita').innerText=(d.receitaMensalEstimada??0).toLocaleString('pt-BR',{style:'currency',currency:'BRL'});document.getElementById('kpi-vencida').innerText=(d.receitaVencida??0).toLocaleString('pt-BR',{style:'currency',currency:'BRL'});document.getElementById('kpi-cobertura').innerText=((d.percentualCobertura??0).toFixed(1))+'%';});
</script>
}
