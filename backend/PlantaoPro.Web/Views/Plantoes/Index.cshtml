@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PlantaoResumoDto>
<div class="page-header d-flex justify-content-between align-items-center">
<div><h1 class="h3 mb-1">Plantões</h1><p class="text-muted mb-0">Visão operacional de vagas e alocação médica.</p></div>
<button class="btn btn-primary" disabled title="Em breve">Novo Plantão</button>
</div>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Hospital</th><th>Cidade/UF</th><th>Especialidade</th><th>Data/Hora</th><th>Valor</th><th>Vagas</th><th>Disp.</th><th>Tipo</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var plantao in Model.Items){<tr><td>@plantao.HospitalNome</td><td>@plantao.HospitalCidade/@plantao.HospitalEstado</td><td>@plantao.EspecialidadeNome</td><td>@plantao.DataInicio.ToString("dd/MM HH:mm") - @plantao.DataFim.ToString("dd/MM HH:mm")</td><td>@plantao.Valor.ToString("C")</td><td>@plantao.Vagas</td><td>@plantao.VagasDisponiveis</td><td>@plantao.Tipo</td><td><span class="badge status-@plantao.Status.ToLowerInvariant()">@plantao.Status</span></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@plantao.Id">Detalhes</a></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="10" class="text-center text-muted py-5">Nenhum plantão encontrado.</td></tr>}
</tbody></table></div><partial name="_Pagination" model="Model" />
