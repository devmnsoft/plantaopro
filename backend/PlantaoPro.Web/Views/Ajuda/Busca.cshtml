@using PlantaoPro.Web.Models
@{
    ViewData["Title"] = "Ajuda interativa";
    var topicos = (ViewBag.Topicos as IEnumerable<AjudaTopicoViewModel>) ?? Array.Empty<AjudaTopicoViewModel>();
    var artigos = (ViewBag.Artigos as IEnumerable<AjudaArtigoViewModel>) ?? Array.Empty<AjudaArtigoViewModel>();
    var busca = ViewBag.Busca as string;
}
<div class="card shadow-sm mb-3"><div class="card-body"><h2 class="h5">Manual de uso interativo</h2><p class="text-muted">Busque tutoriais por perfil e acesse checklists de primeiros passos.</p><form asp-action="Busca" method="get" class="input-group"><input name="termo" class="form-control" value="@busca" placeholder="Buscar no manual" /><button class="btn btn-primary">Buscar</button></form><div class="mt-2"><a class="btn btn-sm btn-outline-secondary" asp-action="PrimeirosPassos">Checklist de primeiros passos</a></div></div></div>
@if (topicos.Any()) { <div class="row g-3 mb-3">@foreach (var topico in topicos) { <div class="col-md-4"><div class="card h-100 shadow-sm"><div class="card-body"><span class="badge text-bg-light">@topico.Perfil</span><h3 class="h6 mt-2">@topico.Titulo</h3><p class="small text-muted">@topico.Descricao</p><a class="btn btn-sm btn-outline-primary" asp-action="Checklist" asp-route-perfil="@topico.Perfil">Ver checklist</a></div></div></div> }</div> }
<div class="row g-3">@foreach (var artigo in artigos) { <div class="col-md-6"><div class="card h-100 shadow-sm"><div class="card-body"><span class="badge text-bg-info">@artigo.Perfil</span><h3 class="h6 mt-2">@artigo.Titulo</h3><p class="text-muted small">@artigo.Resumo</p><a class="btn btn-sm btn-primary" asp-action="Artigo" asp-route-id="@artigo.Id">Ler artigo</a></div></div></div> }</div>
@if (!artigos.Any()) { <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-search", "Nenhum artigo encontrado", "Tente buscar por outro termo ou consulte os checklists por perfil.")' /> }
