@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.NotificacaoDto>
<h1 class="h3">Notificações</h1><p class="text-muted">Central de notificações</p>
<div class="table-responsive"><table class="table table-hover"><thead><tr><th>Título</th><th>Mensagem</th><th>Tipo</th><th>Lida</th><th>Data</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var item in Model.Items){<tr><td>@item.Titulo</td><td>@item.Mensagem</td><td>@item.Tipo</td><td><span class="badge @(item.Lida?"bg-secondary":"bg-warning text-dark")">@(item.Lida?"Lida":"Não lida")</span></td><td>@item.RegDate.ToString("dd/MM/yyyy HH:mm")</td><td class="text-end"><button class="btn btn-sm btn-outline-primary" disabled>Marcar lida</button></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="6" class="text-center text-muted py-4">Nenhuma notificação no período.</td></tr>}
</tbody></table></div><partial name="_Pagination" model="Model" />