@{
    ViewData["Title"] = "Templates de comunicação";
}
<section class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Templates de comunicação</h1>
            <p class="text-muted mb-0">Modelos internos para convites, substituições, pendências e alertas operacionais.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Comunicacao" asp-action="NovaConversa">Usar em conversa</a>
    </div>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm h-100"><div class="card-body"><span class="badge bg-primary mb-2">Convite</span><h2 class="h5">Convite para plantão</h2><p class="text-muted">Mensagem padronizada para médicos sugeridos pela central de escala.</p></div></div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100"><div class="card-body"><span class="badge bg-warning text-dark mb-2">Substituição</span><h2 class="h5">Solicitação de substituto</h2><p class="text-muted">Texto operacional para informar prazo, motivo e confirmação esperada.</p></div></div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100"><div class="card-body"><span class="badge bg-danger mb-2">Risco</span><h2 class="h5">Plantão crítico</h2><p class="text-muted">Alerta para coordenação quando há risco de plantão descoberto.</p></div></div>
        </div>
    </div>
</section>
