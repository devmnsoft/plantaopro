@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.EscalaResumoDto>

@{
    ViewData["Title"] = "Escalas Médicas";

    var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.EscalaResumoDto>();

    var total = items.Count();
    var solicitado = items.Count(x => string.Equals(x.Status, "solicitado", StringComparison.OrdinalIgnoreCase));
    var confirmado = items.Count(x => string.Equals(x.Status, "confirmado", StringComparison.OrdinalIgnoreCase));
    var realizado = items.Count(x => string.Equals(x.Status, "realizado", StringComparison.OrdinalIgnoreCase));
    var cancelado = items.Count(x => string.Equals(x.Status, "cancelado", StringComparison.OrdinalIgnoreCase));
}

<div class="page-header">
    <div>
        <div class="d-flex align-items-center gap-2 mb-1">
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                <i class="bi bi-diagram-3 me-1"></i>
                Operação
            </span>
        </div>

        <h2 class="mb-1">Escalas Médicas</h2>

        <p class="text-muted mb-0">
            Tela principal de operação das confirmações e execução de plantões.
        </p>
    </div>

    <button type="button"
            class="btn btn-primary"
            disabled
            title="Em breve">
        <i class="bi bi-plus-circle me-1"></i>
        Nova Escala
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @Model.ErrorMessage
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Total</div>
            <div class="metric-value">@total</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Solicitadas</div>
            <div class="metric-value">@solicitado</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Confirmadas</div>
            <div class="metric-value">@confirmado</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Realizadas</div>
            <div class="metric-value">@realizado</div>
        </div>
    </div>

    <div class="col-6 col-lg">
        <div class="metric-card">
            <div class="metric-label">Canceladas</div>
            <div class="metric-value">@cancelado</div>
        </div>
    </div>
</div>

<div class="filter-card mb-3">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select class="form-select" name="status" disabled>
                <option value="">Todos</option>
                <option value="solicitado">Solicitado</option>
                <option value="confirmado">Confirmado</option>
                <option value="realizado">Realizado</option>
                <option value="cancelado">Cancelado</option>
                <option value="recusado">Recusado</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Hospital</label>
            <input class="form-control"
                   name="hospital"
                   placeholder="Hospital ou clínica"
                   disabled />
        </div>

        <div class="col-md-3">
            <label class="form-label">Especialidade</label>
            <input class="form-control"
                   name="especialidade"
                   placeholder="Especialidade"
                   disabled />
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="button"
                    class="btn btn-soft-primary w-100"
                    disabled
                    title="Em breve">
                <i class="bi bi-funnel me-1"></i>
                Filtrar
            </button>

            <button type="button"
                    class="btn btn-outline-secondary w-100"
                    disabled
                    title="Em breve">
                Limpar
            </button>
        </div>
    </form>
</div>

<div class="data-card card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <strong>Lista de Escalas</strong>

        <span class="text-muted small">
            Total: @(Model?.Total ?? total)
        </span>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th>Médico</th>
                        <th>Hospital</th>
                        <th>Especialidade</th>
                        <th>Data/Hora</th>
                        <th>Valor</th>
                        <th>Status</th>
                        <th>Justificativa</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @if (items.Any())
                    {
                        foreach (var e in items)
                        {
                            var status = e.Status?.ToLowerInvariant() ?? "";
                            var statusClass = $"status-{status}";

                            <tr>
                                <td>
                                    <div class="fw-semibold">@e.MedicoNome</div>
                                    <small class="text-muted">
                                        CRM @e.MedicoCrm/@e.MedicoUfCrm
                                    </small>
                                </td>

                                <td>@e.HospitalNome</td>

                                <td>@e.EspecialidadeNome</td>

                                <td>
                                    <div>@e.DataInicio.ToString("dd/MM/yyyy HH:mm")</div>
                                    <small class="text-muted">
                                        até @e.DataFim.ToString("HH:mm")
                                    </small>
                                </td>

                                <td>@e.Valor.ToString("C")</td>

                                <td>
                                    <span class="badge @statusClass">
                                        @e.Status
                                    </span>
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(e.Justificativa))
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else
                                    {
                                        @e.Justificativa
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="action-buttons">
                                        <a class="btn btn-sm btn-soft-primary"
                                           asp-action="Details"
                                           asp-route-id="@e.Id">
                                            Detalhes
                                        </a>

                                        <button type="button"
                                                class="btn btn-sm btn-soft-success"
                                                disabled
                                                title="Em breve">
                                            Confirmar
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-soft-danger"
                                                disabled
                                                title="Em breve">
                                            Recusar
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-soft-warning"
                                                disabled
                                                title="Em breve">
                                            Cancelar
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-outline-success"
                                                disabled
                                                title="Em breve">
                                            Realizado
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary"
                                                disabled
                                                title="Em breve">
                                            Pagamento
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty-state">
                                    <i class="bi bi-calendar2-x"></i>
                                    <h5>Sem escalas</h5>
                                    <p class="mb-0">
                                        Nenhuma escala encontrada para os filtros atuais.
                                    </p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white">
        <partial name="_Pagination" model="Model" />
    </div>
</div>