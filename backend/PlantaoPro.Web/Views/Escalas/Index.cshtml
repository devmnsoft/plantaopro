@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.EscalaResumoDto>
@{ ViewData["Title"]="Escalas"; var items = Model.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.EscalaResumoDto>(); var total=items.Count(); var conf=items.Count(x=>x.Status=="confirmado"); var real=items.Count(x=>x.Status=="realizado"); var porHospital=items.GroupBy(x=>x.HospitalNome).OrderByDescending(x=>x.Count()).FirstOrDefault(); var porEsp=items.GroupBy(x=>x.EspecialidadeNome).OrderByDescending(x=>x.Count()).FirstOrDefault(); }
<div class="page-header d-flex justify-content-between flex-wrap gap-2 mb-4"><div><h2 class="page-title">Escalas</h2><p class="page-subtitle">Acompanhe alocação médica com visão premium por período.</p></div><div class="d-flex gap-2 flex-wrap"><button class="btn btn-soft-secondary" disabled title="Exportação PDF disponível na versão enterprise"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</button><button class="btn btn-soft-secondary" disabled title="Exportação Excel disponível na versão enterprise"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button></div></div>
<div class="row g-3 mb-3"><div class="col-md"><div class="metric-card"><div class="metric-label">Total escalas</div><div class="metric-value">@total</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Confirmadas</div><div class="metric-value">@conf</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Realizadas</div><div class="metric-value">@real</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Hospital líder</div><div class="metric-value fs-6">@(porHospital?.Key ?? "Sem dados")</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Especialidade líder</div><div class="metric-value fs-6">@(porEsp?.Key ?? "Sem dados")</div></div></div></div>
<div class="data-card card"><div class="table-responsive"><table class="table table-modern"><thead><tr><th>Médico</th><th>Hospital</th><th>Especialidade</th><th>Data/Hora</th><th>Valor</th><th>Status</th><th>Justificativa</th><th class="text-end">Ações</th></tr></thead><tbody>
@if(items.Any()){foreach (var e in items){<tr><td>@e.MedicoNome<br/><small>CRM @e.MedicoCrm/@e.MedicoUfCrm</small></td><td>@e.HospitalNome</td><td>@e.EspecialidadeNome</td><td>@e.DataInicio.ToString("dd/MM HH:mm") - @e.DataFim.ToString("dd/MM HH:mm")</td><td>@e.Valor.ToString("C")</td><td><partial name="_StatusBadge" model="e.Status"/></td><td>@(e.Justificativa??"-")</td><td class="action-buttons"><a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-soft-primary">Detalhes</a> @if(e.Status=="realizado"){<form asp-controller="Financeiro" asp-action="GerarPagamento" method="post" class="d-inline"><input type="hidden" name="escalaId" value="@e.Id" /><button class="btn btn-sm btn-soft-success" type="submit" data-confirm="Gerar pagamento para @e.MedicoNome?" data-confirm-class="btn-success">Gerar pagamento</button></form>}</td></tr>}}
else {<tr><td colspan="8"><partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel { Icon = "bi-calendar-x", Title = "Nenhuma escala encontrada", Description = "Ajuste os filtros para visualizar alocações por hospital, especialidade e período." }' /></td></tr>}
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model" /></div></div>
