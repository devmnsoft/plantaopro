@model LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Entrar";
}
<div class="login-shell container py-4">
    @await Html.PartialAsync("_ToastMessages")
    <div class="login-card-modern">
        <div class="brand-block text-center">
            <div class="brand-icon mx-auto"><i class="bi bi-calendar2-heart"></i></div>
            <h2 class="mt-3 mb-1">PlantãoPro</h2>
            <p class="text-muted mb-4">Acesse sua conta para gerenciar plantões com eficiência.</p>
        </div>
        <form asp-action="Login" method="post" id="loginForm" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" aria-live="assertive"></div>
            <div class="mb-3"><label asp-for="Email" class="form-label">E-mail</label><input asp-for="Email" class="form-control form-control-lg" autocomplete="username email" inputmode="email" placeholder="voce@empresa.com" /><span asp-validation-for="Email" class="text-danger small"></span></div>
            <div class="mb-3"><label asp-for="Senha" class="form-label">Senha</label><div class="input-group"><input asp-for="Senha" class="form-control form-control-lg" type="password" id="senha" autocomplete="current-password" placeholder="Sua senha" aria-describedby="capsLockWarning" /><button class="btn btn-outline-secondary" type="button" onclick="togglePassword('senha',this)"><i class="bi bi-eye"></i></button></div><div id="capsLockWarning" class="form-text text-warning d-none" aria-live="polite"><i class="bi bi-exclamation-triangle"></i> Caps Lock ativado.</div><span asp-validation-for="Senha" class="text-danger small"></span></div>
            <button id="btnLogin" class="btn btn-primary btn-lg w-100" type="submit"><span class="label">Entrar</span><span class="spinner-border spinner-border-sm d-none"></span></button>
            <a asp-action="ForgotPassword" class="d-inline-block mt-3">Esqueci a senha</a>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/auth-login.js" asp-append-version="true"></script>
}
