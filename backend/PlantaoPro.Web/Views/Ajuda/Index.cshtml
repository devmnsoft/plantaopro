@model PlantaoPro.Web.Models.AjudaInterativaIndexViewModel
@{
    ViewData["Title"] = "Centro de Ajuda";
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Centro de Ajuda", "Manual interativo por perfil, com busca, checklists e links diretos para as telas.", "bi-life-preserver")' />

<div class="alert alert-info d-flex align-items-start gap-2">
    <i class="bi bi-info-circle fs-5"></i>
    <div>O manual mostra conteúdos do perfil <strong>@Model.Perfil</strong>. Use a busca para localizar rotinas de SaaS, operação, financeiro, médico, hospital e LGPD.</div>
</div>

<form asp-action="Index" method="get" class="card card-body mb-3">
    <div class="row g-2">
        <div class="col-md-7"><input name="busca" value="@Model.Busca" class="form-control" placeholder="Buscar tema, tela ou passo" /></div>
        <div class="col-md-3">
            <select name="perfil" class="form-select">
                @foreach (var perfil in new List<string> { "TODOS", "ADMINISTRADOR_GLOBAL", "COORDENACAO", "MEDICO", "FINANCEIRO", "HOSPITAL" })
                {
                    <option value="@perfil">@perfil</option>
                }
            </select>
        </div>
        <div class="col-md-2"><button class="btn btn-primary w-100" type="submit"><i class="bi bi-search"></i> Buscar</button></div>
    </div>
</form>

<div class="row g-3 mb-4">
@foreach (var topico in Model.Topicos)
{
    <div class="col-lg-4 col-md-6">
        <a asp-action="Modulo" asp-route-id="@topico.Slug" class="card text-decoration-none h-100">
            <div class="card-body">
                <i class="bi @topico.Icone fs-2 text-primary"></i>
                <h2 class="h5 mt-2">@topico.Titulo</h2>
                <p class="text-muted mb-0">@topico.Descricao</p>
            </div>
        </a>
    </div>
}
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="h5 mb-0">Artigos recomendados</h2>
    <div class="d-flex gap-2"><a class="btn btn-sm btn-outline-primary" asp-action="PrimeirosPassos">Primeiros passos</a><a class="btn btn-sm btn-outline-secondary" asp-action="Checklist" asp-route-perfil="@Model.Perfil">Checklist</a></div>
</div>
@if (Model.Artigos.Any())
{
    <div class="list-group">
    @foreach (var artigo in Model.Artigos)
    {
        <a class="list-group-item list-group-item-action" asp-action="Artigo" asp-route-id="@artigo.Id">
            <div class="d-flex justify-content-between gap-3">
                <div><strong>@artigo.Titulo</strong><div class="text-muted small">@artigo.Resumo</div></div>
                <span class="badge bg-light text-dark border align-self-start">@artigo.Perfil</span>
            </div>
        </a>
    }
    </div>
}
else
{
    <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-search", "Nenhum artigo encontrado", "Tente outro termo ou selecione o perfil TODOS.")' />
}
