@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PagamentoDto>
<h1 class="h3">Financeiro</h1><p class="text-muted">Gestão de pagamentos</p>
<div class="table-responsive"><table class="table table-hover"><thead><tr><th>Valor Previsto</th><th>Valor Pago</th><th>Status</th><th>Data Prevista</th><th>Data Pagamento</th><th>Forma</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var item in Model.Items){<tr><td>@item.ValorPrevisto.ToString("C")</td><td>@((item.ValorPago ?? 0).ToString("C"))</td><td><span class="badge bg-info">@item.Status</span></td><td>@item.DataPrevista?.ToString("dd/MM/yyyy")</td><td>@item.DataPagamento?.ToString("dd/MM/yyyy")</td><td>@item.FormaPagamento</td><td class="text-end"><button class="btn btn-sm btn-outline-primary" disabled>Ver</button></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="7" class="text-center text-muted py-4">Nenhum pagamento encontrado.</td></tr>}
</tbody></table></div><partial name="_Pagination" model="Model" />