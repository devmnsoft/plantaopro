@using PlantaoPro.Web.Security
@using PlantaoPro.Web.Services.Security
@inject IModuleAccessService ModuleAccess
@inject IPermissionService Permissions
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isGlobalAdmin = User.IsGlobalAdmin();
    var isAdmin = User.IsAdmin();
    var isTenantAdmin = User.IsTenantAdmin();
    var isCoord = User.IsCoordenacao();
    var isOper = User.IsOperador();
    var isFin = User.IsFinanceiro();
    var isMed = User.IsMedico();
    var isHospital = User.IsHospital();
    var isParceiro = User.IsParceiro();
    var isSuporte = User.IsSuporte();
    var isAuditor = User.IsAuditor();
    var isComercial = User.IsComercial();
    var isCs = User.IsCustomerSuccess();
    var tenantName = User.FindFirst("cliente")?.Value ?? User.FindFirst("tenant")?.Value ?? "Tenant demonstração";
    var planName = User.FindFirst("plano")?.Value ?? "Profissional";
    var environmentName = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") ?? "Demo";
    Func<string, string, string> active = (controller, action) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) && (string.IsNullOrWhiteSpace(action) || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)) ? "active" : string.Empty;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#155eef" />
    <title>@(ViewData["Title"] ?? "PlantãoPro")</title>
    <link rel="icon" type="image/svg+xml" href="~/branding/logo-icon.svg" />
    <link rel="apple-touch-icon" href="~/branding/logo-plantaopro.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantaopro-design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantao-saas.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantao-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantao-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantao-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantao-white-label.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantao-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantao-forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/plantaopro-toast.css" asp-append-version="true" />
</head>
<body class="app-body">
@if (isAuthenticated)
{
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <img src="~/branding/logo-horizontal-light.svg" alt="PlantãoPro" class="brand-logo" />
                <div class="brand-subtitle">@tenantName • white label ativo</div>
                <div class="sidebar-badges">
                    <span class="pp-pill pp-pill-soft"><i class="bi bi-gem"></i>@planName</span>
                    <span class="pp-pill pp-pill-env"><i class="bi bi-circle-fill"></i>@environmentName</span>
                </div>
            </div>
            <nav class="sidebar-nav" aria-label="Menu principal">
                @if (isGlobalAdmin || isSuporte || isAuditor)
                {
                    <div class="nav-section-title">Admin SaaS</div>
                    <a class="nav-link-app @active("AdminSaas", string.Empty)" asp-controller="AdminSaas" asp-action="Index"><i class="bi bi-buildings"></i><span>Central SaaS</span></a>
                    <a class="nav-link-app @active("Clientes", string.Empty)" asp-controller="Clientes" asp-action="Index"><i class="bi bi-building-check"></i><span>Clientes/Tenants</span></a>
                    <a class="nav-link-app @active("Planos", string.Empty)" asp-controller="Planos" asp-action="Index"><i class="bi bi-columns-gap"></i><span>Planos</span></a>
                    <a class="nav-link-app @active("Assinaturas", string.Empty)" asp-controller="Assinaturas" asp-action="Index"><i class="bi bi-receipt"></i><span>Assinaturas</span></a>
                    <a class="nav-link-app @active("Permissoes", string.Empty)" asp-controller="Permissoes" asp-action="Index"><i class="bi bi-shield-lock"></i><span>Permissões</span></a>
                    <a class="nav-link-app @active("Observabilidade", string.Empty)" asp-controller="Observabilidade" asp-action="Index"><i class="bi bi-activity"></i><span>Observabilidade</span></a>
                }

                @if (isTenantAdmin)
                {
                    <div class="nav-section-title">Portal Cliente</div>
                    <a class="nav-link-app @active("ClientePortal", string.Empty)" asp-controller="ClientePortal" asp-action="Index"><i class="bi bi-window-sidebar"></i><span>Home Cliente</span></a>
                    <a class="nav-link-app @active("MinhaAssinatura", string.Empty)" asp-controller="MinhaAssinatura" asp-action="Index"><i class="bi bi-card-checklist"></i><span>Minha assinatura</span></a>
                    <a class="nav-link-app @active("Usuarios", string.Empty)" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-person-gear"></i><span>Usuários</span></a>
                    <a class="nav-link-app @active("Perfis", string.Empty)" asp-controller="Perfis" asp-action="Index"><i class="bi bi-person-lock"></i><span>Perfis</span></a>
                    @if (Permissions.CanManageWhiteLabel())
                    {
                        <a class="nav-link-app @active("WhiteLabel", string.Empty)" asp-controller="WhiteLabel" asp-action="Index"><i class="bi bi-palette"></i><span>White label</span></a>
                    }
                    <a class="nav-link-app @active("Marketplace", string.Empty)" asp-controller="Marketplace" asp-action="Index"><i class="bi bi-bag-plus"></i><span>Marketplace</span></a>
                }

                @if (isCoord || isOper || isHospital || isTenantAdmin || isGlobalAdmin)
                {
                    <div class="nav-section-title">Operação</div>
                    <a class="nav-link-app @active("Coordenacao", string.Empty)" asp-controller="Coordenacao" asp-action="Index"><i class="bi bi-kanban"></i><span>Central de Escala</span></a>
                    <a class="nav-link-app @active("CentralEscala", string.Empty)" asp-controller="CentralEscala" asp-action="Index"><i class="bi bi-diagram-3"></i><span>Convites e cobertura</span></a>
                    <a class="nav-link-app @active("Plantoes", string.Empty)" asp-controller="Plantoes" asp-action="Index"><i class="bi bi-calendar2-week"></i><span>Plantões</span></a>
                    <a class="nav-link-app @active("Escalas", string.Empty)" asp-controller="Escalas" asp-action="Index"><i class="bi bi-calendar-check"></i><span>Escalas</span></a>
                    <a class="nav-link-app @active("Agenda", string.Empty)" asp-controller="Agenda" asp-action="Index"><i class="bi bi-calendar3"></i><span>Agenda</span></a>
                    @if (!isHospital)
                    {
                        <a class="nav-link-app @active("Medicos", string.Empty)" asp-controller="Medicos" asp-action="Index"><i class="bi bi-people"></i><span>Médicos</span></a>
                        <a class="nav-link-app @active("Hospitais", string.Empty)" asp-controller="Hospitais" asp-action="Index"><i class="bi bi-hospital"></i><span>Hospitais</span></a>
                    }
                }

                @if (isMed)
                {
                    <div class="nav-section-title">Área do Médico</div>
                    <a class="nav-link-app @active("MedicoArea", string.Empty)" asp-controller="MedicoArea" asp-action="Index"><i class="bi bi-person-heart"></i><span>Resumo</span></a>
                    <a class="nav-link-app @active("MinhaAgenda", string.Empty)" asp-controller="MinhaAgenda" asp-action="Index"><i class="bi bi-calendar-check"></i><span>Minha agenda</span></a>
                    <a class="nav-link-app @active("Financeiro", string.Empty)" asp-controller="Financeiro" asp-action="Index"><i class="bi bi-cash-coin"></i><span>Meus pagamentos</span></a>
                }

                @if (isFin || isTenantAdmin || isGlobalAdmin)
                {
                    <div class="nav-section-title">Financeiro</div>
                    <a class="nav-link-app @active("Financeiro", string.Empty)" asp-controller="Financeiro" asp-action="Index"><i class="bi bi-cash-stack"></i><span>Pagamentos</span></a>
                    <a class="nav-link-app @active("FaturamentoSaas", string.Empty)" asp-controller="FaturamentoSaas" asp-action="Index"><i class="bi bi-receipt-cutoff"></i><span>Billing/Faturas</span></a>
                    <a class="nav-link-app @active("Relatorios", string.Empty)" asp-controller="Relatorios" asp-action="Index"><i class="bi bi-file-earmark-bar-graph"></i><span>Relatórios</span></a>
                }

                @if (isParceiro)
                {
                    <div class="nav-section-title">Parceiro</div>
                    <a class="nav-link-app @active("ParceiroPortal", string.Empty)" asp-controller="ParceiroPortal" asp-action="Index"><i class="bi bi-handshake"></i><span>Portal Parceiro</span></a>
                    <a class="nav-link-app @active("PropostasComerciais", string.Empty)" asp-controller="PropostasComerciais" asp-action="Dashboard"><i class="bi bi-file-earmark-richtext"></i><span>Propostas</span></a>
                }

                @if (isComercial || isCs)
                {
                    <div class="nav-section-title">Crescimento</div>
                    @if (isComercial)
                    {
                        <a class="nav-link-app @active("Comercial", string.Empty)" asp-controller="Comercial" asp-action="Funil"><i class="bi bi-funnel"></i><span>Comercial</span></a>
                        <a class="nav-link-app @active("PropostasComerciais", string.Empty)" asp-controller="PropostasComerciais" asp-action="Dashboard"><i class="bi bi-file-earmark-text"></i><span>Propostas</span></a>
                    }
                    @if (isCs)
                    {
                        <a class="nav-link-app @active("CustomerSuccess", string.Empty)" asp-controller="CustomerSuccess" asp-action="Index"><i class="bi bi-heart-pulse"></i><span>Customer Success</span></a>
                    }
                }

                <div class="nav-section-title">Suporte e governança</div>
                <a class="nav-link-app @active("Ajuda", string.Empty)" asp-controller="Ajuda" asp-action="Index"><i class="bi bi-question-circle"></i><span>Ajuda/Treinamento</span></a>
                <a class="nav-link-app @active("Lgpd", string.Empty)" asp-controller="Lgpd" asp-action="Index"><i class="bi bi-shield-check"></i><span>LGPD</span></a>
                @if (isAdmin || isAuditor || isSuporte)
                {
                    <a class="nav-link-app @active("Auditoria", string.Empty)" asp-controller="Auditoria" asp-action="Index"><i class="bi bi-journal-check"></i><span>Auditoria</span></a>
                }
                @if (isSuporte || isAdmin)
                {
                    <a class="nav-link-app @active("Suporte", string.Empty)" asp-controller="Suporte" asp-action="Index"><i class="bi bi-life-preserver"></i><span>Suporte</span></a>
                }
                <a class="nav-link-app @active("Usuario", string.Empty)" asp-controller="Usuario" asp-action="Index"><i class="bi bi-person-circle"></i><span>Minha conta</span></a>
                <a class="nav-link-app logout-link" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i><span>Sair</span></a>
            </nav>
        </aside>
        <section class="app-main" data-app-shell="true">
            <header class="app-topbar">
                <div class="topbar-left">
                    <button class="btn btn-light d-lg-none" id="sidebarToggle" type="button"><i class="bi bi-list"></i></button>
                    <div>
                        <div class="topbar-brand-line"><img src="~/branding/logo-icon.svg" alt="PlantãoPro" class="topbar-mini-logo" /><span class="topbar-slogan">SaaS B2B white label para escalas médicas.</span></div>
                        <h1 class="page-title">@(ViewData["Title"] ?? currentController)</h1>
                        <nav aria-label="breadcrumb"><ol class="breadcrumb app-breadcrumb mb-0"><li class="breadcrumb-item"><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li class="breadcrumb-item active" aria-current="page">@currentController</li></ol></nav>
                    </div>
                </div>
                <div class="topbar-actions">
                    <form class="topbar-search d-none d-xl-flex" asp-controller="Ajuda" asp-action="Busca" method="get"><i class="bi bi-search"></i><input name="q" class="form-control" placeholder="Buscar telas, ajuda e atalhos" /></form>
                    <partial name="_TenantContextBadge" />
                    <partial name="_PlanUsageMiniCard" />
                    <a class="btn btn-light btn-icon" asp-controller="Ajuda" asp-action="Index" title="Ajuda"><i class="bi bi-question-circle"></i></a>
                    <a class="btn btn-light btn-icon position-relative" asp-controller="Notificacoes" asp-action="Index" title="Notificações"><i class="bi bi-bell"></i><span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-danger">@((ViewBag.NotificationCount as int?) ?? 0)</span></a>
                    <a class="btn btn-warning btn-sm d-none d-md-inline-flex" asp-controller="MinhaAssinatura" asp-action="Upgrade"><i class="bi bi-rocket-takeoff me-1"></i>Upgrade</a>
                    <div class="user-pill"><div class="user-avatar"><i class="bi bi-person"></i></div><div class="user-info"><span class="user-name">@User.Identity?.Name</span><small>@User.PrimaryRole()</small></div></div>
                </div>
            </header>
            <main class="app-content" id="mainContent">
                <partial name="_ToastMessages" />
                @RenderBody()
            </main>
            <footer class="app-footer"><span>PlantãoPro SaaS • v2026.06</span><span>@environmentName</span><span>Powered by MNSOFT</span></footer>
        </section>
    </div>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
}
else
{
    <main class="auth-main"><partial name="_ToastMessages" />@RenderBody()</main>
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/plantaopro-toast.js" asp-append-version="true"></script>
<script src="~/js/plantaopro-ui.js" asp-append-version="true"></script>
<script>
if ("serviceWorker" in navigator) {
  window.addEventListener("load", function(){ navigator.serviceWorker.register("/service-worker.js").catch(function(){}); });
}
</script>
@await RenderSectionAsync("Scripts", false)
<partial name="_ConfirmModal" model="new PlantaoPro.Web.Models.ConfirmModalViewModel()" />
</body>
</html>
