@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PlantaoDto>
<h1 class="h3">Plantões</h1><p class="text-muted">Gestão de plantões</p>
<div class="card p-3 mb-3"><button class="btn btn-outline-secondary" disabled>Novo Plantão</button></div>
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage) || !string.IsNullOrWhiteSpace(ViewBag.ErrorMessage)) { <div class="alert alert-warning">@(Model?.ErrorMessage ?? ViewBag.ErrorMessage)</div> }
<div class="table-responsive"><table class="table table-hover"><thead><tr><th>Data Início</th><th>Data Fim</th><th>Valor</th><th>Vagas</th><th>Vagas Disp.</th><th>Tipo</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var item in Model.Items){<tr><td>@item.DataInicio.ToString("dd/MM/yyyy HH:mm")</td><td>@item.DataFim.ToString("dd/MM/yyyy HH:mm")</td><td>@item.Valor.ToString("C")</td><td>@item.Vagas</td><td>@item.VagasDisponiveis</td><td>@item.Tipo</td><td><span class="badge bg-info">@item.Status</span></td><td class="text-end"><button class="btn btn-sm btn-outline-primary" disabled>Ver</button></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="8" class="text-center text-muted py-4">Nenhum plantão encontrado.</td></tr>}
</tbody></table></div>
<partial name="_Pagination" model="Model" />