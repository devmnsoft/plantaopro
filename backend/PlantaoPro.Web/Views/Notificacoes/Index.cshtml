@model dynamic
@using System.Linq
@{
    var items = Model?.Items as System.Collections.IEnumerable ?? Enumerable.Empty<object>();
}
<h2 class="mb-3">Lista</h2>
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage)) { <div class="alert alert-warning">@Model.ErrorMessage</div> }
<div class="table-responsive"><table class="table table-striped"><thead><tr><th>ID</th><th>Detalhes</th><th>Ações</th></tr></thead><tbody>
@if (items.Cast<object>().Any()) {
foreach (var item in items) {
<tr>
<td>@item.Id</td>
<td>
@if(item.GetType().GetProperty("Nome") != null){@item.Nome}
else if(item.GetType().GetProperty("Titulo") != null){@item.Titulo}
else if(item.GetType().GetProperty("Status") != null){@item.Status}
</td>
<td><a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = item.Id })">Detalhes</a> <button class="btn btn-sm btn-outline-secondary" disabled title="Em breve">Ação</button></td>
</tr>
}
} else { <tr><td colspan="3" class="text-center text-muted">Nenhum registro encontrado.</td></tr> }
</tbody></table></div>
<partial name="_Pagination" model="Model" />
