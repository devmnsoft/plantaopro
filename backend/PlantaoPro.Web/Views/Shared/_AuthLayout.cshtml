@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>@(ViewData["Title"] ?? "Entrar") - PlantãoPro</title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" /><link rel="stylesheet" href="~/css/plantaopro.css" asp-append-version="true" /></head>
<body class="app-body"><a class="skip-link" href="#mainContent">Pular para o conteúdo</a><main id="mainContent" class="container py-5">@if (Configuration.GetValue<bool>("Demo:Enabled")) { <div class="alert alert-info" role="status">Ambiente de demonstração ativo. Credenciais não são exibidas por segurança.</div> } @RenderBody()</main><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>@await RenderSectionAsync("Scripts", false)</body>
</html>
