{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=plantaopro;Username=postgres;Password=__SET_VIA_USER_SECRETS__;Pooling=true;Maximum Pool Size=50;Search Path=plantaopro,public"
  },
  "Database": {
    "AllowLegacyPostgresDatabase": false,
    "AllowDevelopmentAutoCreate": false
  },
  "Jwt": {
    "Issuer": "PlantaoPro",
