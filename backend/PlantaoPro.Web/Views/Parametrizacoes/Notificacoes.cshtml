@model PlantaoPro.Web.Models.ParametrizacoesWebViewModel
@{
    ViewData["Title"] = "Parametrizações";
    var grupos = new Dictionary<string, Dictionary<string, string>> { ["Operacionais"] = Model.Operacionais, ["Financeiras"] = Model.Financeiras, ["Notificações"] = Model.Notificacoes, ["LGPD"] = Model.Lgpd };
}
<section class="container py-4"><h1>@ViewData["Title"]</h1><p class="text-muted">Alterações são por tenant, auditadas e validadas conforme plano.</p>@foreach (var grupo in grupos){<h2 class="h5 mt-4">@grupo.Key</h2><div class="card"><div class="card-body">@foreach (var item in grupo.Value){<div class="row g-2 align-items-center mb-2"><div class="col-md-5"><label class="form-label">@item.Key</label></div><div class="col-md-7"><input class="form-control" value="@item.Value" /></div></div>}</div></div>}<button type="button" class="btn btn-primary mt-3">Salvar parametrizações</button></section>
