@model PlantaoPro.Web.Models.ClienteSaudeSaasViewModel
@{ ViewData["Title"] = "Saúde do cliente"; }
<div class="container py-3"><div class="d-flex justify-content-between"><div><h1 class="h3">@Model.ClienteNome</h1><p>Saúde do cliente: <span class="badge bg-secondary">@Model.Classificacao</span></p></div><form asp-action="Recalcular" method="post">@Html.AntiForgeryToken()<input type="hidden" name="clienteId" value="@Model.ClienteId" /><button class="btn btn-primary" type="submit">Recalcular saúde</button></form></div><div class="card mb-3"><div class="card-body"><h2 class="display-6">@Model.Score</h2><div class="progress"><div class="progress-bar" style="width:@Model.Score%">@Model.Score%</div></div></div></div><div class="row g-3"><div class="col-md-4"><div class="card h-100"><div class="card-header">Riscos</div><ul class="list-group list-group-flush">@foreach(var item in Model.Riscos){<li class="list-group-item">@item</li>}</ul></div></div><div class="col-md-4"><div class="card h-100"><div class="card-header">Oportunidades</div><ul class="list-group list-group-flush">@foreach(var item in Model.Oportunidades){<li class="list-group-item">@item</li>}</ul></div></div><div class="col-md-4"><div class="card h-100"><div class="card-header">Ações recomendadas</div><ul class="list-group list-group-flush">@foreach(var item in Model.AcoesRecomendadas){<li class="list-group-item">@item</li>}</ul></div></div></div><div class="mt-3"><a class="btn btn-outline-secondary" asp-action="Index">Voltar</a> <a class="btn btn-outline-warning" asp-action="Alertas" asp-route-clienteId="@Model.ClienteId">Alertas</a> <a class="btn btn-outline-success" asp-action="Recomendacoes" asp-route-clienteId="@Model.ClienteId">Recomendações</a></div></div>
