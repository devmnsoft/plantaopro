@{ ViewData["Title"] = "Não encontrado"; }
<div class="container py-5">
    <div class="card border-0 shadow-sm mx-auto" style="max-width: 720px;">
        <div class="card-body text-center p-5">
            <i class="bi bi-search text-secondary display-4"></i>
            <h1 class="h3 mt-3">Página ou registro não encontrado</h1>
            <p class="text-muted mb-4">O conteúdo solicitado não existe, foi removido ou não está disponível para o seu perfil.</p>
            <a class="btn btn-primary" asp-controller="Home" asp-action="Dashboard">Voltar ao dashboard</a>
        </div>
    </div>
</div>
