@model PlantaoPro.Web.Models.PagedResult<PlantaoPro.Web.Models.RelatorioSaasLinhaViewModel>
@{ ViewData["Title"] = ViewBag.Titulo ?? "Relatório SaaS"; var itens = Model.Items ?? Array.Empty<PlantaoPro.Web.Models.RelatorioSaasLinhaViewModel>(); var tipo = (string)(ViewBag.Tipo ?? "clientes"); }
<div class="container-fluid py-3"><div class="d-flex justify-content-between mb-3"><div><h1 class="h3">@ViewData["Title"]</h1><p class="text-muted">Relatórios SaaS com paginação e exportação CSV auditada.</p></div><a class="btn btn-outline-success" asp-action="ExportarSaas" asp-route-tipo="@tipo">Exportar CSV</a></div><div class="row g-3 mb-3"><div class="col-md-4"><div class="card"><div class="card-body"><span>Total de linhas</span><h2 class="h4">@Model.Total</h2></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><span>Valor consolidado</span><h2 class="h4">@itens.Sum(x => x.Valor).ToString("C")</h2></div></div></div></div><div class="table-responsive card"><table class="table mb-0"><thead><tr><th>Cliente</th><th>Status</th><th>Classificação</th><th>Quantidade</th><th class="text-end">Valor</th><th>Competência</th></tr></thead><tbody>@if(!itens.Any()){<tr><td colspan="6" class="text-muted p-4">Nenhum dado encontrado.</td></tr>}else{foreach(var item in itens){<tr><td>@item.ClienteNome</td><td>@item.Status</td><td>@item.Classificacao</td><td>@item.Quantidade</td><td class="text-end">@item.Valor.ToString("C")</td><td>@(item.Competencia?.ToString("MM/yyyy") ?? string.Empty)</td></tr>}}</tbody></table></div></div>
