@model PlantaoPro.Web.Models.UsoPlanoViewModel
@{ ViewData["Title"] = "Uso do plano"; }
<div class="container py-3"><h1 class="h3">Uso do plano @Model.PlanoNome</h1><div class="card"><div class="card-body"><p>Status: <span class="badge bg-secondary">@Model.AssinaturaStatus</span></p>@foreach (var item in new[] { new { Nome = "Médicos", Usado = Model.MedicosUsados, Limite = Model.MedicosLimite }, new { Nome = "Hospitais", Usado = Model.HospitaisUsados, Limite = Model.HospitaisLimite }, new { Nome = "Plantões no mês", Usado = Model.PlantoesMesUsados, Limite = Model.PlantoesMesLimite } }) { var pct = item.Limite <= 0 ? 0 : Math.Min(100, item.Usado * 100 / item.Limite); <div class="mb-3"><div class="d-flex justify-content-between"><strong>@item.Nome</strong><span>@item.Usado / @(item.Limite <= 0 ? "Ilimitado" : item.Limite.ToString())</span></div><div class="progress"><div class="progress-bar @(pct >= 80 ? "bg-warning" : "bg-success")" style="width:@pct%">@pct%</div></div></div> }<div class="mt-3"><span class="badge bg-info">Mobile: @(Model.PermiteMobile ? "Sim" : "Não")</span> <span class="badge bg-info">BI: @(Model.PermiteBi ? "Sim" : "Não")</span> <span class="badge bg-info">Relatórios: @(Model.PermiteRelatoriosAvancados ? "Sim" : "Não")</span></div></div></div></div>
