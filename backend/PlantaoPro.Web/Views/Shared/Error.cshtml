@{ ViewData["Title"] = "Erro"; }
<div class="container py-5">
    <div class="card border-0 shadow-sm mx-auto" style="max-width: 720px;">
        <div class="card-body text-center p-5">
            <i class="bi bi-exclamation-triangle text-danger display-4"></i>
            <h1 class="h3 mt-3">Não foi possível concluir a operação</h1>
            <p class="text-muted mb-4">Ocorreu uma falha inesperada. Nossa equipe foi notificada e você pode tentar novamente em instantes.</p>
            <a class="btn btn-primary" asp-controller="Home" asp-action="Dashboard">Voltar ao dashboard</a>
        </div>
    </div>
</div>
