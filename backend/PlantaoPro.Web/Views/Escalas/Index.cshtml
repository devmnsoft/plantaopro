@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.EscalaDto>
<h1 class="h3">Escalas</h1><p class="text-muted">Gestão de escalas</p>
<div class="table-responsive"><table class="table table-hover"><thead><tr><th>Plantão</th><th>Médico</th><th>Status</th><th>Justificativa</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var item in Model.Items){<tr><td>@item.PlantaoId</td><td>@item.MedicoId</td><td><span class="badge bg-info">@item.Status</span></td><td>@(item.Justificativa ?? "-")</td><td class="text-end"><button class="btn btn-sm btn-outline-primary" disabled>Ver</button></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="5" class="text-center text-muted py-4">Nenhuma escala encontrada.</td></tr>}
</tbody></table></div><partial name="_Pagination" model="Model" />