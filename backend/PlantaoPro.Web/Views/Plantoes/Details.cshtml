@model PlantaoPro.Web.Models.DetailsPageViewModel<PlantaoPro.Web.Models.PlantaoDetailsDto>

@{
    ViewData["Title"] = "Detalhes do Plantão";

    var plantao = Model?.Data;
    var status = plantao?.Status?.ToLowerInvariant() ?? "";
    var podeEditar = status == "rascunho";
    var podePublicar = status == "rascunho";
    var podeCancelar = status != "cancelado" && status != "realizado" && status != "pago";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h4 mb-1">Detalhes do Plantão</h1>
        <p class="text-muted mb-0">
            Visualize as informações operacionais do plantão e execute ações conforme o status.
        </p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>
        Voltar
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @Model.ErrorMessage
    </div>
}

@if (plantao is null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
            Plantão não encontrado ou detalhamento ainda não disponível.
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>Informações do Plantão</strong>

            <span class="badge status-@status">
                @plantao.Status
            </span>
        </div>

        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="text-muted small">Hospital/Clínica</div>
                    <div class="fw-semibold">
                        @plantao.HospitalNome
                    </div>
                    <div class="text-muted small">
                        @plantao.HospitalCidade/@plantao.HospitalEstado
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="text-muted small">Especialidade</div>
                    <div class="fw-semibold">
                        @plantao.EspecialidadeNome
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="text-muted small">Início</div>
                    <div class="fw-semibold">
                        @plantao.DataInicio.ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="text-muted small">Fim</div>
                    <div class="fw-semibold">
                        @plantao.DataFim.ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Valor</div>
                    <div class="fw-semibold">
                        @plantao.Valor.ToString("C")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Vagas</div>
                    <div class="fw-semibold">
                        @plantao.Vagas
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Vagas disponíveis</div>
                    <div class="fw-semibold">
                        @plantao.VagasDisponiveis
                    </div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Observações</div>
                    <div>
                        @if (!string.IsNullOrWhiteSpace(plantao.Observacoes))
                        {
                            @plantao.Observacoes
                        }
                        else
                        {
                            <span class="text-muted">Sem observações registradas.</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <strong>Ações do Plantão</strong>
        </div>

        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                @if (podeEditar)
                {
                    <a asp-action="Edit"
                       asp-route-id="@plantao.Id"
                       class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>
                        Editar
                    </a>
                }
                else
                {
                    <button type="button"
                            class="btn btn-outline-primary"
                            disabled
                            title="Somente plantões em rascunho podem ser editados.">
                        <i class="bi bi-pencil me-1"></i>
                        Editar
                    </button>
                }

                <form asp-action="Publicar" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@plantao.Id" />

                    <button type="submit"
                            class="btn btn-success"
                            disabled="@(!podePublicar)"
                            title="@(podePublicar ? "Publicar plantão" : "Somente plantões em rascunho podem ser publicados.")">
                        <i class="bi bi-megaphone me-1"></i>
                        Publicar
                    </button>
                </form>

                <button type="button"
                        class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#cancelModal"
                        disabled="@(!podeCancelar)"
                        title="@(podeCancelar ? "Cancelar plantão" : "Este plantão não pode ser cancelado.")">
                    <i class="bi bi-x-circle me-1"></i>
                    Cancelar
                </button>
            </div>
        </div>
    </div>

    <div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Cancelar" method="post">
                    @Html.AntiForgeryToken()

                    <div class="modal-header">
                        <h5 class="modal-title" id="cancelModalLabel">
                            Cancelar Plantão
                        </h5>

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Fechar">
                        </button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" name="Id" value="@plantao.Id" />

                        <label class="form-label">Justificativa</label>
                        <textarea class="form-control"
                                  name="Justificativa"
                                  rows="4"
                                  required
                                  placeholder="Informe o motivo do cancelamento..."></textarea>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary"
                                type="button"
                                data-bs-dismiss="modal">
                            Fechar
                        </button>

                        <button class="btn btn-danger" type="submit">
                            Confirmar Cancelamento
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}