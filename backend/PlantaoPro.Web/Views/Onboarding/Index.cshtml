@{
    ViewData["Title"] = "Onboarding SaaS";
}
<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h2><i class="bi bi-rocket-takeoff me-2 text-primary"></i>Onboarding de Clientes</h2>
            <p class="text-muted">Configure um novo cliente, plano, unidade e usuário administrador em poucos passos.</p>
            <a asp-action="NovoCliente" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Iniciar onboarding</a>
        </div>
    </div>
</div>
