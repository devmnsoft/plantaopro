@model dynamic

@{
    var totalRegistros = (long?)(Model?.Total) ?? 0L;
    var paginaAtual = (int?)(Model?.Page) ?? 1;
    var tamanhoPagina = (int?)(Model?.PageSize) ?? 20;
    var totalPaginas = (int?)(Model?.TotalPages) ?? 0;
}

@if (totalPaginas > 1)
{
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mt-3">
        <small class="text-muted">
            Total: @totalRegistros registro(s) — Página @paginaAtual de @totalPaginas
        </small>

        <nav aria-label="Paginação">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(paginaAtual <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       href="?pagina=@(paginaAtual - 1)&tamanhoPagina=@tamanhoPagina">
                        Anterior
                    </a>
                </li>

                <li class="page-item active">
                    <span class="page-link">@paginaAtual</span>
                </li>

                <li class="page-item @(paginaAtual >= totalPaginas ? "disabled" : "")">
                    <a class="page-link"
                       href="?pagina=@(paginaAtual + 1)&tamanhoPagina=@tamanhoPagina">
                        Próxima
                    </a>
                </li>
            </ul>
        </nav>
    </div>
}