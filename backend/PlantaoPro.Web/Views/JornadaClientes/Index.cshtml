<div class="row g-3">
@foreach (var etapa in new[] { "Lead cadastrado", "Demonstração agendada", "Proposta enviada", "Negociação", "Convertido", "Implantação", "Treinamento", "Operação assistida", "Ativo", "Expansão", "Risco", "Cancelado" })
