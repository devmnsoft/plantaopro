@model PlantaoPro.Web.Models.SaasResumoExecutivoViewModel
@{
    ViewData["Title"] = "Dashboard SaaS";
    var alertas = ViewBag.Alertas as IEnumerable<PlantaoPro.Web.Models.ClienteAlertaSaasViewModel> ?? Array.Empty<PlantaoPro.Web.Models.ClienteAlertaSaasViewModel>();
}
<div class="container-fluid py-3"><div class="d-flex justify-content-between mb-3"><div><h1 class="h3">Dashboard SaaS executivo</h1><p class="text-muted">MRR, risco, inadimplência, alertas e oportunidades de upgrade.</p></div><a class="btn btn-outline-primary" asp-controller="Relatorios" asp-action="FaturamentoSaas">Relatórios</a></div><div class="row g-3 mb-4">@foreach (var kpi in new[] { new { T = "Clientes ativos", V = Model.ClientesAtivos.ToString(), C = "text-success" }, new { T = "Trial", V = Model.ClientesTrial.ToString(), C = "text-info" }, new { T = "Suspensos", V = Model.ClientesSuspensos.ToString(), C = "text-warning" }, new { T = "Cancelados", V = Model.ClientesCancelados.ToString(), C = "text-danger" }, new { T = "Risco", V = Model.ClientesRisco.ToString(), C = "text-warning" }, new { T = "Críticos", V = Model.ClientesCriticos.ToString(), C = "text-danger" }, new { T = "MRR", V = Model.MrrEstimado.ToString("C"), C = "text-success" }, new { T = "Faturas vencidas", V = Model.FaturasVencidas.ToString(), C = "text-danger" } }) { <div class="col-md-3"><div class="card h-100"><div class="card-body"><span class="text-muted">@kpi.T</span><h2 class="h4 @kpi.C">@kpi.V</h2></div></div></div> }</div><div class="row g-3"><div class="col-lg-6"><div class="card"><div class="card-header">Receita</div><div class="card-body"><p>Prevista no mês: <strong>@Model.ReceitaPrevistaMes.ToString("C")</strong></p><p>Recebida no mês: <strong>@Model.ReceitaRecebidaMes.ToString("C")</strong></p><p>Churn estimado: <strong>@Model.ChurnEstimado</strong></p></div></div></div><div class="col-lg-6"><div class="card"><div class="card-header">Ações comerciais</div><div class="card-body"><p>Clientes próximos do limite: <strong>@Model.ClientesProximosLimite</strong></p><p>Oportunidades de upgrade: <strong>@Model.OportunidadesUpgrade</strong></p><p>Alertas abertos: <strong>@Model.AlertasAbertos</strong></p></div></div></div></div><div class="card mt-3"><div class="card-header">Alertas recentes</div><div class="list-group list-group-flush">@if(!alertas.Any()){<div class="p-3 text-muted">Nenhum alerta aberto.</div>}else{foreach(var alerta in alertas.Take(10)){<a class="list-group-item list-group-item-action" asp-controller="CustomerSuccess" asp-action="Details" asp-route-clienteId="@alerta.ClienteId"><strong>@alerta.ClienteNome</strong> — @alerta.Titulo <span class="badge bg-secondary">@alerta.Severidade</span></a>}}</div></div></div>
