@model PlantaoPro.Web.Models.JornadaClienteDetalheViewModel
@{
    ViewData["Title"] = "Jornada do Cliente";
    var jornada = Model?.Jornada ?? new PlantaoPro.Web.Models.JornadaClienteResumoViewModel();
    var eventos = Model?.Eventos ?? Array.Empty<PlantaoPro.Web.Models.JornadaClienteEventoViewModel>();
    var tarefas = Model?.Tarefas ?? Array.Empty<PlantaoPro.Web.Models.JornadaClienteTarefaViewModel>();
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Jornada do cliente", "Visão contextual da jornada comercial e operacional deste cliente.", "bi-signpost-split")' />
@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage as string)) { <div class="alert alert-warning">@ViewBag.ErrorMessage</div> }
<div class="row g-3">
    <div class="col-lg-4"><div class="card h-100"><div class="card-body"><h2 class="h5">@jornada.ClienteNome</h2><partial name="_StatusBadge" model="jornada.Etapa" /><p class="mt-3 mb-1"><strong>Responsável:</strong> @(string.IsNullOrWhiteSpace(jornada.Responsavel) ? "Customer Success" : jornada.Responsavel)</p><p><strong>Próxima ação:</strong> @(string.IsNullOrWhiteSpace(jornada.ProximaAcao) ? "Definir próxima ação" : jornada.ProximaAcao)</p><a class="btn btn-primary" asp-controller="JornadaClientes" asp-action="Details" asp-route-id="@jornada.ClienteId">Abrir jornada completa</a></div></div></div>
    <div class="col-lg-4"><div class="card h-100"><div class="card-header fw-semibold">Últimos eventos</div><div class="list-group list-group-flush">@if (eventos.Any()) { foreach (var evento in eventos.Take(5)) { <div class="list-group-item"><strong>@evento.Tipo</strong><br /><small>@evento.Resumo</small></div> } } else { <div class="p-4 text-muted">Sem eventos registrados.</div> }</div></div></div>
    <div class="col-lg-4"><div class="card h-100"><div class="card-header fw-semibold">Tarefas pendentes</div><div class="list-group list-group-flush">@if (tarefas.Any()) { foreach (var tarefa in tarefas.Where(x => !string.Equals(x.Status, "CONCLUIDA", StringComparison.OrdinalIgnoreCase)).Take(5)) { <div class="list-group-item"><strong>@tarefa.Titulo</strong><br /><small>@(tarefa.Vencimento.HasValue ? tarefa.Vencimento.Value.ToString("dd/MM/yyyy HH:mm") : "Sem vencimento")</small></div> } } else { <div class="p-4 text-muted">Sem tarefas pendentes.</div> }</div></div></div>
</div>
