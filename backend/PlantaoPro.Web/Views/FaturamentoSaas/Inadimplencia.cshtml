@model PlantaoPro.Web.Models.PagedResult<PlantaoPro.Web.Models.InadimplenciaSaasViewModel>
@{
    ViewData["Title"] = "Inadimplência SaaS";
    var items = Model.Items ?? Array.Empty<PlantaoPro.Web.Models.InadimplenciaSaasViewModel>();
}
<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div><h1 class="h3 mb-1">Inadimplência SaaS</h1><p class="text-muted mb-0">Clientes com faturas vencidas.</p></div>
        <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
    </div>
    @if (!items.Any())
    {
        <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-check-circle", "Sem inadimplência", "Nenhum cliente com faturas vencidas no momento.")' />
    }
    else
    {
        <div class="table-responsive card"><table class="table table-hover mb-0"><thead><tr><th>Cliente</th><th>Faturas vencidas</th><th>Vencimento mais antigo</th><th class="text-end">Valor vencido</th></tr></thead><tbody>
        @foreach (var item in items)
        {
            <tr><td>@item.ClienteNome</td><td>@item.FaturasVencidas</td><td>@item.VencimentoMaisAntigo.ToString("dd/MM/yyyy")</td><td class="text-end">@item.ValorVencido.ToString("C")</td></tr>
        }
        </tbody></table></div>
    }
</div>
