@model PlantaoPro.Web.Models.WhiteLabelWebViewModel
@{
    ViewData["Title"] = "White label";
    var primaria = string.IsNullOrWhiteSpace(Model.CorPrimaria) ? "#155eef" : Model.CorPrimaria;
    var secundaria = string.IsNullOrWhiteSpace(Model.CorSecundaria) ? "#0f766e" : Model.CorSecundaria;
    var menu = string.IsNullOrWhiteSpace(Model.CorMenu) ? "#081a30" : Model.CorMenu;
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("White label profissional", "Configure marca, cores, login, dashboard e rodapé do tenant com fallback seguro por plano.", "bi-palette", "Ver preview", "Preview", "WhiteLabel", false)' />
<div class="row g-3 mb-4">
    <div class="col-md-3"><partial name="_KpiCard" model='new PlantaoPro.Web.Models.KpiCardViewModel("Plano", "Profissional", "White label básico", "bi-gem", null, "primary")' /></div>
    <div class="col-md-3"><partial name="_KpiCard" model='new PlantaoPro.Web.Models.KpiCardViewModel("Logo", string.IsNullOrWhiteSpace(Model.LogoUrl) ? "Fallback" : "Custom", "Sem quebra se vazio", "bi-image", null, "success")' /></div>
    <div class="col-md-3"><partial name="_KpiCard" model='new PlantaoPro.Web.Models.KpiCardViewModel("Preview", "Login + app", "Aplicação visual imediata", "bi-window", null, "success")' /></div>
    <div class="col-md-3"><partial name="_KpiCard" model='new PlantaoPro.Web.Models.KpiCardViewModel("Auditoria", "Obrigatória", "Alterações rastreadas", "bi-journal-check", null, "warning")' /></div>
</div>
<div class="row g-4">
    <div class="col-xl-5">
        <form class="card shadow-sm" method="post" asp-action="Edit">
            @Html.AntiForgeryToken()
            <div class="card-body">
                <h2 class="h5 mb-3">Identidade do tenant</h2>
                <div class="mb-3"><label class="form-label">Nome da plataforma</label><input class="form-control" asp-for="NomePlataforma" placeholder="PlantãoPro" /></div>
                <div class="mb-3"><label class="form-label">Nome do cliente</label><input class="form-control" asp-for="ClienteNome" placeholder="Hospital demonstração" /></div>
                <div class="mb-3"><label class="form-label">Slogan</label><input class="form-control" asp-for="Slogan" placeholder="Escalas médicas com previsibilidade" /></div>
                <div class="row g-3"><div class="col-md-6"><label class="form-label">Cor primária</label><input type="color" class="form-control form-control-color" asp-for="CorPrimaria" /></div><div class="col-md-6"><label class="form-label">Cor secundária</label><input type="color" class="form-control form-control-color" asp-for="CorSecundaria" /></div><div class="col-md-6"><label class="form-label">Cor do menu</label><input type="color" class="form-control form-control-color" asp-for="CorMenu" /></div><div class="col-md-6"><label class="form-label">Cor de fundo</label><input type="color" class="form-control form-control-color" asp-for="CorFundo" /></div></div>
                <div class="mt-3"><label class="form-label">Logo URL</label><input class="form-control" asp-for="LogoUrl" placeholder="https://.../logo.svg" /><div class="form-help">Aceite recomendado: SVG/PNG até 1MB. Se vazio, usa o fallback PlantãoPro.</div></div>
                <div class="mt-3"><label class="form-label">Favicon URL</label><input class="form-control" asp-for="FaviconUrl" placeholder="https://.../favicon.svg" /></div>
                <div class="mt-3"><label class="form-label">Rodapé white label</label><input class="form-control" asp-for="TextoRodape" placeholder="Powered by sua marca" /></div>
            </div>
            <div class="card-footer bg-white d-flex flex-wrap gap-2"><button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#confirmWhiteLabel">Salvar identidade</button><button type="button" class="btn btn-outline-primary">Aplicar template saúde</button><a class="btn btn-outline-secondary" asp-action="Index">Restaurar padrão</a></div>
        </form>
    </div>
    <div class="col-xl-7">
        <div class="wl-preview-shell">
            <div class="row g-0">
                <div class="col-md-4 wl-preview-sidebar" style="background:@menu"><div class="fw-bold fs-5">@(string.IsNullOrWhiteSpace(Model.NomePlataforma) ? "PlantãoPro" : Model.NomePlataforma)</div><div class="small opacity-75 mb-4">@(string.IsNullOrWhiteSpace(Model.ClienteNome) ? "Tenant demonstração" : Model.ClienteNome)</div><div class="d-grid gap-2"><span class="btn text-start text-white" style="background:@primaria">Dashboard</span><span class="btn text-start text-white-50">Plantões</span><span class="btn text-start text-white-50">Financeiro</span></div></div>
                <div class="col-md-8 wl-preview-content" style="background:@Model.CorFundo"><div class="card card-body mb-3"><span class="badge align-self-start" style="background:@secundaria">Preview interno</span><h2 class="mt-3" style="color:@primaria">@(string.IsNullOrWhiteSpace(Model.ClienteNome) ? "Hospital demonstração" : Model.ClienteNome)</h2><p>@(string.IsNullOrWhiteSpace(Model.Slogan) ? "Sua operação com marca própria, módulos e governança SaaS." : Model.Slogan)</p><button class="btn text-white" style="background:@primaria" type="button">Ação principal</button></div><div class="card card-body"><span class="text-muted small">Preview público do login</span><div class="mt-2 p-3 rounded" style="background:linear-gradient(135deg,@primaria,@secundaria); color:white"><strong>@(string.IsNullOrWhiteSpace(Model.NomePlataforma) ? "PlantãoPro" : Model.NomePlataforma)</strong><div class="small">Portal seguro do cliente</div></div></div></div>
            </div>
        </div>
        <partial name="_ModuleLockedNotice" model='@("Planos Essencial exibem white label bloqueado; Profissional libera marca básica; Enterprise e Revendedor liberam experiência completa multi-cliente.")' />
    </div>
</div>
<div class="modal fade" id="confirmWhiteLabel" tabindex="-1" aria-labelledby="confirmWhiteLabelLabel" aria-hidden="true"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h2 class="modal-title h5" id="confirmWhiteLabelLabel">Confirmar alteração visual</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button></div><div class="modal-body">As alterações serão auditadas e aplicadas ao tenant sem exigir deploy.</div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Revisar</button><button type="button" class="btn btn-primary" data-bs-dismiss="modal">Confirmar</button></div></div></div></div>
