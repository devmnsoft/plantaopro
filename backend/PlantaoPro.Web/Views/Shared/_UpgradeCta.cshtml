@model PlantaoPro.Web.Models.LockedResourceViewModel
<div class="pp-upgrade-cta">
    <div class="pp-upgrade-copy">
        <span class="pp-eyebrow">Expansão do plano</span>
        <strong>@Model.Recurso</strong>
        <p>@Model.Motivo</p>
        <small>Plano atual: @Model.PlanoAtual • Recomendado: @Model.PlanoNecessario</small>
    </div>
    <div class="pp-upgrade-actions">
        <a class="btn btn-warning" asp-controller="MinhaAssinatura" asp-action="Upgrade">Solicitar upgrade</a>
        <a class="btn btn-outline-dark" asp-controller="MinhaAssinatura" asp-action="Index">Ver assinatura</a>
    </div>
</div>
