@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PlantaoResumoDto>
@{ ViewData["Title"] = "Plantões"; var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.PlantaoResumoDto>(); }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Plantões","Gerencie oportunidades, vagas, horários e status dos plantões.","bi-calendar2-week","Novo Plantão","Create","Plantoes")' />
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Hospital</th><th>Especialidade</th><th>Período</th><th>Valor</th><th>Vagas</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@if(items.Any()){foreach(var p in items){
    var disponibilidadeCritica = p.Vagas > 0 && p.VagasDisponiveis <= Math.Max(1, (int)Math.Ceiling(p.Vagas * 0.25m));
<tr><td><div class="fw-semibold">@p.HospitalNome</div><div class="text-muted small">@p.HospitalCidade/@p.HospitalEstado</div></td><td>@p.EspecialidadeNome</td><td><div>@p.DataInicio.ToString("dd/MM/yyyy HH:mm")</div><div class="text-muted small">até @p.DataFim.ToString("dd/MM/yyyy HH:mm")</div></td><td>@p.Valor.ToString("C")</td><td><span class="badge @(disponibilidadeCritica ? "text-bg-warning" : "text-bg-light border")">@p.VagasDisponiveis/@p.Vagas</span>@if(disponibilidadeCritica){<div class="small text-warning-emphasis mt-1"><i class="bi bi-exclamation-triangle"></i> Vagas limitadas</div>}</td><td><partial name="_StatusBadge" model="p.Status" /></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@p.Id">Detalhes</a> <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id">Editar</a> <button class="btn btn-sm btn-outline-danger" disabled title="Ação indisponível">Cancelar</button></td></tr>}} else {<tr><td colspan="7" class="py-5"><partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-calendar-x","Nenhum plantão encontrado","Crie um novo plantão para começar a alocação.","Novo Plantão","Create","Plantoes")' /></td></tr>}
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model" /></div></div>
