@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PagamentoResumoDto>
@{var totalPrevisto = Model.Items.Sum(x=>x.ValorPrevisto); var totalPendente = Model.Items.Where(x=>x.Status=="pendente").Sum(x=>x.ValorPrevisto); var totalPago = Model.Items.Where(x=>x.ValorPago.HasValue).Sum(x=>x.ValorPago ?? 0);}
<div class="page-header"><h1 class="h3 mb-1">Financeiro</h1><p class="text-muted mb-0">Controle de repasses, previsões e pagamentos realizados.</p></div>
<div class="row g-3 mb-3"><div class="col-md-4"><div class="metric-card"><small>Total previsto</small><h5>@totalPrevisto.ToString("C")</h5></div></div><div class="col-md-4"><div class="metric-card"><small>Total pendente</small><h5>@totalPendente.ToString("C")</h5></div></div><div class="col-md-4"><div class="metric-card"><small>Total pago</small><h5>@totalPago.ToString("C")</h5></div></div></div>
<div class="filter-bar d-flex gap-2 flex-wrap"><button class="btn btn-sm btn-outline-secondary" disabled title="Em breve">Status</button><button class="btn btn-sm btn-outline-secondary" disabled title="Em breve">Período</button><button class="btn btn-sm btn-outline-secondary" disabled title="Em breve">Forma de pagamento</button></div>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Médico</th><th>CRM</th><th>Hospital</th><th>Especialidade</th><th>Data do plantão</th><th>Valor previsto</th><th>Valor pago</th><th>Status</th><th>Data prevista</th><th>Data pagamento</th><th>Forma pagamento</th><th class="text-end">Ações</th></tr></thead><tbody>
@foreach (var pg in Model.Items){<tr><td>@pg.MedicoNome</td><td>@pg.MedicoCrm</td><td>@pg.HospitalNome</td><td>@pg.EspecialidadeNome</td><td>@pg.DataPlantao.ToString("dd/MM/yyyy")</td><td>@pg.ValorPrevisto.ToString("C")</td><td>@((pg.ValorPago ?? 0).ToString("C"))</td><td><span class="badge status-@pg.Status.ToLowerInvariant()">@pg.Status</span></td><td>@pg.DataPrevista?.ToString("dd/MM/yyyy")</td><td>@pg.DataPagamento?.ToString("dd/MM/yyyy")</td><td>@(pg.FormaPagamento ?? "-")</td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@pg.Id">Detalhes</a></td></tr>}
@if (!Model.Items.Any()){<tr><td colspan="12" class="empty-state">Nenhum pagamento encontrado.</td></tr>}
</tbody></table></div><partial name="_Pagination" model="Model" />