@model PlantaoPro.Web.Models.MinhaAgendaViewModel
@{ ViewData["Title"] = "Minha Agenda"; var pl = Model?.MeusPlantoes ?? Enumerable.Empty<PlantaoPro.Web.Models.PlantaoResumoDto>(); var pg = Model?.MeusPagamentos ?? Enumerable.Empty<PlantaoPro.Web.Models.PagamentoResumoDto>(); var nt = Model?.MinhasNotificacoes ?? Enumerable.Empty<PlantaoPro.Web.Models.NotificacaoDto>(); }
<div class="page-header mb-4"><h2 class="page-title">Minha Agenda</h2><p class="page-subtitle">Acompanhe seus próximos compromissos, escalas e repasses.</p></div>
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage)){<div class="alert alert-warning">@Model.ErrorMessage</div>}
<div class="row g-3">
<div class="col-lg-6"><div class="data-card card"><div class="card-header">Próximos plantões</div><div class="card-body">@if(pl.Any()){<ul class="list-group list-group-flush">@foreach(var p in pl.Take(6)){<li class="list-group-item d-flex justify-content-between"><div><div class="fw-semibold">@p.HospitalNome</div><small>@p.EspecialidadeNome</small></div><span>@p.DataInicio.ToString("dd/MM HH:mm")</span></li>}</ul>}else{<div class="empty-state text-center">Nenhum plantão previsto.</div>}</div></div></div>
<div class="col-lg-6"><div class="data-card card"><div class="card-header">Escalas confirmadas</div><div class="card-body">@{var conf=pl.Where(x=>x.Status.Equals("confirmado",StringComparison.OrdinalIgnoreCase));} @if(conf.Any()){<ul class="list-group list-group-flush">@foreach(var c in conf.Take(6)){<li class="list-group-item d-flex justify-content-between"><span>@c.HospitalNome - @c.EspecialidadeNome</span><partial name="_StatusBadge" model="c.Status" /></li>}</ul>}else{<div class="empty-state text-center">Sem escalas confirmadas no momento.</div>}</div></div></div>
<div class="col-lg-6"><div class="data-card card"><div class="card-header">Pagamentos pendentes</div><div class="card-body">@{var pend=pg.Where(x=>x.Status.Equals("pendente",StringComparison.OrdinalIgnoreCase));} @if(pend.Any()){<ul class="list-group list-group-flush">@foreach(var p in pend.Take(6)){<li class="list-group-item d-flex justify-content-between"><span>@p.HospitalNome</span><span>@p.ValorPrevisto.ToString("C")</span></li>}</ul>}else{<div class="empty-state text-center">Sem pagamentos pendentes.</div>}</div></div></div>
<div class="col-lg-6"><div class="data-card card"><div class="card-header">Notificações recentes</div><div class="card-body">@if(nt.Any()){<ul class="list-group list-group-flush">@foreach(var n in nt.Take(6)){<li class="list-group-item"><div class="fw-semibold">@n.Titulo</div><small class="text-muted">@n.RegDate.ToString("dd/MM/yyyy HH:mm")</small></li>}</ul>}else{<div class="empty-state text-center">Nenhuma notificação recente.</div>}</div></div></div>
</div>
