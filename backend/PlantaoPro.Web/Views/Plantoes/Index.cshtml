@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PlantaoResumoDto>
@{ViewData["Title"]="Plantões"; var items=Model?.Items??Enumerable.Empty<PlantaoPro.Web.Models.PlantaoResumoDto>(); var total=items.Count(); var ab=items.Count(x=>x.Status=="aberto"); var cf=items.Count(x=>x.Status=="confirmado"); var rl=items.Count(x=>x.Status=="realizado"); var cc=items.Count(x=>x.Status=="cancelado"); var vagas=items.Sum(x=>x.VagasDisponiveis);} 
<div class="page-header d-flex justify-content-between mb-4"><div><h2 class="page-title">Plantões</h2><p class="page-subtitle">Gerencie oportunidades, vagas, horários e status dos plantões.</p></div><div class="d-flex gap-2"><a class="btn btn-soft-secondary" asp-action="Calendario">Calendário</a><a class="btn btn-primary" asp-action="Create">Novo Plantão</a></div></div>
<div class="row g-3 mb-3">@foreach(var k in new[]{("Total",total.ToString()),("Abertos",ab.ToString()),("Confirmados",cf.ToString()),("Realizados",rl.ToString()),("Cancelados",cc.ToString()),("Vagas disponíveis",vagas.ToString())}){<div class="col-6 col-lg-2"><div class="metric-card"><div class="metric-label">@k.Item1</div><div class="metric-value">@k.Item2</div></div></div>}</div>
<div class="filter-card mb-3"><form class="row g-3"><div class="col-md-2"><label class="form-label">Hospital</label><input class="form-control" disabled></div><div class="col-md-2"><label>Especialidade</label><input class="form-control" disabled></div><div class="col-md-2"><label>Status</label><input class="form-control" disabled></div><div class="col-md-2"><label>Tipo</label><input class="form-control" disabled></div><div class="col-md-2"><label>Data inicial</label><input class="form-control" disabled></div><div class="col-md-2"><label>Data final</label><input class="form-control" disabled></div></form></div>
<div class="data-card card"><div class="table-responsive"><table class="table table-modern"><thead><tr><th>Hospital</th><th>Cidade/UF</th><th>Especialidade</th><th>Início</th><th>Fim</th><th>Valor</th><th>Vagas</th><th>Vagas disponíveis</th><th>Tipo</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@if(items.Any()){foreach(var p in items){<tr><td>@p.HospitalNome</td><td>@p.HospitalCidade/@p.HospitalEstado</td><td>@p.EspecialidadeNome</td><td>@p.DataInicio.ToString("dd/MM/yyyy HH:mm")</td><td>@p.DataFim.ToString("dd/MM/yyyy HH:mm")</td><td>@p.Valor.ToString("C")</td><td>@p.Vagas</td><td>@p.VagasDisponiveis</td><td>@p.Tipo</td><td><partial name="_StatusBadge" model="p.Status"/></td><td class="action-buttons"><a class="btn btn-sm btn-soft-primary" asp-action="Details" asp-route-id="@p.Id">Detalhes</a><a class="btn btn-sm btn-soft-secondary" asp-action="Edit" asp-route-id="@p.Id">Editar</a><button class="btn btn-sm btn-soft-success" disabled title="Em breve">Publicar</button><button class="btn btn-sm btn-soft-danger" disabled title="Em breve">Cancelar</button><button class="btn btn-sm btn-soft-warning" disabled title="Em breve">Ver escalas</button></td></tr>}} else {<tr><td colspan="11"><div class="empty-state text-center">Nenhum plantão encontrado.</div></td></tr>}
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model"/></div></div>
