@model IEnumerable<PlantaoPro.Web.Models.FunilItemViewModel>
@{ ViewData["Title"] = "Funil comercial"; }
<div class="d-flex gap-2 mb-3"><a class="btn btn-primary" asp-action="Leads">Leads</a><a class="btn btn-outline-primary" asp-action="Oportunidades">Oportunidades</a><a class="btn btn-outline-primary" asp-action="Propostas">Propostas</a><a class="btn btn-outline-secondary" asp-action="PrevisaoReceita">Previsão de receita</a></div>
<div class="row g-3">@foreach (var item in Model) { <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><span class="text-muted small">@item.Etapa</span><div class="display-6">@item.Quantidade</div></div></div></div> }</div>
@if (!Model.Any()) { <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-funnel", "Funil comercial vazio", "Crie leads e oportunidades para alimentar o funil.", "Criar lead", "Leads", "Comercial")' /> }
