@model PlantaoPro.Web.Models.AssinaturaSaasViewModel
@{ ViewData["Title"] = "Detalhes da assinatura"; }
<div class="container py-3"><h1 class="h3">Assinatura de @Model.ClienteNome</h1><div class="card mb-3"><div class="card-body"><dl class="row"><dt class="col-sm-3">Plano</dt><dd class="col-sm-9">@Model.PlanoNome</dd><dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge bg-secondary">@Model.Status</span></dd><dt class="col-sm-3">Valor</dt><dd class="col-sm-9">@Model.ValorContratado.ToString("C")</dd></dl><a class="btn btn-outline-secondary" asp-action="Index">Voltar</a> <a class="btn btn-outline-success" asp-action="Uso" asp-route-id="@Model.Id">Uso do plano</a> <a class="btn btn-outline-primary" asp-action="AlterarPlano" asp-route-id="@Model.Id">Alterar plano</a></div></div><div class="card"><div class="card-header">Ações sensíveis</div><div class="card-body d-flex gap-2"><form asp-action="AlterarStatus" method="post" data-confirm="true" data-confirm-message="Suspender assinatura?">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="acao" value="suspender" /><input class="form-control mb-2" name="justificativa" placeholder="Justificativa" /><button class="btn btn-outline-warning" type="submit">Suspender</button></form><form asp-action="AlterarStatus" method="post" data-confirm="true" data-confirm-message="Reativar assinatura?">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="acao" value="reativar" /><input class="form-control mb-2" name="justificativa" placeholder="Justificativa" /><button class="btn btn-outline-success" type="submit">Reativar</button></form><form asp-action="AlterarStatus" method="post" data-confirm="true" data-confirm-message="Cancelar assinatura?">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="acao" value="cancelar" /><input class="form-control mb-2" name="justificativa" placeholder="Justificativa" /><button class="btn btn-outline-danger" type="submit">Cancelar</button></form></div></div></div>
