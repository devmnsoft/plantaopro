@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.PagamentoResumoDto>
@{ViewData["Title"]="Financeiro"; var items=Model?.Items??Enumerable.Empty<PlantaoPro.Web.Models.PagamentoResumoDto>(); var pend=items.Where(x=>x.Status=="pendente"); var pago=items.Where(x=>x.Status=="pago"); var previstoMes=items.Where(x=>x.DataPrevista.HasValue && x.DataPrevista.Value.Month==DateTime.Today.Month && x.DataPrevista.Value.Year==DateTime.Today.Year).Sum(x=>x.ValorPrevisto);} 
<div class="page-header mb-4"><h2 class="page-title">Financeiro</h2><p class="page-subtitle">Controle pagamentos previstos, pendentes, pagos e cancelados.</p></div>
<div class="row g-3 mb-3"><div class="col-md"><div class="metric-card"><div class="metric-label">Valor pendente</div><div class="metric-value">@pend.Sum(x=>x.ValorPrevisto).ToString("C")</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Valor pago</div><div class="metric-value">@pago.Sum(x=>x.ValorPago ?? 0).ToString("C")</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Quantidade pendente</div><div class="metric-value">@pend.Count()</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Quantidade paga</div><div class="metric-value">@pago.Count()</div></div></div><div class="col-md"><div class="metric-card"><div class="metric-label">Valor previsto no mês</div><div class="metric-value">@previstoMes.ToString("C")</div></div></div></div>
<div class="filter-card mb-3"><form class="row g-2"><div class="col-md-2"><input class="form-control" placeholder="Médico" disabled></div><div class="col-md-2"><input class="form-control" placeholder="Hospital" disabled></div><div class="col-md-2"><input class="form-control" placeholder="Status" disabled></div><div class="col-md-2"><input class="form-control" placeholder="Data prevista" disabled></div><div class="col-md-2"><input class="form-control" placeholder="Data pagamento" disabled></div><div class="col-md-2"><input class="form-control" placeholder="Forma pagamento" disabled></div></form></div>
<div class="data-card card"><div class="table-responsive"><table class="table table-modern"><thead><tr><th>Médico</th><th>CRM</th><th>Hospital</th><th>Especialidade</th><th>Data do plantão</th><th>Valor previsto</th><th>Valor pago</th><th>Status</th><th>Data prevista</th><th>Data pagamento</th><th>Forma</th><th class="text-end">Ações</th></tr></thead><tbody>@if(items.Any()){foreach(var pg in items){<tr><td>@pg.MedicoNome</td><td>@pg.MedicoCrm</td><td>@pg.HospitalNome</td><td>@pg.EspecialidadeNome</td><td>@pg.DataPlantao:dd/MM/yyyy</td><td>@pg.ValorPrevisto.ToString("C")</td><td>@((pg.ValorPago ?? 0).ToString("C"))</td><td><partial name="_StatusBadge" model="pg.Status"/></td><td>@(pg.DataPrevista?.ToString("dd/MM/yyyy") ?? "-")</td><td>@(pg.DataPagamento?.ToString("dd/MM/yyyy") ?? "-")</td><td>@(string.IsNullOrWhiteSpace(pg.FormaPagamento)?"-":pg.FormaPagamento)</td><td class="action-buttons"><a class="btn btn-sm btn-soft-primary" asp-action="Details" asp-route-id="@pg.Id">Detalhes</a><button class="btn btn-sm btn-soft-success" disabled title="Em breve">Confirmar pagamento</button><button class="btn btn-sm btn-soft-danger" disabled title="Em breve">Cancelar pagamento</button></td></tr>}}else{<tr><td colspan="12"><div class="empty-state text-center">Nenhum pagamento encontrado.</div></td></tr>}</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model"/></div></div>
