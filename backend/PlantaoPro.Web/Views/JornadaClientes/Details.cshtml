@model PlantaoPro.Web.Models.JornadaClienteViewModel
@{ ViewData["Title"] = "Detalhe da jornada"; }
<div class="row g-3">
<div class="col-lg-8"><div class="card shadow-sm"><div class="card-body"><span class="badge text-bg-primary">@Model.Etapa</span><h2 class="h4 mt-2">@Model.ClienteNome</h2><div class="progress mb-3"><div class="progress-bar" style="width:@Math.Min(Model.Score,100)%">@Model.Score</div></div><p><strong>Responsável:</strong> @(string.IsNullOrWhiteSpace(Model.Responsavel) ? "Não definido" : Model.Responsavel)</p><p><strong>Próxima ação:</strong> @(string.IsNullOrWhiteSpace(Model.ProximaAcao) ? "Não definida" : Model.ProximaAcao)</p></div></div></div>
<div class="col-lg-4"><div class="card shadow-sm"><div class="card-body"><h3 class="h6">Mudar etapa</h3>
<form asp-action="Avancar" asp-route-clienteId="@Model.ClienteId" method="post" class="mb-2" data-ajax-form="true" data-confirm="true" data-confirm-title="Avançar etapa" data-confirm-message="Confirma avançar a jornada?" data-confirm-type="success">@Html.AntiForgeryToken()<input name="Motivo" class="form-control mb-2" placeholder="Motivo/resumo" required /><input name="Responsavel" class="form-control mb-2" placeholder="Responsável" /><input name="ProximaAcao" class="form-control mb-2" placeholder="Próxima ação" /><button class="btn btn-success w-100" type="submit">Avançar etapa</button></form>
<form asp-action="Retroceder" asp-route-clienteId="@Model.ClienteId" method="post" data-ajax-form="true" data-confirm="true" data-confirm-title="Retroceder etapa" data-confirm-message="Confirma retroceder a jornada?" data-confirm-type="warning">@Html.AntiForgeryToken()<input name="Motivo" class="form-control mb-2" placeholder="Justificativa" required /><button class="btn btn-outline-warning w-100" type="submit">Retroceder etapa</button></form>
</div></div></div></div>
<div class="card shadow-sm mt-3"><div class="card-body"><h3 class="h6">Criar tarefa</h3><form asp-action="CriarTarefa" method="post" class="row g-2" data-ajax-form="true">@Html.AntiForgeryToken()<input type="hidden" name="ClienteId" value="@Model.ClienteId" /><div class="col-md-4"><input name="Titulo" class="form-control" placeholder="Título" required /></div><div class="col-md-3"><input name="Responsavel" class="form-control" placeholder="Responsável" /></div><div class="col-md-3"><input name="Prazo" class="form-control" type="datetime-local" /></div><div class="col-md-2"><button class="btn btn-primary w-100" type="submit">Criar tarefa</button></div><div class="col-12"><input name="Descricao" class="form-control" placeholder="Descrição" /></div></form></div></div>
