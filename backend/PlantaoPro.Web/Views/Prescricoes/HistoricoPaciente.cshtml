@{
    ViewData["Title"] = "Saúde 360";
}
<section class="container-fluid py-3">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <p class="text-uppercase text-primary fw-semibold small mb-1">PlantãoPro Saúde 360</p>
            <h1 class="h4 mb-2">@ViewData["Title"]</h1>
            <p class="text-muted mb-3">Jornada clínica com tenant, perfil, auditoria LGPD e restrição de dados sensíveis.</p>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge bg-primary-subtle text-primary">Consulta médica</span>
                <span class="badge bg-success-subtle text-success">CID</span>
                <span class="badge bg-info-subtle text-info">Prescrição</span>
                <span class="badge bg-warning-subtle text-warning">Auditoria clínica</span>
            </div>
        </div>
    </div>
</section>
