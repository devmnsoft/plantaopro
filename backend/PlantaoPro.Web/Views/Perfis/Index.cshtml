@model IEnumerable<PlantaoPro.Web.Models.PerfilWebViewModel>
@{
    ViewData["Title"] = "Perfis e permissões";
}
<section class="container-fluid py-4">
    <div class="d-flex justify-content-between mb-3"><div><h1>Perfis parametrizáveis</h1><p class="text-muted">Perfis base e customizados restritos ao tenant.</p></div><a class="btn btn-primary" asp-controller="Perfis" asp-action="Create">Novo perfil</a></div>
    <div class="card shadow-sm"><div class="table-responsive"><table class="table align-middle"><thead><tr><th>Perfil</th><th>Código</th><th>Tipo</th><th>Status</th><th></th></tr></thead><tbody>@foreach (var perfil in Model){<tr><td>@perfil.Nome</td><td><code>@perfil.Codigo</code></td><td>@(perfil.BaseSistema ? "Base" : "Customizado")</td><td><span class="badge bg-success">@perfil.Status</span></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-controller="Perfis" asp-action="Permissoes" asp-route-id="@perfil.Id">Permissões</a></td></tr>}</tbody></table></div></div>
</section>
