@model string
<div class="alert alert-warning d-flex align-items-start gap-3" role="alert">
    <i class="bi bi-lock-fill fs-4"></i>
    <div>
        <strong>Módulo bloqueado pelo plano.</strong>
        <div>@(string.IsNullOrWhiteSpace(Model) ? "Este recurso exige upgrade de plano ou liberação comercial." : Model)</div>
        <a class="btn btn-sm btn-warning mt-2" asp-controller="MinhaAssinatura" asp-action="Upgrade">Solicitar upgrade</a>
    </div>
</div>
