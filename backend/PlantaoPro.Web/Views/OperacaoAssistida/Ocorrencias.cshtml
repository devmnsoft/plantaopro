@model PlantaoPro.Web.Models.OperacaoAssistidaOcorrenciasPageViewModel
@{
    ViewData["Title"] = "Ocorrências da Operação Assistida";
    var ocorrencias = Model?.Ocorrencias ?? Array.Empty<PlantaoPro.Web.Models.OperacaoAssistidaOcorrenciaViewModel>();
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Ocorrências da Homologação", Model?.ClienteNome ?? "Cliente", "bi-exclamation-triangle", null, null, null, true)' />

<form method="get" class="row g-2 mb-3">
    <input type="hidden" name="clienteId" value="@(Model?.ClienteId ?? Guid.Empty)" />
    <div class="col-md-3"><input name="status" class="form-control" value="@Model?.Status" placeholder="Status" /></div>
    <div class="col-md-3"><input name="prioridade" class="form-control" value="@Model?.Prioridade" placeholder="Prioridade" /></div>
    <div class="col-md-2"><button type="submit" class="btn btn-outline-primary w-100">Filtrar</button></div>
</form>

<div class="card mb-3"><div class="card-body">
    <h5>Nova ocorrência</h5>
    <form asp-action="CriarOcorrencia" method="post" class="row g-2" data-confirm="true" data-confirm-title="Registrar ocorrência" data-confirm-message="Confirma registrar esta ocorrência da homologação assistida? Ocorrências críticas geram alerta operacional." data-confirm-type="warning">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ClienteId" value="@(Model?.ClienteId ?? Guid.Empty)" />
        <div class="col-md-2"><select name="Tipo" class="form-select"><option>BUG</option><option>DUVIDA</option><option>MELHORIA</option><option>TREINAMENTO</option><option>CONFIGURACAO</option></select></div>
        <div class="col-md-2"><select name="Prioridade" class="form-select"><option>BAIXA</option><option selected>MEDIA</option><option>ALTA</option><option>CRITICA</option></select></div>
        <div class="col-md-2"><input name="Responsavel" class="form-control" placeholder="Responsável" /></div>
        <div class="col-md-5"><input name="Descricao" class="form-control" placeholder="Descrição" required /></div>
        <div class="col-md-1"><button type="submit" class="btn btn-primary w-100">Salvar</button></div>
    </form>
</div></div>

@if (!ocorrencias.Any())
{
    <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-exclamation-triangle", "Nenhuma ocorrência", "Registre dúvidas, bugs, melhorias, treinamentos e configurações da homologação.")' />
}
else
{
    <div class="row g-3">
    @foreach (var item in ocorrencias)
    {
        <div class="col-lg-6">
            <div class="card h-100 @(item.Prioridade == "CRITICA" ? "border-danger" : string.Empty)">
                <div class="card-body">
                    <div class="d-flex justify-content-between gap-2 mb-2">
                        <div><span class="badge text-bg-secondary">@item.Tipo</span> <span class="badge @(item.Prioridade == "CRITICA" ? "text-bg-danger" : "text-bg-warning")">@item.Prioridade</span></div>
                        <span class="badge text-bg-light">@item.Status</span>
                    </div>
                    <p>@item.Descricao</p>
                    <p class="small text-muted mb-2">Responsável: @item.Responsavel · Aberta em @item.DataAbertura.ToString("dd/MM/yyyy HH:mm")</p>
                    @if (item.Status != "RESOLVIDA")
                    {
                        <form asp-action="ResolverOcorrencia" method="post" class="d-flex gap-2" data-confirm="true" data-confirm-title="Resolver ocorrência" data-confirm-message="Confirma resolver esta ocorrência? Informe a solução aplicada antes de continuar." data-confirm-type="success">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="clienteId" value="@item.ClienteId" />
                            <input name="solucao" class="form-control form-control-sm" placeholder="Solução aplicada" required />
                            <button type="submit" class="btn btn-sm btn-outline-success">Resolver</button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success py-2 mb-0">@item.Solucao</div>
                    }
                </div>
            </div>
        </div>
    }
    </div>
}
