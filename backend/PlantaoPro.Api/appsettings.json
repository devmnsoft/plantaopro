      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "LoginLockoutEnabled": true,
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15,
    "FailedAttemptWindowMinutes": 30
  },
  "Demo": {
    "Enabled": false
  }
}
