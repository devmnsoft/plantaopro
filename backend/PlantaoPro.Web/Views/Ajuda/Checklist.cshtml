@model PlantaoPro.Web.Models.AjudaInterativaChecklistViewModel
@{
    ViewData["Title"] = "Checklist de Primeiros Passos";
}
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Checklist por perfil", "Primeiros passos para administrador, coordenação, médico, financeiro e hospital.", "bi-ui-checks")' />
<div class="card">
    <div class="card-body">
        <h2 class="h5">Perfil: @Model.Perfil</h2>
        @if (Model.Artigos.Any())
        {
            <ol class="list-group list-group-numbered list-group-flush">
            @foreach (var artigo in Model.Artigos)
            {
                <li class="list-group-item d-flex justify-content-between align-items-start">
                    <div class="ms-2 me-auto"><div class="fw-semibold">@artigo.Titulo</div><span class="text-muted small">@artigo.Resumo</span></div>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Artigo" asp-route-id="@artigo.Id">Ver</a>
                </li>
            }
            </ol>
        }
        else
        {
            <partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-ui-checks", "Checklist vazio", "Selecione outro perfil para ver os primeiros passos.")' />
        }
    </div>
</div>
