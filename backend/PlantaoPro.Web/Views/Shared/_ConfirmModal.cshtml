@model PlantaoPro.Web.Models.ConfirmModalViewModel?
@{
    var modal = Model ?? new PlantaoPro.Web.Models.ConfirmModalViewModel();

    var id = string.IsNullOrWhiteSpace(modal.Id)
        ? "pp-confirm-modal"
        : modal.Id;

    var title = string.IsNullOrWhiteSpace(modal.Title)
        ? "Confirmar ação"
        : modal.Title;

    var message = string.IsNullOrWhiteSpace(modal.Message)
        ? "Deseja realmente continuar?"
        : modal.Message;

    var confirmText = string.IsNullOrWhiteSpace(modal.ConfirmText)
        ? "Confirmar"
        : modal.ConfirmText;

    var cancelText = string.IsNullOrWhiteSpace(modal.CancelText)
        ? "Cancelar"
        : modal.CancelText;

    var requestedType = string.IsNullOrWhiteSpace(modal.Type)
        ? "warning"
        : modal.Type.Trim().ToLowerInvariant();

    var allowedTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "primary", "secondary", "success", "danger", "warning", "info"
    };

    var type = allowedTypes.Contains(requestedType)
        ? requestedType
        : "warning";
}

<div class="modal fade" id="@id" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content pp-confirm-modal pp-confirm-modal-@type">
            <div class="modal-header">
                <div>
                    <span class="pp-confirm-kicker">Confirmação necessária</span>
                    <h5 class="modal-title mb-0" data-pp-confirm-title>@title</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">
                <p class="mb-0" data-pp-confirm-message>@message</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">@cancelText</button>
                <button type="button" class="btn btn-primary" data-pp-confirm-action>
                    <i class="bi bi-check2-circle me-1"></i>@confirmText
                </button>
            </div>
        </div>
    </div>
</div>
