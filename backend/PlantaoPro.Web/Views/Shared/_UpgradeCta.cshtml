@model string
<div class="card border-primary shadow-sm">
    <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <h2 class="h5 mb-1">Precisa de mais capacidade?</h2>
            <p class="text-muted mb-0">@(string.IsNullOrWhiteSpace(Model) ? "Faça upgrade para liberar mais limites, módulos e white label avançado." : Model)</p>
        </div>
        <a class="btn btn-primary" asp-controller="MinhaAssinatura" asp-action="Upgrade">Comparar upgrades</a>
    </div>
</div>
