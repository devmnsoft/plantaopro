@model PlantaoPro.Web.Models.ListPageViewModel<PlantaoPro.Web.Models.HospitalDto>
@{ ViewData["Title"] = "Hospitais e Clínicas"; var items = Model?.Items ?? Enumerable.Empty<PlantaoPro.Web.Models.HospitalDto>(); }
<partial name="_PageHeader" model='new PlantaoPro.Web.Models.PageHeaderViewModel("Hospitais e Clínicas","Gestão das unidades contratantes e locais de realização dos plantões.","bi-hospital","Novo Hospital","Create","Hospitais",false)' />
@if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage)){<div class="alert alert-warning">@Model.ErrorMessage</div>}
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Hospital</th><th>CNPJ</th><th>Cidade/UF</th><th>Contato</th><th>Status</th><th class="text-end">Ações</th></tr></thead><tbody>
@if (items.Any()) { foreach (var row in items) { <tr><td><div class="fw-semibold">@row.NomeFantasia</div><div class="text-muted small">@row.RazaoSocial</div></td><td>@row.Cnpj</td><td>@row.Cidade/@row.Estado</td><td><div>@row.Telefone</div><div class="text-muted small">@row.Responsavel</div></td><td><partial name="_StatusBadge" model='@(string.Equals(row.RegStatus,"A",StringComparison.OrdinalIgnoreCase) ? "ativo" : "inativo")' /></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@row.Id"><i class="bi bi-eye"></i></a> <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@row.Id" title="Editar"><i class="bi bi-pencil"></i></a> <form asp-action="Delete" asp-route-id="@row.Id" method="post" class="d-inline" data-confirm="true" data-confirm-message="Inativar este hospital?">@Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-outline-danger" title="Inativar"><i class="bi bi-trash"></i></button></form></td></tr> } } else { <tr><td colspan="6" class="py-5"><partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-hospital","Nenhum hospital encontrado","Cadastre hospitais para começar a operar plantões.")' /></td></tr> }
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model="Model" /></div></div>
