@model PlantaoPro.Web.Models.PageHeaderViewModel

<div class="page-header d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div class="d-flex align-items-start gap-3">
        @if (!string.IsNullOrWhiteSpace(Model.Icon))
        {
            <div class="page-header-icon"><i class="bi @Model.Icon"></i></div>
        }
        <div>
            <h2 class="mb-1">@Model.Title</h2>
            <p class="text-muted mb-0">@Model.Subtitle</p>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.ButtonText))
    {
        if (!Model.ButtonDisabled && !string.IsNullOrWhiteSpace(Model.ButtonAction) && !string.IsNullOrWhiteSpace(Model.ButtonController))
        {
            <a class="btn btn-primary" asp-action="@Model.ButtonAction" asp-controller="@Model.ButtonController">@Model.ButtonText</a>
        }
        else
        {
            <button class="btn btn-primary" disabled title="Em breve">@Model.ButtonText</button>
        }
    }
</div>
