@model PlantaoPro.Web.Models.PlanosSaasIndexViewModel
@{
    ViewData["Title"] = "Planos SaaS";
    var planos = Model.Planos.Items ?? Array.Empty<PlantaoPro.Web.Models.PlanoSaasViewModel>();
}
<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3">Planos SaaS</h1><p class="text-muted">Catálogo comercial, limites e recursos.</p></div><a class="btn btn-primary" asp-action="Create">Novo plano</a></div>
    <form method="get" class="card card-body mb-3"><div class="row g-2"><div class="col-md-4"><select class="form-select" name="status"><option value="">Todos os status</option><option value="ATIVO" selected="@(Model.Status == "ATIVO")">ATIVO</option><option value="INATIVO" selected="@(Model.Status == "INATIVO")">INATIVO</option><option value="ARQUIVADO" selected="@(Model.Status == "ARQUIVADO")">ARQUIVADO</option></select></div><div class="col-md-4"><button class="btn btn-outline-primary" type="submit">Filtrar</button> <a class="btn btn-outline-secondary" asp-action="Comparativo">Comparativo</a></div></div></form>
    <div class="row g-3">
    @if (!planos.Any()) { <div class="col-12"><partial name="_EmptyState" model='new PlantaoPro.Web.Models.EmptyStateViewModel("bi-layers", "Nenhum plano encontrado", "Cadastre planos SaaS para iniciar assinaturas.", "Novo plano", "Create", "Planos")' /></div> }
    else { foreach (var item in planos) { <div class="col-md-4"><div class="card h-100"><div class="card-body"><div class="d-flex justify-content-between"><h2 class="h5">@item.Nome</h2><span class="badge bg-secondary">@item.Status</span></div><p class="text-muted">@item.Descricao</p><div class="h4">@item.ValorMensal.ToString("C")</div><div class="small">Médicos: @item.LimiteMedicos | Hospitais: @item.LimiteHospitais | Plantões/mês: @item.LimitePlantoesMes</div><div class="mt-2"><span class="badge bg-info">Mobile: @(item.PermiteMobile ? "Sim" : "Não")</span> <span class="badge bg-info">BI: @(item.PermiteBi ? "Sim" : "Não")</span></div></div><div class="card-footer bg-white d-flex gap-2"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Detalhes</a><a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Editar</a><a class="btn btn-sm btn-outline-success" asp-action="Recursos" asp-route-id="@item.Id">Recursos</a><form asp-action="AlterarStatus" method="post" data-confirm="true" data-confirm-message="Alterar status do plano?">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="acao" value="@(item.Status == "ATIVO" ? "INATIVAR" : "REATIVAR")" /><button class="btn btn-sm btn-outline-warning" type="submit">@(item.Status == "ATIVO" ? "Inativar" : "Reativar")</button></form></div></div></div> } }
    </div>
</div>
