@model IEnumerable<PlantaoPro.Web.Models.JornadaTarefaViewModel>
@{ ViewData["Title"] = "Tarefas da jornada"; }
<div class="card shadow-sm"><div class="card-body"><h2 class="h5">Tarefas pendentes e concluídas</h2><table class="table"><thead><tr><th>Cliente</th><th>Tarefa</th><th>Responsável</th><th>Prazo</th><th>Status</th></tr></thead><tbody>@foreach (var item in Model) { <tr><td>@item.ClienteNome</td><td>@item.Titulo<br /><small>@item.Descricao</small></td><td>@item.Responsavel</td><td>@item.Prazo</td><td><span class="badge text-bg-info">@item.Status</span></td></tr> }</tbody></table></div></div>
