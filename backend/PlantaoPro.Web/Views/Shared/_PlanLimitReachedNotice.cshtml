@model PlantaoPro.Web.Models.LockedResourceViewModel
<div class="module-locked-notice plan-limit-notice">
    <div class="d-flex align-items-start gap-3">
        <div class="module-locked-icon"><i class="bi bi-speedometer2"></i></div>
        <div>
            <strong>Limite do plano atingido: @Model.Recurso</strong>
            <p class="mb-2">@Model.Motivo Plano atual: <b>@Model.PlanoAtual</b>. Plano necessário: <b>@Model.PlanoNecessario</b>. Uso atual: <b>@Model.UsoAtual</b> de <b>@Model.LimiteContratado</b>.</p>
            <a class="btn btn-sm btn-primary" asp-controller="MinhaAssinatura" asp-action="Upgrade">Solicitar upgrade</a>
            <a class="btn btn-sm btn-outline-secondary" asp-controller="Suporte" asp-action="Index">Falar com suporte</a>
        </div>
    </div>
</div>
