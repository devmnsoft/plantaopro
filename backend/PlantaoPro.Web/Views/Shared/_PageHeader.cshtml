@model (string Title, string Subtitle, string? Icon, string? PrimaryActionText, string? PrimaryActionUrl, bool PrimaryActionDisabled)

<div class="page-header d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div class="d-flex align-items-start gap-3">
        @if (!string.IsNullOrWhiteSpace(Model.Icon))
        {
            <div class="page-header-icon"><i class="bi @Model.Icon"></i></div>
        }
        <div>
            <h2 class="mb-1">@Model.Title</h2>
            <p class="text-muted mb-0">@Model.Subtitle</p>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.PrimaryActionText))
    {
        if (!Model.PrimaryActionDisabled && !string.IsNullOrWhiteSpace(Model.PrimaryActionUrl))
        {
            <a class="btn btn-primary" href="@Model.PrimaryActionUrl">@Model.PrimaryActionText</a>
        }
        else
        {
            <button class="btn btn-primary" disabled title="Em breve">@Model.PrimaryActionText</button>
        }
    }
</div>
