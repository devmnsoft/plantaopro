@model (string Icon, string Title, string Description, string? ActionText, string? ActionUrl, bool ActionDisabled)

<div class="empty-state text-center">
    <div class="empty-state-icon"><i class="bi @Model.Icon"></i></div>
    <h5 class="mb-2">@Model.Title</h5>
    <p class="text-muted mb-3">@Model.Description</p>
    @if (!string.IsNullOrWhiteSpace(Model.ActionText))
    {
        if (!Model.ActionDisabled && !string.IsNullOrWhiteSpace(Model.ActionUrl))
        {
            <a class="btn btn-soft-primary" href="@Model.ActionUrl">@Model.ActionText</a>
        }
        else
        {
            <button class="btn btn-soft-primary" disabled title="Em breve">@Model.ActionText</button>
        }
    }
</div>
