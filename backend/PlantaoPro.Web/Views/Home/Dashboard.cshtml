@model DashboardOverviewDto
@using PlantaoPro.Web.Security
@{
    ViewData["Title"] = "Visão Geral Saúde 360";
    var i = Model?.Indicadores;
    var proximos = Model?.ProximosPlantoes ?? Enumerable.Empty<PlantaoPro.Web.Models.PlantaoResumoDto>();
    var porEspecialidade = Model?.PlantoesPorEspecialidade ?? Enumerable.Empty<DashboardChartItem>();
    var porHospital = Model?.PlantoesPorHospital ?? Enumerable.Empty<DashboardChartItem>();
    var notificacoes = Model?.UltimasNotificacoes ?? Enumerable.Empty<NotificacaoDto>();

    var isAdmin = User.IsAdmin();
    var isCoord = User.IsCoordenacao();
    var isMed = User.IsMedico();
    var isFin = User.IsFinanceiro();
    var isHosp = User.IsHospital();

    var perfilLabel = isAdmin ? "Admin" : isCoord ? "Coordenação" : isMed ? "Médico" : isFin ? "Financeiro" : isHosp ? "Hospital" : "Operacional";
    var tituloVisao = isMed ? "Minha Agenda" : isFin ? "KPIs Financeiros" : isHosp ? "Visão da Unidade" : "Visão Operacional";
    var queryInicio = Context.Request.Query["inicio"].ToString();
    var queryFim = Context.Request.Query["fim"].ToString();
    var queryHospital = Context.Request.Query["hospital"].ToString();
    var queryEspecialidade = Context.Request.Query["especialidade"].ToString();
}

<div class="page-header mb-4 d-flex flex-wrap justify-content-between gap-3 align-items-start">
    <div>
        <img src="~/branding/logo-horizontal-dark.svg" class="dashboard-brand mb-2" alt="PlantãoPro" />
        <h2 class="page-title">Olá, Administrador. Veja o resumo da sua operação hoje.</h2>
        <p class="page-subtitle mb-0">PlantãoPro Saúde 360 centraliza atendimento, plantões, financeiro, convênios, relatórios e gestão SaaS em uma jornada pronta para demonstração comercial.</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <span class="badge text-bg-light border">Perfil: @perfilLabel</span>
        <a asp-controller="ClinicaDashboard" asp-action="FluxoAtendimento" class="btn btn-primary btn-sm"><i class="bi bi-signpost-2 me-1"></i>Iniciar jornada guiada</a>
        <a asp-controller="MinhaAssinatura" asp-action="Upgrade" class="btn btn-outline-warning btn-sm"><i class="bi bi-rocket-takeoff me-1"></i>Upgrade</a>
    </div>
</div>
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form class="row g-2" method="get" asp-controller="Home" asp-action="Dashboard">
            <div class="col-12 col-md-3"><input type="date" name="inicio" value="@queryInicio" class="form-control form-control-sm" aria-label="Início" /></div>
            <div class="col-12 col-md-3"><input type="date" name="fim" value="@queryFim" class="form-control form-control-sm" aria-label="Fim" /></div>
            <div class="col-12 col-md-3"><input type="text" name="hospital" value="@queryHospital" class="form-control form-control-sm" placeholder="Hospital" /></div>
            <div class="col-12 col-md-3"><input type="text" name="especialidade" value="@queryEspecialidade" class="form-control form-control-sm" placeholder="Especialidade" /></div>
            <div class="col-12 col-md-3 d-grid"><button type="submit" class="btn btn-outline-primary btn-sm">Aplicar filtros</button></div>
            <div class="col-12 col-md-3 d-grid"><a asp-action="Dashboard" class="btn btn-light btn-sm">Limpar</a></div>
        </form>
    </div>
</div>


<div class="row g-3 mb-4">
@foreach (var a in new[] {
("Cadastrar paciente","Pacientes","Create","bi-person-plus","Cadastre ou localize o paciente antes de iniciar o atendimento."),
("Criar agendamento","Agendamentos","Create","bi-calendar2-plus","Agende consulta, retorno, procedimento ou encaixe."),
("Fazer check-in","Agendamentos","CheckIn","bi-person-check","Confirme a chegada do paciente."),
("Abrir painel","PainelChamada","Index","bi-megaphone","Chame para sala, guichê ou triagem."),
("Realizar triagem","Triagem","Create","bi-clipboard2-pulse","Classifique risco e sinais vitais."),
("Iniciar consulta","Consultas","Atendimento","bi-journal-medical","Registre atendimento e conduta."),
("Emitir prescrição","Prescricoes","Create","bi-capsule","Gere prescrição auditável."),
("Receber pagamento","ClinicaFinanceiro","Receber","bi-cash-coin","Finalize cobrança particular ou coparticipação.")
})
{
    <div class="col-12 col-md-6 col-xl-3"><a asp-controller="@a.Item2" asp-action="@a.Item3" class="card border-0 shadow-sm h-100 text-decoration-none text-reset"><div class="card-body"><div class="d-flex align-items-start gap-3"><div class="kpi-icon"><i class="bi @a.Item4"></i></div><div><strong>@a.Item1</strong><p class="text-muted small mb-0">@a.Item5</p></div></div></div></a></div>
}
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-7"><div class="card border-0 shadow-sm h-100"><div class="card-header bg-white"><strong>O que fazer agora?</strong></div><div class="card-body"><ol class="mb-0"><li>Verificar pacientes aguardando e realizar chamadas pendentes.</li><li>Finalizar triagens em aberto antes de iniciar novas consultas.</li><li>Conferir pagamentos e autorizações pendentes do dia.</li></ol></div></div></div>
    <div class="col-lg-5"><div class="card border-0 shadow-sm h-100"><div class="card-header bg-white d-flex justify-content-between"><strong>Plano atual</strong><span class="badge text-bg-primary">Profissional</span></div><div class="card-body"><p class="mb-2">Recursos liberados: atendimento, plantões, financeiro, CID e prescrições.</p><p class="text-muted small mb-3">Premium: convênios avançados, BI SaaS e white label completo.</p><a asp-controller="MinhaAssinatura" asp-action="Upgrade" class="btn btn-warning btn-sm">Ver upgrade</a></div></div></div>
</div>

<div class="row g-3 mb-4 kpi-grid">
@foreach (var m in new[] {
("Plantões",(i?.TotalPlantoes ?? 0).ToString(),"bi-calendar2-week"),
("Confirmados",(i?.PlantoesConfirmados ?? 0).ToString(),"bi-check2-circle"),
("Pendentes",(i?.PagamentosPendentes ?? 0).ToString(),"bi-cash"),
("Notificações",(i?.NotificacoesNaoLidas ?? 0).ToString(),"bi-bell")
})
{
    <div class="col-6 col-lg-3"><div class="metric-card h-100"><div class="kpi-icon"><i class="bi @m.Item3"></i></div><div class="kpi-title">@m.Item1</div><div class="metric-value">@m.Item2</div></div></div>
}
</div>

@if ((i?.PagamentosPendentes ?? 0) > 0 || (i?.NotificacoesNaoLidas ?? 0) > 0)
{
    <div class="alert alert-warning border-0 shadow-sm">
        <div class="d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Ações críticas detectadas.</strong>
                Há @(i?.PagamentosPendentes ?? 0) pagamentos pendentes e @(i?.NotificacoesNaoLidas ?? 0) notificações não lidas.
            </div>
        </div>
    </div>
}

<div class="row g-3">
    <div class="col-12 col-xxl-8">
        <div class="data-card card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@(isMed ? "Minha Agenda" : "Próximos plantões e escalas")</strong>
                <span class="badge text-bg-light border">Atualizado agora</span>
            </div>
            <div class="table-responsive">
                <table class="table table-modern"><thead><tr><th>Hospital</th><th>Especialidade</th><th>Início</th><th>Status</th></tr></thead><tbody>
                @if(proximos.Any())
                {
                    foreach(var p in proximos.Take(8))
                    {
                        <tr><td>@(p.HospitalNome ?? "—")</td><td>@(p.EspecialidadeNome ?? "—")</td><td>@p.DataInicio.ToString("dd/MM/yyyy HH:mm")</td><td><partial name="_StatusBadge" model="p.Status" /></td></tr>
                    }
                }
                else
                { <tr><td colspan="4"><div class="empty-state">Nenhum plantão encontrado no período selecionado.</div></td></tr> }
                </tbody></table>
            </div>
        </div>
    </div>
    <div class="col-12 col-xxl-4">
        <div class="data-card card h-100">
            <div class="card-header"><strong>@(isFin ? "KPIs Financeiros" : isHosp ? "Visão da Unidade" : "Distribuição")</strong></div>
            <div class="card-body">
                @if(isFin)
                {
                    <ul class="list-group list-group-flush"><li class="list-group-item d-flex justify-content-between"><span>Valor pendente</span><strong>@(i?.ValorPendente ?? 0).ToString("C")</strong></li><li class="list-group-item d-flex justify-content-between"><span>Pago no mês</span><strong>@(i?.ValorPagoMes ?? 0).ToString("C")</strong></li></ul>
                }
                else if(isHosp && porHospital.Any())
                {
                    foreach(var it in porHospital.Take(6)){<div class="d-flex justify-content-between border-bottom py-1"><span>@it.Label</span><strong>@it.Valor</strong></div>}
                }
                else if(porEspecialidade.Any())
                {
                    foreach(var it in porEspecialidade.Take(6)){<div class="mb-2"><div class="d-flex justify-content-between"><span>@it.Label</span><span>@it.Valor</span></div><div class="progress"><div class="progress-bar" style="width:@(Math.Min(it.Valor*10,100))%"></div></div></div>}
                }
                else
                { <div class="empty-state">Sem dados no período.</div> }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-12 col-xl-7"><div class="data-card card"><div class="card-header"><strong>Resumo visual da semana</strong></div><div class="card-body"><canvas id="kpiChart" height="100"></canvas></div></div></div>
    <div class="col-12 col-xl-5"><div class="data-card card"><div class="card-header d-flex justify-content-between"><strong>Notificações in-app</strong><a asp-controller="Notificacoes" asp-action="Index" class="small">Ver todas</a></div><div class="card-body">
        @if(notificacoes.Any()){
            foreach(var n in notificacoes.Take(5)){<div class="border-bottom py-2"><div class="d-flex justify-content-between"><strong>@n.Titulo</strong><span class="badge @(n.Lida ? "text-bg-light" : "text-bg-warning")">@(n.Lida ? "Lida" : "Nova")</span></div><div class="text-muted small">@n.Mensagem</div></div>}
        } else { <div class="empty-state">Sem notificações recentes.</div> }
    </div></div></div>
</div>

@section Scripts{
<script>
document.addEventListener("DOMContentLoaded",()=>{
  if(!window.Chart) return;
  const ctx=document.getElementById("kpiChart");
  if(!ctx) return;
  const labels=[@Html.Raw(string.Join(",", (Model?.PlantoesPorMes ?? Enumerable.Empty<DashboardChartItem>()).Select(x=>$"\"{x.Label}\"")))];
  const values=[@Html.Raw(string.Join(",", (Model?.PlantoesPorMes ?? Enumerable.Empty<DashboardChartItem>()).Select(x=>x.Valor.ToString(System.Globalization.CultureInfo.InvariantCulture))))];
  new Chart(ctx,{type:"bar",data:{labels:labels.length?labels:["Sem dados"],datasets:[{label:"Plantões por mês",data:values.length?values:[0],borderRadius:8,backgroundColor:"#155eef"}]},options:{plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}});
});
</script>
}
