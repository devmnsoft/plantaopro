@model ResetPasswordViewModel
<div class="container py-5"><div class="card p-4 mx-auto" style="max-width:520px"><h3>Redefinir senha</h3><form asp-action="ResetPassword" method="post">@Html.AntiForgeryToken()<input asp-for="Email" type="hidden"/><input asp-for="Token" type="hidden"/><label asp-for="NovaSenha" class="form-label"></label><input asp-for="NovaSenha" class="form-control" type="password"/><span asp-validation-for="NovaSenha" class="text-danger"></span><label asp-for="ConfirmarSenha" class="form-label mt-2"></label><input asp-for="ConfirmarSenha" class="form-control" type="password"/><span asp-validation-for="ConfirmarSenha" class="text-danger"></span><button class="btn btn-success mt-3"><i class="bi bi-check2-circle"></i> Redefinir senha</button></form></div></div>
