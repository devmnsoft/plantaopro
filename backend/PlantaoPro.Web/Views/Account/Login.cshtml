@model LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login • PlantãoPro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
</head>
<body class="auth-main">
<div class="login-shell container py-4">
    @await Html.PartialAsync("_ToastMessages")
    <div class="login-card-modern">
        <div class="brand-block text-center">
            <div class="login-card-brand">
                <img src="~/branding/logo-icon.svg" alt="PlantãoPro" class="login-logo" />
                <img src="~/branding/logo-horizontal-light.svg" alt="PlantãoPro" class="img-fluid" style="max-width:220px" />
            </div>
            <h2 class="mt-3 mb-1">Bem-vindo de volta</h2>
            <p class="text-muted mb-4">Acesse sua conta e acompanhe operação, agenda e financeiro em tempo real.</p>
        </div>
        <form asp-action="Login" method="post" id="loginForm" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            @if (TempData["Warning"] is string warningMessage && !string.IsNullOrWhiteSpace(warningMessage))
            {
                <div class="alert alert-warning py-2 small">
                    <i class="bi bi-shield-exclamation me-1"></i>@warningMessage
                </div>
            }
            <div class="alert alert-info py-2 small">
                <strong>Ambiente de demonstração:</strong> use <code>admin@plantaopro.com</code> e senha <code>123456</code>.
            </div>
            <div class="mb-3"><label asp-for="Email" class="form-label">E-mail</label><input asp-for="Email" class="form-control form-control-lg" placeholder="voce@empresa.com" /><span asp-validation-for="Email" class="text-danger small"></span></div>
            <div class="mb-3"><label asp-for="Senha" class="form-label">Senha</label><div class="input-group"><input asp-for="Senha" class="form-control form-control-lg" type="password" id="senha" placeholder="Sua senha" /><button class="btn btn-outline-secondary" type="button" onclick="togglePassword('senha',this)"><i class="bi bi-eye"></i></button></div><span asp-validation-for="Senha" class="text-danger small"></span></div>
            <button id="btnLogin" class="btn btn-primary btn-lg w-100" type="submit"><span class="label">Entrar</span><span class="spinner-border spinner-border-sm d-none"></span></button>
            <div class="form-text mt-2">Após múltiplas falhas, o acesso é bloqueado temporariamente por segurança.</div>
            <a asp-action="ForgotPassword" class="d-inline-block mt-3">Esqueci a senha</a>
        </form>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
